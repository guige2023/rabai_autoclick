{
  "name": "Fitness Billing Processing Workflow",
  "description": "Automate fitness billing processing",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "billing_items": 49,
    "current_item": 0,
    "processed_items": 0,
    "failed_payments": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "billing_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize billing counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open billing processing system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "billing_processing_loop",
      "count": "{{billing_items}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start billing processing loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select billing item for processing"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for processing"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/billing_processing_{{billing_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture processing screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "billing_counter",
      "value": "{{billing_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment billing counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{billing_counter < billing_items}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more items"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next item"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/fitness_billing_processing_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
