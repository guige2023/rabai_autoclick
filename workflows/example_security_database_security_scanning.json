{
  "name": "Security Database Security Scanning Workflow",
  "description": "Automate database security vulnerability scanning",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "databases_to_scan": 52,
    "current_database": 0,
    "scanned_databases": 0,
    "vulnerable_databases": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "database_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize database counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open database security scanner"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for scanner"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "database_scan_loop",
      "count": "{{databases_to_scan}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start database scanning loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select database for scanning"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for vulnerability scan"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/database_scan_{{database_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture database scan screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "database_counter",
      "value": "{{database_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment database counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{database_counter < databases_to_scan}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more databases"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next database"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_database_security_scanning_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
