{
  "name": "Contractor Timesheet Approval Workflow",
  "description": "Automate contractor timesheet approval including hour verification and budget allocation",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "timesheets_to_process": 45,
    "current_timesheet": 0,
    "approved_timesheets": 0,
    "rejected_timesheets": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "timesheet_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize timesheet counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open timesheet management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for system to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "timesheet_loop",
      "count": "{{timesheets_to_process}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start timesheet approval loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open contractor timesheet"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for timesheet"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/timesheet_{{timesheet_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture timesheet screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Verify hours logged"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for verification"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Check project budget allocation"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for budget check"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Approve or reject timesheet"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for decision"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/timesheet_approved_{{timesheet_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture approval confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "timesheet_counter",
      "value": "{{timesheet_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment timesheet counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{timesheet_counter < timesheets_to_process}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more timesheets"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next timesheet"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/timesheet_approval_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
