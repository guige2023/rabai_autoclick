{
  "name": "Backup Schedule Verification Workflow",
  "description": "Automate backup schedule compliance verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "backup_jobs_to_verify": 25,
    "current_job": 0,
    "compliant_count": 0,
    "missed_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "job_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize job counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open backup management"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for management"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "backup_verify_loop",
      "count": "{{backup_jobs_to_verify}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start backup verification loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select backup job"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for schedule check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/backup_schedule_{{job_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture schedule screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "job_counter",
      "value": "{{job_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment job counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{job_counter < backup_jobs_to_verify}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more jobs"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next job"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/backup_schedule_verification_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}