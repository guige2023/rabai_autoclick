{
  "name": "Healthcare Lab Results Tracking Workflow",
  "description": "Automate laboratory results tracking",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "lab_results": 53,
    "current_result": 0,
    "tracked_results": 0,
    "critical_alerts": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "lab_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize lab counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open lab results system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "lab_results_loop",
      "count": "{{lab_results}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start lab results tracking loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select lab result for tracking"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for result review"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/lab_results_{{lab_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture lab result screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "lab_counter",
      "value": "{{lab_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment lab counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{lab_counter < lab_results}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more results"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next result"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/healthcare_lab_results_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
