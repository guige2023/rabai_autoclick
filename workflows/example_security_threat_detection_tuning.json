{
  "name": "Security Threat Detection Tuning Workflow",
  "description": "Automate threat detection rule tuning and optimization",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "detection_rules_to_tune": 44,
    "current_rule": 0,
    "optimized_rules": 0,
    "rules_needing_review": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "rule_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize rule counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open threat detection platform"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for platform"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "detection_tuning_loop",
      "count": "{{detection_rules_to_tune}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start detection tuning loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select detection rule"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for rule analysis"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/detection_tuning_{{rule_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture detection rule screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "rule_counter",
      "value": "{{rule_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment rule counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{rule_counter < detection_rules_to_tune}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more rules"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next rule"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_threat_detection_tuning_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
