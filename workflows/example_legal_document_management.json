{
  "name": "Legal Document Management Workflow",
  "description": "Automate legal document tracking and management",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "documents_to_track": 77,
    "current_document": 0,
    "tracked_documents": 0,
    "pending_reviews": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "document_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize document counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open document management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "document_management_loop",
      "count": "{{documents_to_track}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start document management loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select document for tracking"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for document update"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/document_management_{{document_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture document screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "document_counter",
      "value": "{{document_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment document counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{document_counter < documents_to_track}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more documents"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next document"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/legal_document_management_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
