{
  "name": "Security Social Engineering Simulation Workflow",
  "description": "Automate social engineering attack simulations",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "simulations_to_run": 52,
    "current_simulation": 0,
    "completed_simulations": 0,
    "successful_attacks": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "simulation_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize simulation counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open social engineering platform"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for platform"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "social_engineering_loop",
      "count": "{{simulations_to_run}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start social engineering loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Launch simulation"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for simulation"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/social_engineering_{{simulation_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture simulation screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "simulation_counter",
      "value": "{{simulation_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment simulation counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{simulation_counter < simulations_to_run}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more simulations"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next simulation"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_social_engineering_simulation_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
