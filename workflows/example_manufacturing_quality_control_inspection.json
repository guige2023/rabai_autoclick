{
  "name": "Manufacturing Quality Control Inspection Workflow",
  "description": "Automate manufacturing quality control inspection from sampling to defect logging",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "inspections_to_complete": 50,
    "current_inspection": 0,
    "passed_inspections": 0,
    "failed_inspections": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "inspection_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize inspection counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open quality management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for QMS to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "inspection_loop",
      "count": "{{inspections_to_complete}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start inspection loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select inspection batch"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for batch details"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/inspection_{{inspection_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture inspection screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Record measurement data"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for recording"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Compare against specifications"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for comparison"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Log inspection results"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for logging"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/inspection_result_{{inspection_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture result screenshot"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "inspection_counter",
      "value": "{{inspection_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment inspection counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{inspection_counter < inspections_to_complete}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more inspections"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next inspection"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/inspection_batch_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture batch completion"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
