{
  "name": "Security Security Operations Automation Workflow",
  "description": "Automate security operations center workflows",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "operations_to_automate": 58,
    "current_operation": 0,
    "automated_operations": 0,
    "failed_operations": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "operation_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize operation counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open security automation platform"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for platform"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "secops_automation_loop",
      "count": "{{operations_to_automate}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start security automation loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select operation to automate"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for automation"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/secops_automation_{{operation_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture automation screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "operation_counter",
      "value": "{{operation_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment operation counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{operation_counter < operations_to_automate}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more operations"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next operation"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_security_operations_automation_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
