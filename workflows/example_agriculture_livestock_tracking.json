{
  "name": "Agriculture Livestock Tracking Workflow",
  "description": "Automate livestock tracking",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "animals_to_track": 52,
    "current_animal": 0,
    "tracked_animals": 0,
    "health_alerts": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "livestock_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize livestock counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open livestock tracking system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "livestock_tracking_loop",
      "count": "{{animals_to_track}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start livestock tracking loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select animal for tracking"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for tracking update"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/livestock_tracking_{{livestock_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture tracking screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "livestock_counter",
      "value": "{{livestock_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment livestock counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{livestock_counter < animals_to_track}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more animals"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next animal"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/agriculture_livestock_tracking_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
