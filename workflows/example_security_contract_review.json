{
  "name": "Security Contract Review Workflow",
  "description": "Automate security contract clause verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "contract_clauses_to_review": 52,
    "current_clause": 0,
    "compliant_clauses": 0,
    "non_compliant_clauses": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "contract_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize contract counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open contract management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "contract_review_loop",
      "count": "{{contract_clauses_to_review}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start contract review loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select contract clause"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for clause review"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/contract_review_{{contract_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture contract screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "contract_counter",
      "value": "{{contract_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment contract counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{contract_counter < contract_clauses_to_review}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more clauses"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next clause"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_contract_review_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}