{
  "name": "Storage Cleanup Workflow",
  "description": "Automate storage cleanup and optimization",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "directories_to_clean": 8,
    "current_directory": 0,
    "files_deleted": 0,
    "space_freed_mb": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "directory_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize directory counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open file manager"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for manager"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "cleanup_loop",
      "count": "{{directories_to_clean}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start cleanup loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Click directory"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for scan"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/cleanup_{{directory_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture cleanup screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "directory_counter",
      "value": "{{directory_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment directory counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{directory_counter < directories_to_clean}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more directories"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next directory"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/storage_cleanup_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
