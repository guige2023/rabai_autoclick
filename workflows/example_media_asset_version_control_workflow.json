{
  "name": "Media Asset Version Control Workflow",
  "description": "Automate media asset version control including version tracking, approval, and archival",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "assets_to_version": 40,
    "current_asset": 0,
    "versioned_assets": 0,
    "pending_approvals": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "asset_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize asset counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open DAM system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for DAM to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "versioning_loop",
      "count": "{{assets_to_version}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start version control loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open asset for versioning"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for asset"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/asset_{{asset_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture asset screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Create new version"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for version creation"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Update metadata"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for metadata update"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Archive old version"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for archival"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/asset_versioned_{{asset_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture versioning confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "asset_counter",
      "value": "{{asset_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment asset counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{asset_counter < assets_to_version}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more assets"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next asset"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/versioning_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
