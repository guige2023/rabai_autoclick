{
  "name": "Static Analysis Security Workflow",
  "description": "Automate static application security testing",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "code_modules_to_scan": 62,
    "current_module": 0,
    "clean_modules": 0,
    "vulnerable_modules": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "sast_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize SAST counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open SAST tool"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for tool"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "sast_scan_loop",
      "count": "{{code_modules_to_scan}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start SAST scan loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select code module"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for analysis"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/sast_scan_{{sast_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture SAST screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "sast_counter",
      "value": "{{sast_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment SAST counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{sast_counter < code_modules_to_scan}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more modules"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next module"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/static_analysis_security_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}