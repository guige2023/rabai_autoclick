{
  "name": "Fitness Class Scheduling Workflow",
  "description": "Automate fitness class scheduling",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "classes_to_schedule": 48,
    "current_class": 0,
    "scheduled_classes": 0,
    "instructor_assignments": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "class_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize class counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open class scheduling system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "class_scheduling_loop",
      "count": "{{classes_to_schedule}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start class scheduling loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select class for scheduling"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for scheduling"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/class_scheduling_{{class_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture scheduling screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "class_counter",
      "value": "{{class_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment class counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{class_counter < classes_to_schedule}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more classes"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next class"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/fitness_class_scheduling_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
