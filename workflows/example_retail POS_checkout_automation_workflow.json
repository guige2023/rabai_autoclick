{
  "name": "Retail POS Checkout Automation Workflow",
  "description": "Automate retail point of sale checkout including barcode scanning, discount application, and receipt generation",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "transactions_to_process": 60,
    "current_transaction": 0,
    "completed_transactions": 0,
    "voided_items": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "transaction_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize transaction counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open POS system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for POS to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "checkout_loop",
      "count": "{{transactions_to_process}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start checkout loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Scan item barcode"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for scan"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/transaction_{{transaction_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture transaction screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Apply discounts if applicable"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for discount"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Calculate total"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for calculation"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Process payment"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for payment"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/receipt_{{transaction_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture receipt"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "transaction_counter",
      "value": "{{transaction_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment transaction counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{transaction_counter < transactions_to_process}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more transactions"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next transaction"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/pos_checkout_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
