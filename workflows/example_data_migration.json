{
  "name": "Data Migration Workflow",
  "description": "Automate database data migration between systems",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "tables_to_migrate": 8,
    "current_table": 0,
    "records_migrated": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "table_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize table counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open migration tool"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for tool"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "migration_loop",
      "count": "{{tables_to_migrate}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start migration loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Click on table"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for migration"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/migration_{{table_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture migration screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "table_counter",
      "value": "{{table_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment table counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{table_counter < tables_to_migrate}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more tables"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next table"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/data_migration_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
