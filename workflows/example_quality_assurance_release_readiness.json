{
  "name": "Quality Assurance Release Readiness Workflow",
  "description": "Automate release readiness verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "readiness_checks_to_perform": 52,
    "current_check": 0,
    "completed_checks": 0,
    "failed_checks": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "readiness_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize readiness counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open release readiness dashboard"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for dashboard"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "release_readiness_loop",
      "count": "{{readiness_checks_to_perform}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start release readiness loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select readiness check"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for check execution"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/release_readiness_check_{{readiness_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture readiness screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "readiness_counter",
      "value": "{{readiness_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment readiness counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{readiness_counter < readiness_checks_to_perform}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more checks"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next check"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/quality_assurance_release_readiness_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
