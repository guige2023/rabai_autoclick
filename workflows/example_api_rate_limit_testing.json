{
  "name": "API API Rate Limit Testing Workflow",
  "description": "Automate API rate limit validation",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "rate_limits_to_test": 48,
    "current_limit": 0,
    "tested_limits": 0,
    "limit_breaches": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "rate_limit_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize rate limit counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open API rate limit testing tool"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for tool"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "rate_limit_testing_loop",
      "count": "{{rate_limits_to_test}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start rate limit testing loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select API for rate limit test"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for rate limit test"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/rate_limit_testing_{{rate_limit_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture rate limit screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "rate_limit_counter",
      "value": "{{rate_limit_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment rate limit counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{rate_limit_counter < rate_limits_to_test}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more rate limits"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next rate limit"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/api_api_rate_limit_testing_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
