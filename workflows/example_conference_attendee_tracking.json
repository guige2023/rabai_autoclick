{
  "name": "Conference Attendee Tracking Workflow",
  "description": "Automate conference attendee tracking",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "attendees_to_track": 50,
    "current_attendee": 0,
    "tracked_attendees": 0,
    "badge_printed": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "attendee_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize attendee counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open attendee tracking system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "attendee_tracking_loop",
      "count": "{{attendees_to_track}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start attendee tracking loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select attendee for tracking"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for tracking"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/attendee_tracking_{{attendee_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture tracking screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "attendee_counter",
      "value": "{{attendee_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment attendee counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{attendee_counter < attendees_to_track}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more attendees"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next attendee"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/conference_attendee_tracking_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
