{
  "name": "Logistics Inventory Tracking Workflow",
  "description": "Automate inventory tracking",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "items_to_track": 51,
    "current_item": 0,
    "tracked_items": 0,
    "discrepancies": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "tracking_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize tracking counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open inventory tracking system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "inventory_tracking_loop",
      "count": "{{items_to_track}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start inventory tracking loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select item for tracking"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for tracking update"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/inventory_tracking_{{tracking_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture tracking screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "tracking_counter",
      "value": "{{tracking_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment tracking counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{tracking_counter < items_to_track}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more items"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next item"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/logistics_inventory_tracking_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
