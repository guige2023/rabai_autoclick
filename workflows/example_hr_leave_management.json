{
  "name": "HR Leave Management Workflow",
  "description": "Automate leave management process",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "leave_requests_to_process": 48,
    "current_request": 0,
    "processed_requests": 0,
    "pending_requests": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "leave_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize leave counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open leave management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "leave_management_loop",
      "count": "{{leave_requests_to_process}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start leave management loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select leave request"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for processing"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/leave_management_{{leave_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture leave screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "leave_counter",
      "value": "{{leave_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment leave counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{leave_counter < leave_requests_to_process}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more requests"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next request"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/hr_leave_management_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
