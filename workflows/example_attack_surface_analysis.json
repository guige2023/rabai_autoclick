{
  "name": "Attack Surface Analysis Workflow",
  "description": "Automate attack surface discovery and analysis",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "attack_vectors_to_analyze": 58,
    "current_vector": 0,
    "protected_vectors": 0,
    "exposed_vectors": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "surface_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize surface counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open attack surface tool"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for tool"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "surface_analysis_loop",
      "count": "{{attack_vectors_to_analyze}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start surface analysis loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select attack vector"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for analysis"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/surface_analysis_{{surface_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture surface screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "surface_counter",
      "value": "{{surface_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment surface counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{surface_counter < attack_vectors_to_analyze}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more vectors"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next vector"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/attack_surface_analysis_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}