{
  "name": "Security Dashboard Consolidation Workflow",
  "description": "Automate multi-source security dashboard merging",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "dashboard_sources_to_consolidate": 40,
    "current_source": 0,
    "consolidated_sources": 0,
    "failed_sources": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "dashboard_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize dashboard counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open dashboard consolidation tool"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for tool"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "dashboard_consolidation_loop",
      "count": "{{dashboard_sources_to_consolidate}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start consolidation loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select dashboard source"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for consolidation"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/dashboard_consolidate_{{dashboard_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture dashboard screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "dashboard_counter",
      "value": "{{dashboard_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment dashboard counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{dashboard_counter < dashboard_sources_to_consolidate}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more sources"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next source"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_dashboard_consolidation_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}