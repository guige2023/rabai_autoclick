{
  "name": "API Rate Limit Audit Workflow",
  "description": "Automate API rate limiting configuration review",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "api_services_to_check": 48,
    "current_service": 0,
    "properly_limited": 0,
    "unlimited_services": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "rate_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize rate counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open API management gateway"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for gateway"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "rate_limit_loop",
      "count": "{{api_services_to_check}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start rate limit loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select API service"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for limit check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/rate_limit_{{rate_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture rate limit screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "rate_counter",
      "value": "{{rate_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment rate counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{rate_counter < api_services_to_check}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more services"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next service"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/api_rate_limit_audit_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}