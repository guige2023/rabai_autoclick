{
  "name": "API Version Deprecation Workflow",
  "description": "Automate API version deprecation including notification, migration tracking, and sunset management",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "api_versions_to_process": 30,
    "current_version": 0,
    "deprecated_versions": 0,
    "active_migrations": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "version_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize version counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open API management portal"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for portal to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "deprecation_loop",
      "count": "{{api_versions_to_process}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start deprecation loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open API version details"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for details"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/api_version_{{version_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture version screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Check usage metrics"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for metrics"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Send deprecation notices"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for notices"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Track migration progress"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for tracking"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/api_deprecated_{{version_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture deprecation confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "version_counter",
      "value": "{{version_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment version counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{version_counter < api_versions_to_process}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more versions"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next version"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/api_deprecation_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
