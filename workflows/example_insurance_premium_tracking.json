{
  "name": "Insurance Premium Tracking Workflow",
  "description": "Automate insurance premium payment tracking",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "premiums_to_track": 57,
    "current_premium": 0,
    "tracked_premiums": 0,
    "overdue_premiums": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "premium_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize premium counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open premium tracking system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "premium_tracking_loop",
      "count": "{{premiums_to_track}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start premium tracking loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select premium for tracking"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for tracking update"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/premium_tracking_{{premium_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture premium screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "premium_counter",
      "value": "{{premium_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment premium counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{premium_counter < premiums_to_track}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more premiums"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next premium"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/insurance_premium_tracking_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
