{
  "name": "Nuclear Waste Management Workflow",
  "description": "Automate nuclear waste management",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "waste_items_to_track": 48,
    "current_item": 0,
    "tracked_items": 0,
    "disposal_scheduled": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "waste_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize waste counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open waste management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "waste_management_loop",
      "count": "{{waste_items_to_track}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start waste management loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select waste item for tracking"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for tracking update"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/waste_tracking_{{waste_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture tracking screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "waste_counter",
      "value": "{{waste_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment waste counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{waste_counter < waste_items_to_track}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more items"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next item"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/nuclear_waste_management_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
