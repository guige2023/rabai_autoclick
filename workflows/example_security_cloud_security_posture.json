{
  "name": "Security Cloud Security Posture Workflow",
  "description": "Automate cloud security posture management",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "cloud_resources_to_assess": 58,
    "current_resource": 0,
    "secure_resources": 0,
    "misconfigured_resources": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "resource_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize resource counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open cloud security posture tool"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for tool"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "posture_assessment_loop",
      "count": "{{cloud_resources_to_assess}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start posture assessment loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select cloud resource"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for posture check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/posture_check_{{resource_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture posture screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "resource_counter",
      "value": "{{resource_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment resource counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{resource_counter < cloud_resources_to_assess}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more resources"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next resource"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_cloud_security_posture_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
