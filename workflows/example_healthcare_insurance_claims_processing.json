{
  "name": "Healthcare Insurance Claims Processing Workflow",
  "description": "Automate end-to-end insurance claims processing from submission to adjudication",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "claims_to_process": 50,
    "current_claim": 0,
    "approved_claims": 0,
    "rejected_claims": 0,
    "pending_review": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "claim_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize claim counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open claims management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for system to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "claims_processing_loop",
      "count": "{{claims_to_process}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start claims processing loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 250,
      "y": 150,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open next claim in queue"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for claim details"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/claim_details_{{claim_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture claim details screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 400,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Verify patient information"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for verification"
    },
    {
      "id": 10,
      "type": "click",
      "x": 500,
      "y": 350,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Verify coverage eligibility"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for eligibility check"
    },
    {
      "id": 12,
      "type": "screenshot",
      "save_path": "./screenshots/eligibility_check_{{claim_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture eligibility screenshot"
    },
    {
      "id": 13,
      "type": "click",
      "x": 600,
      "y": 400,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Process claim adjudication"
    },
    {
      "id": 14,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.2,
      "comment": "Wait for adjudication"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "claim_counter",
      "value": "{{claim_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment claim counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{claim_counter < claims_to_process}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more claims to process"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next claim"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/claims_processing_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
