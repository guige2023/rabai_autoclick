{
  "name": "Purchase Approval Workflow",
  "description": "Automate purchase request approval process",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "purchase_requests": 8,
    "current_request": 0,
    "approved_count": 0,
    "rejected_count": 0,
    "approval_threshold": 1000
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "request_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize request counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open procurement system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "approval_loop",
      "count": "{{purchase_requests}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start approval loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Click on request"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.3,
      "comment": "Wait for request details"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/purchase_{{request_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture request screenshot"
    },
    {
      "id": 8,
      "type": "condition",
      "condition": "{{request_counter % 2 == 0}}",
      "true_next": 9,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if should approve"
    },
    {
      "id": 9,
      "type": "click_image",
      "template": "./templates/approve_purchase.png",
      "confidence": 0.80,
      "pre_delay": 0.5,
      "comment": "Click approve button"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 15,
      "pre_delay": 0.1,
      "comment": "Skip to next"
    },
    {
      "id": 11,
      "type": "click_image",
      "template": "./templates/reject_purchase.png",
      "confidence": 0.80,
      "pre_delay": 0.5,
      "comment": "Click reject button"
    },
    {
      "id": 12,
      "type": "set_variable",
      "name": "rejected_count",
      "value": "{{rejected_count + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment rejected count"
    },
    {
      "id": 13,
      "type": "goto",
      "step_id": 15,
      "pre_delay": 0.1,
      "comment": "Skip to next"
    },
    {
      "id": 14,
      "type": "set_variable",
      "name": "approved_count",
      "value": "{{approved_count + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment approved count"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "request_counter",
      "value": "{{request_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment request counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{request_counter < purchase_requests}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more requests"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next request"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/purchase_approval_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2,
    "continue_on_error": true
  }
}
