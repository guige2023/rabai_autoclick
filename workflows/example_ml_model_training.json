{
  "name": "ML Model Training Workflow",
  "description": "Automate machine learning model training",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "models_to_train": 48,
    "current_model": 0,
    "trained_models": 0,
    "failed_trainings": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "model_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize model counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open ML training platform"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for platform"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "model_training_loop",
      "count": "{{models_to_train}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start model training loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select model for training"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for training"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/model_training_{{model_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture training screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "model_counter",
      "value": "{{model_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment model counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{model_counter < models_to_train}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more models"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next model"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/ml_model_training_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
