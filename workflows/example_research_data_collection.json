{
  "name": "Research Data Collection Workflow",
  "description": "Automate research data gathering",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "data_sources_to_collect": 50,
    "current_source": 0,
    "collected_sources": 0,
    "failed_collections": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "research_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize research counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open research data portal"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for portal"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "data_collection_loop",
      "count": "{{data_sources_to_collect}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start data collection loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select data source"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for data collection"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/data_collection_{{research_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture research screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "research_counter",
      "value": "{{research_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment research counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{research_counter < data_sources_to_collect}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more sources"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next source"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/research_data_collection_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
