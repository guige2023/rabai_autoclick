{
  "name": "API Monitoring Workflow",
  "description": "Automate API endpoint health monitoring",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "api_endpoints": 8,
    "current_endpoint": 0,
    "healthy_count": 0,
    "unhealthy_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "endpoint_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize endpoint counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open monitoring dashboard"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for dashboard"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "monitoring_loop",
      "count": "{{api_endpoints}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start monitoring loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Click endpoint"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.3,
      "comment": "Wait for status"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/api_{{endpoint_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture API screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "endpoint_counter",
      "value": "{{endpoint_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment endpoint counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{endpoint_counter < api_endpoints}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more endpoints"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next endpoint"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/api_monitoring_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
