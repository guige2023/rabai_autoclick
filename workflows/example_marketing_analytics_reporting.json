{
  "name": "Marketing Analytics Reporting Workflow",
  "description": "Automate marketing analytics reporting",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "reports_to_generate": 48,
    "current_report": 0,
    "generated_reports": 0,
    "failed_reports": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "marketing_report_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize report counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open marketing analytics system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "marketing_analytics_loop",
      "count": "{{reports_to_generate}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start marketing analytics loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select report for generation"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for generation"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/marketing_analytics_{{marketing_report_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture analytics screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "marketing_report_counter",
      "value": "{{marketing_report_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment report counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{marketing_report_counter < reports_to_generate}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more reports"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next report"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/marketing_analytics_reporting_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
