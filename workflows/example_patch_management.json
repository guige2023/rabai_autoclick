{
  "name": "Patch Management Workflow",
  "description": "Automate software patch deployment",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "servers_to_patch": 12,
    "current_server": 0,
    "patched_count": 0,
    "failed_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "server_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize server counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open patch manager"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for manager"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "patch_loop",
      "count": "{{servers_to_patch}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start patch loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Click server"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 2.5,
      "pre_delay": 0.3,
      "comment": "Wait for patch"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/patch_{{server_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture patch screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "server_counter",
      "value": "{{server_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment server counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{server_counter < servers_to_patch}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more servers"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next server"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/patch_management_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
