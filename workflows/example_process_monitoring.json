{
  "name": "Process Monitoring Workflow",
  "description": "Automate process monitoring and management",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "processes_to_monitor": 12,
    "current_process": 0,
    "running_count": 0,
    "stopped_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "process_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize process counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open process manager"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for manager"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "process_loop",
      "count": "{{processes_to_monitor}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start process monitoring loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Click process"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.3,
      "comment": "Wait for status"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/process_{{process_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture process screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "process_counter",
      "value": "{{process_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment process counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{process_counter < processes_to_monitor}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more processes"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next process"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/process_monitoring_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
