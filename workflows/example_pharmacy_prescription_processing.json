{
  "name": "Pharmacy Prescription Processing Workflow",
  "description": "Automate pharmacy prescription processing",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "prescriptions_to_process": 53,
    "current_prescription": 0,
    "processed_prescriptions": 0,
    "pending_verifications": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "prescription_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize prescription counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open prescription processing system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "prescription_processing_loop",
      "count": "{{prescriptions_to_process}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start prescription processing loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select prescription for processing"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for processing"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/prescription_processing_{{prescription_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture processing screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "prescription_counter",
      "value": "{{prescription_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment prescription counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{prescription_counter < prescriptions_to_process}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more prescriptions"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next prescription"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/pharmacy_prescription_processing_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
