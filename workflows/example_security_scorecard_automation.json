{
  "name": "Security Scorecard Automation Workflow",
  "description": "Automate security posture scorecard generation",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "scorecard_metrics_to_collect": 75,
    "current_metric": 0,
    "good_scores": 0,
    "poor_scores": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "scorecard_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize scorecard counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open scorecard platform"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for platform"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "scorecard_generation_loop",
      "count": "{{scorecard_metrics_to_collect}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start scorecard generation loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select scorecard metric"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for metric collection"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/scorecard_{{scorecard_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture scorecard screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "scorecard_counter",
      "value": "{{scorecard_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment scorecard counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{scorecard_counter < scorecard_metrics_to_collect}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more metrics"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next metric"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_scorecard_automation_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}