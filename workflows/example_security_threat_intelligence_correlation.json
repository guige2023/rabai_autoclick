{
  "name": "Security Threat Intelligence Correlation Workflow",
  "description": "Automate threat intelligence correlation",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "threat_intel_to_correlate": 54,
    "current_intel": 0,
    "correlated_intel": 0,
    "high_confidence_threats": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "intel_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize intel counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open threat intelligence platform"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for platform"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "intel_correlation_loop",
      "count": "{{threat_intel_to_correlate}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start intel correlation loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select threat intel"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for correlation"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/intel_correlation_{{intel_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture intel screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "intel_counter",
      "value": "{{intel_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment intel counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{intel_counter < threat_intel_to_correlate}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more intel"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next intel"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_threat_intelligence_correlation_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
