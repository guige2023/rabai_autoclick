{
  "name": "Bug Bug Triage Workflow",
  "description": "Automate bug triage and prioritization",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "bugs_to_triage": 50,
    "current_bug": 0,
    "triaged_bugs": 0,
    "critical_bugs": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "bug_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize bug counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open bug tracking system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "bug_triage_loop",
      "count": "{{bugs_to_triage}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start bug triage loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select bug for triage"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for triage assessment"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/bug_triage_{{bug_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture bug screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "bug_counter",
      "value": "{{bug_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment bug counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{bug_counter < bugs_to_triage}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more bugs"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next bug"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/bug_bug_triage_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
