{
  "name": "Audit Trail Verification Workflow",
  "description": "Automate audit trail integrity verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "audit_records": 25,
    "current_record": 0,
    "valid_count": 0,
    "tampered_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "record_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize record counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open audit system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "audit_loop",
      "count": "{{audit_records}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start audit verification loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Click audit record"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.3,
      "comment": "Wait for verification"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/audit_{{record_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture audit screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "record_counter",
      "value": "{{record_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment record counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{record_counter < audit_records}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more records"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next record"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/audit_trail_verification_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
