{
  "name": "Healthcare Patient Tracking Workflow",
  "description": "Automate patient records tracking",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "patients_to_track": 49,
    "current_patient": 0,
    "tracked_patients": 0,
    "appointments_scheduled": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "patient_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize patient counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open patient tracking system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "patient_tracking_loop",
      "count": "{{patients_to_track}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start patient tracking loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select patient for tracking"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for tracking update"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/patient_tracking_{{patient_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture patient screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "patient_counter",
      "value": "{{patient_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment patient counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{patient_counter < patients_to_track}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more patients"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next patient"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/healthcare_patient_tracking_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
