{
  "name": "Ransomware Defense Audit Workflow",
  "description": "Automate ransomware protection measures verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "defense_controls_to_check": 52,
    "current_control": 0,
    "active_defenses": 0,
    "inactive_defenses": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "ransomware_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize ransomware counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open ransomware defense console"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for console"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "ransomware_audit_loop",
      "count": "{{defense_controls_to_check}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start ransomware audit loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select defense control"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for defense check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/ransomware_audit_{{ransomware_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture ransomware screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "ransomware_counter",
      "value": "{{ransomware_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment ransomware counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{ransomware_counter < defense_controls_to_check}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more controls"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next control"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/ransomware_defense_audit_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}