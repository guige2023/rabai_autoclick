{
  "name": "Market Research Workflow",
  "description": "Automate market research data collection",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "competitors": 10,
    "current_competitor": 0,
    "data_points_collected": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "competitor_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize competitor counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open research tool"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for tool"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "research_loop",
      "count": "{{competitors}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start research loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Click competitor"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.3,
      "comment": "Wait for data"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/competitor_{{competitor_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture competitor screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "competitor_counter",
      "value": "{{competitor_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment competitor counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{competitor_counter < competitors}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more competitors"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next competitor"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/market_research_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
