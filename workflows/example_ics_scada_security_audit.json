{
  "name": "ICS SCADA Security Audit Workflow",
  "description": "Automate industrial control system security review",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "ics_components_to_audit": 38,
    "current_component": 0,
    "secure_components": 0,
    "vulnerable_components": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "ics_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize ICS counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open ICS security management"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for management"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "ics_audit_loop",
      "count": "{{ics_components_to_audit}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start ICS audit loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select ICS component"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for security check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/ics_audit_{{ics_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture ICS screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "ics_counter",
      "value": "{{ics_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment ICS counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{ics_counter < ics_components_to_audit}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more components"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next component"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/ics_scada_security_audit_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}