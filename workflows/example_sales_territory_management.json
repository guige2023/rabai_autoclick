{
  "name": "Sales Territory Management Workflow",
  "description": "Automate sales territory assignment",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "territories_to_manage": 52,
    "current_territory": 0,
    "managed_territories": 0,
    "unassigned_accounts": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "territory_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize territory counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open territory management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "territory_management_loop",
      "count": "{{territories_to_manage}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start territory management loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select territory for management"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for territory update"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/territory_management_{{territory_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture territory screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "territory_counter",
      "value": "{{territory_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment territory counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{territory_counter < territories_to_manage}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more territories"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next territory"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/sales_territory_management_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
