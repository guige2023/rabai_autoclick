{
  "name": "Security Security Metrics Dashboard Workflow",
  "description": "Automate security metrics collection and dashboard updates",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "metrics_to_collect": 50,
    "current_metric": 0,
    "collected_metrics": 0,
    "pending_metrics": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "metric_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize metric counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open security metrics dashboard"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for dashboard"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "metrics_collection_loop",
      "count": "{{metrics_to_collect}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start metrics collection loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select metric source"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for metric collection"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/metric_{{metric_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture metric screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "metric_counter",
      "value": "{{metric_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment metric counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{metric_counter < metrics_to_collect}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more metrics"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next metric"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_security_metrics_dashboard_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
