{
  "name": "Patch Deployment Tracking Workflow",
  "description": "Automate patch deployment status tracking",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "patches_to_track": 35,
    "current_patch": 0,
    "deployed_count": 0,
    "pending_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "patch_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize patch counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open patch tracking"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for tracking"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "patch_tracking_loop",
      "count": "{{patches_to_track}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start patch tracking loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select patch"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for deployment check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/patch_deployment_{{patch_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture deployment screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "patch_counter",
      "value": "{{patch_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment patch counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{patch_counter < patches_to_track}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more patches"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next patch"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/patch_deployment_tracking_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}