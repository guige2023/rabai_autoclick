{
  "name": "Security Data Leak Prevention Workflow",
  "description": "Automate data leak prevention monitoring",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "dlp_incidents_to_investigate": 54,
    "current_incident": 0,
    "investigated_incidents": 0,
    "confirmed_leaks": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "incident_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize incident counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open DLP console"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for console"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "dlp_incident_loop",
      "count": "{{dlp_incidents_to_investigate}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start DLP incident loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select DLP incident"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for investigation"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/dlp_incident_{{incident_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture incident screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "incident_counter",
      "value": "{{incident_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment incident counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{incident_counter < dlp_incidents_to_investigate}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more incidents"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next incident"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_data_leak_prevention_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
