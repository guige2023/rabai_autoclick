{
  "name": "Security Email Security Scan Workflow",
  "description": "Automate email security scanning and analysis",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "emails_to_scan": 65,
    "current_email": 0,
    "threats_detected": 0,
    "safe_emails": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "email_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize email counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open email security system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "email_scan_loop",
      "count": "{{emails_to_scan}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start email scan loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select email message"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for email analysis"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/email_scan_{{email_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture email scan screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "email_counter",
      "value": "{{email_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment email counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{email_counter < emails_to_scan}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more emails"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next email"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_email_security_scan_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
