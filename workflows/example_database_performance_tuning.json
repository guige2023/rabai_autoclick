{
  "name": "Database Performance Tuning Workflow",
  "description": "Automate database performance tuning",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "tuning_tasks": 51,
    "current_task": 0,
    "completed_tasks": 0,
    "failed_tasks": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "tuning_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize tuning counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open performance tuning tool"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for tool"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "performance_tuning_loop",
      "count": "{{tuning_tasks}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start performance tuning loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select tuning task"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for tuning"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/performance_tuning_{{tuning_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture tuning screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "tuning_counter",
      "value": "{{tuning_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment tuning counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{tuning_counter < tuning_tasks}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more tasks"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next task"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/database_performance_tuning_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
