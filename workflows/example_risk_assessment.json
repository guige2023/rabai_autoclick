{
  "name": "Risk Assessment Workflow",
  "description": "Automate security risk assessment",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "assets_to_assess": 15,
    "current_asset": 0,
    "high_risk_count": 0,
    "low_risk_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "asset_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize asset counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open risk assessment platform"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for platform"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "risk_loop",
      "count": "{{assets_to_assess}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start risk assessment loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Click asset"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for risk analysis"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/risk_assessment_{{asset_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture risk screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "asset_counter",
      "value": "{{asset_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment asset counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{asset_counter < assets_to_assess}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more assets"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next asset"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/risk_assessment_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
