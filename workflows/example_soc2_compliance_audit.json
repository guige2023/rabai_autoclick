{
  "name": "SOC 2 Compliance Audit Workflow",
  "description": "Automate SOC 2 trust principle verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "soc2_criteria_to_verify": 65,
    "current_criteria": 0,
    "compliant_criteria": 0,
    "non_compliant_criteria": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "soc2_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize SOC2 counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open SOC 2 compliance portal"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for portal"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "soc2_audit_loop",
      "count": "{{soc2_criteria_to_verify}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start SOC2 audit loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select SOC2 criteria"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for criteria check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/soc2_audit_{{soc2_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture SOC2 screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "soc2_counter",
      "value": "{{soc2_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment SOC2 counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{soc2_counter < soc2_criteria_to_verify}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more criteria"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next criteria"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/soc2_compliance_audit_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}