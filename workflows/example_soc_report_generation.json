{
  "name": "SOC Report Generation Workflow",
  "description": "Automate Security Operations Center report generation",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "report_sections": 20,
    "current_section": 0,
    "completed_count": 0,
    "pending_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "section_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize section counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open SOC reporting"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for reporting"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "soc_report_loop",
      "count": "{{report_sections}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start SOC report loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select report section"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for report generation"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/soc_report_{{section_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture report screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "section_counter",
      "value": "{{section_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment section counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{section_counter < report_sections}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more sections"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next section"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/soc_report_generation_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}