{
  "name": "Compliance Framework Mapping Workflow",
  "description": "Automate compliance control mapping verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "compliance_controls_to_map": 70,
    "current_control": 0,
    "mapped_controls": 0,
    "unmapped_controls": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "compliance_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize compliance counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open compliance management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "compliance_mapping_loop",
      "count": "{{compliance_controls_to_map}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start compliance mapping loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select compliance control"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for mapping check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/compliance_map_{{compliance_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture compliance screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "compliance_counter",
      "value": "{{compliance_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment compliance counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{compliance_counter < compliance_controls_to_map}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more controls"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next control"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/compliance_framework_mapping_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}