{
  "name": "Infrastructure Network Configuration Workflow",
  "description": "Automate network configuration tasks",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "networks_to_configure": 49,
    "current_network": 0,
    "configured_networks": 0,
    "failed_configurations": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "network_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize network counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open network configuration tool"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for tool"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "network_config_loop",
      "count": "{{networks_to_configure}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start network config loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select network for configuration"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for configuration"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/network_config_{{network_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture network screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "network_counter",
      "value": "{{network_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment network counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{network_counter < networks_to_configure}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more networks"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next network"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/infrastructure_network_config_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
