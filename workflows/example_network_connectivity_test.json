{
  "name": "Network Connectivity Test Workflow",
  "description": "Automate network connectivity testing",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "hosts_to_test": 30,
    "current_host": 0,
    "reachable_count": 0,
    "unreachable_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "host_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize host counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open network testing tool"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for tool"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "connectivity_loop",
      "count": "{{hosts_to_test}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start connectivity test loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select host"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for connectivity test"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/connectivity_test_{{host_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture test screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "host_counter",
      "value": "{{host_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment host counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{host_counter < hosts_to_test}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more hosts"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next host"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/network_connectivity_test_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}