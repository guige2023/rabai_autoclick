{
  "name": "FedRAMP Compliance Audit Workflow",
  "description": "Automate FedRAMP authorization verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "fedramp_controls_to_assess": 78,
    "current_control": 0,
    "authorized_controls": 0,
    "unauthorized_controls": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "fedramp_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize FedRAMP counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open FedRAMP dashboard"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for dashboard"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "fedramp_audit_loop",
      "count": "{{fedramp_controls_to_assess}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start FedRAMP audit loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select FedRAMP control"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for authorization check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/fedramp_audit_{{fedramp_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture FedRAMP screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "fedramp_counter",
      "value": "{{fedramp_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment FedRAMP counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{fedramp_counter < fedramp_controls_to_assess}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more controls"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next control"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/fedramp_compliance_audit_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}