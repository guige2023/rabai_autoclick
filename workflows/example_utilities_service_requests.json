{
  "name": "Utilities Service Requests Workflow",
  "description": "Automate utilities service requests",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "requests_to_process": 48,
    "current_request": 0,
    "processed_requests": 0,
    "pending_installation": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "request_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize request counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open service requests system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "service_requests_loop",
      "count": "{{requests_to_process}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start service requests loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select request for processing"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for processing"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/service_request_{{request_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture request screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "request_counter",
      "value": "{{request_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment request counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{request_counter < requests_to_process}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more requests"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next request"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/utilities_service_requests_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
