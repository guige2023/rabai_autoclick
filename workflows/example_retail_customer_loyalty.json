{
  "name": "Retail Customer Loyalty Management Workflow",
  "description": "Automate customer loyalty management",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "customers_to_manage": 49,
    "current_customer": 0,
    "managed_customers": 0,
    "tier_upgrades": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "loyalty_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize loyalty counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open loyalty management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "customer_loyalty_loop",
      "count": "{{customers_to_manage}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start customer loyalty loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select customer for loyalty management"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for management action"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/customer_loyalty_{{loyalty_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture loyalty screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "loyalty_counter",
      "value": "{{loyalty_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment loyalty counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{loyalty_counter < customers_to_manage}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more customers"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next customer"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/retail_customer_loyalty_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
