{
  "name": "Load Balancer Configuration Workflow",
  "description": "Automate load balancer configuration and health checks",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "server_pools": 4,
    "current_pool": 0,
    "healthy_nodes": 0,
    "unhealthy_nodes": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "pool_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize pool counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open load balancer console"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for console"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "pool_loop",
      "count": "{{server_pools}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start pool check loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Click server pool"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for health check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/pool_{{pool_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture pool screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "pool_counter",
      "value": "{{pool_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment pool counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{pool_counter < server_pools}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more pools"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next pool"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/load_balancer_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
