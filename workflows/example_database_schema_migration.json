{
  "name": "Database Schema Migration Workflow",
  "description": "Automate database schema migration validation",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "migrations_to_validate": 46,
    "current_migration": 0,
    "validated_migrations": 0,
    "failed_migrations": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "migration_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize migration counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open database migration tool"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for tool"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "schema_migration_loop",
      "count": "{{migrations_to_validate}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start schema migration loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select migration for validation"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for validation"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/schema_migration_{{migration_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture migration screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "migration_counter",
      "value": "{{migration_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment migration counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{migration_counter < migrations_to_validate}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more migrations"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next migration"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/database_schema_migration_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
