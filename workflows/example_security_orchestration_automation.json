{
  "name": "Security Orchestration Automation Workflow",
  "description": "Automate security workflow orchestration",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "orchestration_tasks_to_execute": 65,
    "current_task": 0,
    "successful_tasks": 0,
    "failed_tasks": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "orch_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize orch counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open SOAR platform"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for platform"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "orchestration_loop",
      "count": "{{orchestration_tasks_to_execute}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start orchestration loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select orchestration task"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for task execution"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/orch_task_{{orch_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture orch screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "orch_counter",
      "value": "{{orch_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment orch counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{orch_counter < orchestration_tasks_to_execute}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more tasks"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next task"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_orchestration_automation_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}