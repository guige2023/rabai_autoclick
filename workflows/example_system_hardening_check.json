{
  "name": "System Hardening Check Workflow",
  "description": "Automate system hardening verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "systems_to_harden": 32,
    "current_system": 0,
    "hardened_count": 0,
    "unhardened_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "system_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize system counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open hardening management"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for management"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "hardening_check_loop",
      "count": "{{systems_to_harden}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start hardening check loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select system"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for hardening check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/hardening_check_{{system_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture hardening screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "system_counter",
      "value": "{{system_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment system counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{system_counter < systems_to_harden}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more systems"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next system"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/system_hardening_check_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}