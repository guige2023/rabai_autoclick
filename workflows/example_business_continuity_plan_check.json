{
  "name": "Business Continuity Plan Check Workflow",
  "description": "Automate BCP readiness verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "bcp_elements_to_check": 22,
    "current_element": 0,
    "ready_count": 0,
    "not_ready_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "element_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize element counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open BCP management"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for management"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "bcp_check_loop",
      "count": "{{bcp_elements_to_check}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start BCP check loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select BCP element"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for readiness check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/bcp_check_{{element_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture BCP screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "element_counter",
      "value": "{{element_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment element counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{element_counter < bcp_elements_to_check}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more elements"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next element"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/business_continuity_plan_check_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}