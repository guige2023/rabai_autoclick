{
  "name": "Analytics Data Exploration Workflow",
  "description": "Automate data exploration and discovery",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "datasets_to_explore": 52,
    "current_dataset": 0,
    "explored_datasets": 0,
    "insights_found": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "dataset_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize dataset counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open data exploration tool"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for tool"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "data_exploration_loop",
      "count": "{{datasets_to_explore}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start data exploration loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select dataset for exploration"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for exploration"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/exploration_{{dataset_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture exploration screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "dataset_counter",
      "value": "{{dataset_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment dataset counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{dataset_counter < datasets_to_explore}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more datasets"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next dataset"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/analytics_data_exploration_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
