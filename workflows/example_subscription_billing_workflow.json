{
  "name": "Subscription Billing Workflow",
  "description": "Automate subscription billing including invoice generation, payment processing, and dunning",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "subscriptions_to_bill": 55,
    "current_subscription": 0,
    "billed_subscriptions": 0,
    "failed_payments": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "subscription_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize subscription counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open billing system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for system to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "billing_loop",
      "count": "{{subscriptions_to_bill}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start billing loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open subscription record"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for record"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/subscription_{{subscription_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture subscription screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Verify billing details"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for verification"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Generate invoice"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for generation"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Process payment"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for payment"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/billing_complete_{{subscription_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture billing confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "subscription_counter",
      "value": "{{subscription_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment subscription counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{subscription_counter < subscriptions_to_bill}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more subscriptions"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next subscription"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/billing_batch_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture batch completion"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
