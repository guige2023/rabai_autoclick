{
  "name": "Publishing Copy Editing Workflow",
  "description": "Automate publishing copy editing",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "manuscripts_to_edit": 49,
    "current_manuscript": 0,
    "edited_manuscripts": 0,
    "pending_approvals": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "manuscript_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize manuscript counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open copy editing system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "copy_editing_loop",
      "count": "{{manuscripts_to_edit}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start copy editing loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select manuscript for editing"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for editing"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/copy_editing_{{manuscript_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture editing screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "manuscript_counter",
      "value": "{{manuscript_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment manuscript counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{manuscript_counter < manuscripts_to_edit}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more manuscripts"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next manuscript"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/publishing_copy_editing_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
