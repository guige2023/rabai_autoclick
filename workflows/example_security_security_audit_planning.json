{
  "name": "Security Security Audit Planning Workflow",
  "description": "Automate security audit planning process",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "audit_areas_to_plan": 58,
    "current_area": 0,
    "planned_audits": 0,
    "pending_audits": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "area_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize area counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open audit planning platform"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for platform"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "audit_planning_loop",
      "count": "{{audit_areas_to_plan}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start audit planning loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select audit area"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for planning"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/audit_planning_{{area_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture audit planning screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "area_counter",
      "value": "{{area_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment area counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{area_counter < audit_areas_to_plan}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more areas"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next area"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_security_audit_planning_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
