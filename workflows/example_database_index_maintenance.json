{
  "name": "Database Index Maintenance Workflow",
  "description": "Automate database index maintenance",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "indexes_to_maintain": 49,
    "current_index": 0,
    "maintained_indexes": 0,
    "failed_maintenance": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "index_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize index counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open index management tool"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for tool"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "index_maintenance_loop",
      "count": "{{indexes_to_maintain}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start index maintenance loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select index for maintenance"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for maintenance"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/index_maintenance_{{index_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture maintenance screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "index_counter",
      "value": "{{index_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment index counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{index_counter < indexes_to_maintain}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more indexes"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next index"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/database_index_maintenance_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
