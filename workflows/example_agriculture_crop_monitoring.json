{
  "name": "Agriculture Crop Monitoring Workflow",
  "description": "Automate crop monitoring process",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "crops_to_monitor": 48,
    "current_crop": 0,
    "monitored_crops": 0,
    "alerts_triggered": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "crop_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize crop counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open crop monitoring system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "crop_monitoring_loop",
      "count": "{{crops_to_monitor}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start crop monitoring loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select crop for monitoring"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for monitoring"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/crop_monitoring_{{crop_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture monitoring screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "crop_counter",
      "value": "{{crop_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment crop counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{crop_counter < crops_to_monitor}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more crops"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next crop"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/agriculture_crop_monitoring_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
