{
  "name": "Security Security Audit Trail Workflow",
  "description": "Automate security audit trail management",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "audit_events_to_review": 58,
    "current_event": 0,
    "reviewed_events": 0,
    "flagged_events": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "event_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize event counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open audit trail system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "audit_trail_loop",
      "count": "{{audit_events_to_review}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start audit trail review loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select audit event"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for event review"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/audit_trail_{{event_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture audit event screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "event_counter",
      "value": "{{event_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment event counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{event_counter < audit_events_to_review}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more events"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next event"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_security_audit_trail_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
