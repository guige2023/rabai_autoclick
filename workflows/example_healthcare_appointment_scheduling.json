{
  "name": "Healthcare Appointment Scheduling Workflow",
  "description": "Automate appointment scheduling",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "appointments_to_schedule": 51,
    "current_appointment": 0,
    "scheduled_appointments": 0,
    "cancelled_appointments": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "appointment_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize appointment counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open appointment scheduling system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "appointment_scheduling_loop",
      "count": "{{appointments_to_schedule}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start appointment scheduling loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select appointment for scheduling"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for scheduling"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/appointment_scheduling_{{appointment_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture scheduling screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "appointment_counter",
      "value": "{{appointment_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment appointment counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{appointment_counter < appointments_to_schedule}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more appointments"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next appointment"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/healthcare_appointment_scheduling_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
