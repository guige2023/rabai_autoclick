{
  "name": "Security Security Review Process Workflow",
  "description": "Automate security review process management",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "reviews_to_complete": 50,
    "current_review": 0,
    "completed_reviews": 0,
    "pending_reviews": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "review_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize review counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open security review system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "review_process_loop",
      "count": "{{reviews_to_complete}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start review process loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select review item"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for review completion"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/review_process_{{review_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture review screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "review_counter",
      "value": "{{review_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment review counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{review_counter < reviews_to_complete}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more reviews"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next review"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_security_review_process_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
