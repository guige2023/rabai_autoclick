{
  "name": "Secret Rotation Check Workflow",
  "description": "Automate secret rotation compliance verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "secrets_to_check": 22,
    "current_secret": 0,
    "rotated_count": 0,
    "overdue_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "secret_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize secret counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open secret management"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for management"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "secret_rotation_loop",
      "count": "{{secrets_to_check}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start secret rotation loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select secret"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for rotation check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/secret_rotation_{{secret_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture rotation screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "secret_counter",
      "value": "{{secret_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment secret counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{secret_counter < secrets_to_check}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more secrets"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next secret"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/secret_rotation_check_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}