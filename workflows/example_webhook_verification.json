{
  "name": "Webhook Verification Workflow",
  "description": "Automate webhook health verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "webhooks_to_check": 12,
    "current_webhook": 0,
    "healthy_count": 0,
    "failed_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "webhook_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize webhook counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open webhook dashboard"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for dashboard"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "webhook_loop",
      "count": "{{webhooks_to_check}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start webhook verification loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Click webhook"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.3,
      "comment": "Wait for verification"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/webhook_{{webhook_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture webhook screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "webhook_counter",
      "value": "{{webhook_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment webhook counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{webhook_counter < webhooks_to_check}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more webhooks"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next webhook"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/webhook_verification_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
