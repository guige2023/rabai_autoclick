{
  "name": "Password Policy Compliance Workflow",
  "description": "Automate password policy compliance checking including policy enforcement and user notification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "users_to_check": 60,
    "current_user": 0,
    "compliant_users": 0,
    "non_compliant_users": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "user_check_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize user counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open identity management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for system to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "compliance_loop",
      "count": "{{users_to_check}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start compliance check loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open user account"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for account"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/password_user_{{user_check_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture user screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Check password age"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for check"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Verify policy compliance"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for verification"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Send notification if non-compliant"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for notification"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/password_checked_{{user_check_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture check confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "user_check_counter",
      "value": "{{user_check_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment user counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{user_check_counter < users_to_check}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more users"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next user"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/password_compliance_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
