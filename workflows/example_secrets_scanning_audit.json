{
  "name": "Secrets Scanning Audit Workflow",
  "description": "Automate secrets detection in code review",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "codebases_to_scan": 45,
    "current_codebase": 0,
    "clean_codebases": 0,
    "secrets_found": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "secrets_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize secrets counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open secrets scanner"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for scanner"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "secrets_scan_loop",
      "count": "{{codebases_to_scan}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start secrets scan loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select codebase"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for secrets detection"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/secrets_scan_{{secrets_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture secrets screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "secrets_counter",
      "value": "{{secrets_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment secrets counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{secrets_counter < codebases_to_scan}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more codebases"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next codebase"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/secrets_scanning_audit_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}