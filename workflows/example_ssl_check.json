{
  "name": "SSL Certificate Check Workflow",
  "description": "Automate SSL certificate expiration monitoring",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "certificates": 8,
    "current_cert": 0,
    "expiring_count": 0,
    "valid_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "cert_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize cert counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open SSL dashboard"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for dashboard"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "ssl_loop",
      "count": "{{certificates}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start SSL check loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Click certificate"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.3,
      "comment": "Wait for details"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/ssl_{{cert_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture SSL screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "cert_counter",
      "value": "{{cert_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment cert counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{cert_counter < certificates}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more certs"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next cert"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/ssl_check_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
