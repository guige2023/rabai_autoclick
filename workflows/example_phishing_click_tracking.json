{
  "name": "Phishing Click Tracking Workflow",
  "description": "Automate phishing campaign click tracking",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "campaigns_to_track": 15,
    "current_campaign": 0,
    "clicked_count": 0,
    "not_clicked_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "campaign_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize campaign counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open phishing tracking"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for tracking"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "phishing_click_loop",
      "count": "{{campaigns_to_track}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start click tracking loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select campaign"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for tracking check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/phishing_click_tracking_{{campaign_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture tracking screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "campaign_counter",
      "value": "{{campaign_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment campaign counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{campaign_counter < campaigns_to_track}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more campaigns"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next campaign"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/phishing_click_tracking_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}