{
  "name": "SSL Certificate Renewal Workflow",
  "description": "Automate SSL certificate renewal including expiration monitoring and automated reissuance",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "certificates_to_renew": 40,
    "current_cert": 0,
    "renewed_certs": 0,
    "expiring_certs": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "cert_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize certificate counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open certificate management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for system to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "renewal_loop",
      "count": "{{certificates_to_renew}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start certificate renewal loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open certificate details"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for details"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/certificate_{{cert_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture certificate screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Check expiration date"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for check"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Initiate renewal if needed"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for renewal"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Deploy renewed certificate"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for deployment"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/cert_renewed_{{cert_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture renewal confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "cert_counter",
      "value": "{{cert_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment cert counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{cert_counter < certificates_to_renew}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more certificates"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next certificate"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/cert_renewal_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
