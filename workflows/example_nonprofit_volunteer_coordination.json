{
  "name": "Nonprofit Volunteer Coordination Workflow",
  "description": "Automate nonprofit volunteer coordination",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "volunteers_to_coordinate": 50,
    "current_volunteer": 0,
    "coordinated_volunteers": 0,
    "assignments_made": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "volunteer_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize volunteer counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open volunteer coordination system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "volunteer_coordination_loop",
      "count": "{{volunteers_to_coordinate}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start volunteer coordination loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select volunteer for coordination"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for coordination"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/volunteer_coordination_{{volunteer_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture coordination screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "volunteer_counter",
      "value": "{{volunteer_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment volunteer counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{volunteer_counter < volunteers_to_coordinate}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more volunteers"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next volunteer"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/nonprofit_volunteer_coordination_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
