{
  "name": "Sensitive Data Discovery Workflow",
  "description": "Automate sensitive data discovery across systems",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "data_repositories_to_scan": 22,
    "current_repository": 0,
    "discovered_count": 0,
    "clean_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "repo_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize repository counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open data discovery tool"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for tool"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "data_discovery_loop",
      "count": "{{data_repositories_to_scan}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start data discovery loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select repository"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for discovery scan"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/data_discovery_{{repo_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture discovery screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "repo_counter",
      "value": "{{repo_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment repository counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{repo_counter < data_repositories_to_scan}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more repositories"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next repository"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/sensitive_data_discovery_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}