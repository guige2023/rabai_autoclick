{
  "name": "Parking Lot Enforcement Workflow",
  "description": "Automate parking lot enforcement including violation detection and citation processing",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "violations_to_process": 55,
    "current_violation": 0,
    "processed_violations": 0,
    "citations_issued": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "violation_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize violation counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open parking enforcement system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for system to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "enforcement_loop",
      "count": "{{violations_to_process}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start enforcement loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Review violation report"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for report"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/violation_{{violation_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture violation screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Verify license plate"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for verification"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Check registration status"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for status check"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Generate citation"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for generation"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/citation_{{violation_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture citation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "violation_counter",
      "value": "{{violation_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment violation counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{violation_counter < violations_to_process}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more violations"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next violation"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/enforcement_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
