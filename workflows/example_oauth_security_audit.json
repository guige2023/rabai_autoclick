{
  "name": "OAuth Security Audit Workflow",
  "description": "Automate OAuth provider configuration review",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "oauth_clients_to_audit": 45,
    "current_client": 0,
    "secure_clients": 0,
    "insecure_clients": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "oauth_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize OAuth counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open OAuth management console"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for console"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "oauth_audit_loop",
      "count": "{{oauth_clients_to_audit}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start OAuth audit loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select OAuth client"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for security check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/oauth_audit_{{oauth_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture OAuth screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "oauth_counter",
      "value": "{{oauth_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment OAuth counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{oauth_counter < oauth_clients_to_audit}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more clients"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next client"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/oauth_security_audit_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}