{
  "name": "Infrastructure Power Management Workflow",
  "description": "Automate power infrastructure management",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "power_circuits_to_monitor": 46,
    "current_circuit": 0,
    "monitored_circuits": 0,
    "power_alerts": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "circuit_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize circuit counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open power management console"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for console"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "power_management_loop",
      "count": "{{power_circuits_to_monitor}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start power monitoring loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select power circuit"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for monitoring"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/power_circuit_{{circuit_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture power screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "circuit_counter",
      "value": "{{circuit_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment circuit counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{circuit_counter < power_circuits_to_monitor}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more circuits"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next circuit"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/infrastructure_power_management_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
