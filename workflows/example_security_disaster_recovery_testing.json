{
  "name": "Security Disaster Recovery Testing Workflow",
  "description": "Automate disaster recovery testing",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "dr_tests_to_run": 48,
    "current_test": 0,
    "passed_tests": 0,
    "failed_tests": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "test_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize test counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open DR testing platform"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for platform"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "dr_testing_loop",
      "count": "{{dr_tests_to_run}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start DR testing loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select DR test scenario"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for test execution"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/dr_test_{{test_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture DR test screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "test_counter",
      "value": "{{test_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment test counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{test_counter < dr_tests_to_run}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more tests"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next test"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_disaster_recovery_testing_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
