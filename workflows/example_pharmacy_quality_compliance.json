{
  "name": "Pharmacy Quality Compliance Workflow",
  "description": "Automate pharmacy quality compliance",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "compliance_checks": 50,
    "current_check": 0,
    "passed_checks": 0,
    "failed_checks": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "check_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize check counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open quality compliance system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "quality_compliance_loop",
      "count": "{{compliance_checks}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start quality compliance loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select check for verification"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for verification"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/quality_check_{{check_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture check screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "check_counter",
      "value": "{{check_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment check counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{check_counter < compliance_checks}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more checks"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next check"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/pharmacy_quality_compliance_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
