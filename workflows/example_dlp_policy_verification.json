{
  "name": "DLP Policy Verification Workflow",
  "description": "Automate data loss prevention policy compliance",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "dlp_policies_to_verify": 42,
    "current_policy": 0,
    "enforced_policies": 0,
    "violations_found": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "dlp_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize DLP counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open DLP management console"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for console"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "dlp_verification_loop",
      "count": "{{dlp_policies_to_verify}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start DLP verification loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select DLP policy"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for policy check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/dlp_verify_{{dlp_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture DLP screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "dlp_counter",
      "value": "{{dlp_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment DLP counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{dlp_counter < dlp_policies_to_verify}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more policies"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next policy"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/dlp_policy_verification_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}