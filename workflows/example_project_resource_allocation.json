{
  "name": "Project Resource Allocation Workflow",
  "description": "Automate project resource allocation tracking",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "resources_to_allocate": 48,
    "current_resource": 0,
    "allocated_resources": 0,
    "overloaded_resources": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "resource_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize resource counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open resource management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "resource_allocation_loop",
      "count": "{{resources_to_allocate}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start resource allocation loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select resource for allocation"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for allocation"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/resource_allocation_{{resource_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture allocation screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "resource_counter",
      "value": "{{resource_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment resource counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{resource_counter < resources_to_allocate}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more resources"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next resource"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/project_resource_allocation_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
