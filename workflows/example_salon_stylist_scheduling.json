{
  "name": "Salon Stylist Scheduling Workflow",
  "description": "Automate salon stylist scheduling",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "stylists_to_schedule": 48,
    "current_stylist": 0,
    "scheduled_stylists": 0,
    "conflicts": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "stylist_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize stylist counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open stylist scheduling system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "stylist_scheduling_loop",
      "count": "{{stylists_to_schedule}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start stylist scheduling loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select stylist for scheduling"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for scheduling"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/stylist_scheduling_{{stylist_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture scheduling screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "stylist_counter",
      "value": "{{stylist_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment stylist counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{stylist_counter < stylists_to_schedule}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more stylists"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next stylist"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/salon_stylist_scheduling_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
