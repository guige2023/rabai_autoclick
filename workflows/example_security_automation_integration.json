{
  "name": "Security Automation Integration Workflow",
  "description": "Automate security toolchain integration verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "tool_integrations_to_verify": 58,
    "current_integration": 0,
    "working_integrations": 0,
    "broken_integrations": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "integration_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize integration counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open integration management"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for management"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "integration_verification_loop",
      "count": "{{tool_integrations_to_verify}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start integration verification loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select tool integration"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for integration check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/integration_verify_{{integration_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture integration screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "integration_counter",
      "value": "{{integration_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment integration counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{integration_counter < tool_integrations_to_verify}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more integrations"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next integration"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_automation_integration_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}