{
  "name": "Agriculture Irrigation Control Workflow",
  "description": "Automate irrigation control",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "zones_to_control": 50,
    "current_zone": 0,
    "controlled_zones": 0,
    "water_savings": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "irrigation_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize irrigation counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open irrigation control system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "irrigation_control_loop",
      "count": "{{zones_to_control}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start irrigation control loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select zone for control"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for control action"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/irrigation_control_{{irrigation_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture control screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "irrigation_counter",
      "value": "{{irrigation_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment irrigation counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{irrigation_counter < zones_to_control}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more zones"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next zone"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/agriculture_irrigation_control_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
