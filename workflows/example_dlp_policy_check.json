{
  "name": "DLP Policy Check Workflow",
  "description": "Automate data loss prevention policy verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "policies_to_check": 12,
    "current_policy": 0,
    "compliant_count": 0,
    "violation_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "policy_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize policy counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open DLP management console"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for console"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "dlp_loop",
      "count": "{{policies_to_check}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start DLP check loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Click policy"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.3,
      "comment": "Wait for policy check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/dlp_{{policy_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture DLP screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "policy_counter",
      "value": "{{policy_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment policy counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{policy_counter < policies_to_check}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more policies"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next policy"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/dlp_policy_check_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
