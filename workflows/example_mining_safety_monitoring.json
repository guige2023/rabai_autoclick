{
  "name": "Mining Safety Monitoring Workflow",
  "description": "Automate mining safety monitoring",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "inspection_points": 50,
    "current_point": 0,
    "inspected_points": 0,
    "hazards_found": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "safety_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize safety counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open safety monitoring system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "safety_monitoring_loop",
      "count": "{{inspection_points}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start safety monitoring loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select point for inspection"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for inspection"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/safety_inspection_{{safety_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture inspection screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "safety_counter",
      "value": "{{safety_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment safety counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{safety_counter < inspection_points}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more points"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next point"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/mining_safety_monitoring_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
