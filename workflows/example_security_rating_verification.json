{
  "name": "Security Rating Verification Workflow",
  "description": "Automate security posture rating verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "rating_categories_to_verify": 40,
    "current_category": 0,
    "good_ratings": 0,
    "poor_ratings": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "rating_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize rating counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open security rating platform"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for platform"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "rating_verification_loop",
      "count": "{{rating_categories_to_verify}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start rating verification loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select rating category"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for rating check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/rating_verify_{{rating_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture rating screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "rating_counter",
      "value": "{{rating_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment rating counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{rating_counter < rating_categories_to_verify}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more categories"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next category"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_rating_verification_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}