{
  "name": "UX Usability Testing Workflow",
  "description": "Automate usability testing",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "tests_to_conduct": 46,
    "current_test": 0,
    "conducted_tests": 0,
    "failed_tests": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "usability_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize usability counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open usability testing platform"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for platform"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "usability_testing_loop",
      "count": "{{tests_to_conduct}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start usability testing loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select usability test"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for test"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/usability_testing_{{usability_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture test screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "usability_counter",
      "value": "{{usability_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment usability counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{usability_counter < tests_to_conduct}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more tests"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next test"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/ux_usability_testing_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
