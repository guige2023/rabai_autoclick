{
  "name": "Documents Archive Management Workflow",
  "description": "Automate document archiving process",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "documents_to_archive": 46,
    "current_doc": 0,
    "archived_docs": 0,
    "retention_violations": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "archive_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize archive counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open archive management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "archive_management_loop",
      "count": "{{documents_to_archive}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start archive management loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select document for archiving"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for archiving"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/archive_management_{{archive_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture archive screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "archive_counter",
      "value": "{{archive_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment archive counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{archive_counter < documents_to_archive}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more documents"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next document"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/documents_archive_management_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
