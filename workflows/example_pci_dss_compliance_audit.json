{
  "name": "PCI DSS Compliance Audit Workflow",
  "description": "Automate PCI DSS requirement verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "pci_requirements_to_check": 68,
    "current_requirement": 0,
    "compliant_requirements": 0,
    "violation_requirements": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "pci_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize PCI counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open PCI compliance dashboard"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for dashboard"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "pci_audit_loop",
      "count": "{{pci_requirements_to_check}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start PCI audit loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select PCI requirement"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for compliance check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/pci_audit_{{pci_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture PCI screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "pci_counter",
      "value": "{{pci_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment PCI counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{pci_counter < pci_requirements_to_check}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more requirements"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next requirement"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/pci_dss_compliance_audit_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}