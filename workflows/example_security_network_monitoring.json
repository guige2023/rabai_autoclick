{
  "name": "Security Network Monitoring Workflow",
  "description": "Automate network security monitoring",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "network_devices_to_monitor": 58,
    "current_device": 0,
    "monitored_devices": 0,
    "alerting_devices": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "device_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize device counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open network monitoring center"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for center"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "network_monitoring_loop",
      "count": "{{network_devices_to_monitor}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start network monitoring loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select network device"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for device check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/network_device_{{device_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture device screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "device_counter",
      "value": "{{device_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment device counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{device_counter < network_devices_to_monitor}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more devices"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next device"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_network_monitoring_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
