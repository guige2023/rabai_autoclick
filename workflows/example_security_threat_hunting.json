{
  "name": "Security Threat Hunting Workflow",
  "description": "Automate proactive threat hunting operations",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "hunting_campaigns_to_run": 44,
    "current_campaign": 0,
    "completed_hunts": 0,
    "threat_indicators_found": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "campaign_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize campaign counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open threat hunting platform"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for platform"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "threat_hunting_loop",
      "count": "{{hunting_campaigns_to_run}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start threat hunting loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Launch hunting hypothesis"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for threat analysis"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/threat_hunt_{{campaign_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture threat hunt screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "campaign_counter",
      "value": "{{campaign_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment campaign counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{campaign_counter < hunting_campaigns_to_run}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more hunts"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next hunt"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_threat_hunting_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
