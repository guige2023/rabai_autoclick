{
  "name": "Security File Integrity Monitoring Workflow",
  "description": "Automate file integrity monitoring operations",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "files_to_monitor": 56,
    "current_file": 0,
    "monitored_files": 0,
    "changed_files": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "file_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize file counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open FIM system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "fim_monitoring_loop",
      "count": "{{files_to_monitor}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start FIM monitoring loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select file for monitoring"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for file check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/file_integrity_{{file_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture file screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "file_counter",
      "value": "{{file_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment file counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{file_counter < files_to_monitor}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more files"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next file"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_file_integrity_monitoring_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
