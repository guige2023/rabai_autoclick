{
  "name": "Service Catalog Verification Workflow",
  "description": "Automate IT service catalog accuracy verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "services_to_verify": 30,
    "current_service": 0,
    "accurate_count": 0,
    "outdated_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "service_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize service counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open service catalog"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for catalog"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "service_catalog_loop",
      "count": "{{services_to_verify}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start service verification loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select service"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for verification"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/service_catalog_{{service_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture verification screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "service_counter",
      "value": "{{service_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment service counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{service_counter < services_to_verify}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more services"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next service"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/service_catalog_verification_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}