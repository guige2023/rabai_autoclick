{
  "name": "Database Permission Audit Workflow",
  "description": "Automate database access permission review",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "permissions_to_review": 52,
    "current_permission": 0,
    "appropriate_count": 0,
    "excessive_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "perm_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize permission counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open database admin console"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for console"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "permission_review_loop",
      "count": "{{permissions_to_review}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start permission review loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select permission entry"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for permission check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/permission_review_{{perm_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture permission screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "perm_counter",
      "value": "{{perm_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment permission counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{perm_counter < permissions_to_review}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more permissions"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next permission"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/database_permission_audit_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}