{
  "name": "User Access Review Workflow",
  "description": "Automate user access rights auditing",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "users_to_review": 30,
    "current_user": 0,
    "compliant_count": 0,
    "violations_found": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "user_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize user counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open access management"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "access_loop",
      "count": "{{users_to_review}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start access review loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Click user"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.3,
      "comment": "Wait for details"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/access_{{user_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture access screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "user_counter",
      "value": "{{user_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment user counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{user_counter < users_to_review}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more users"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next user"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/access_review_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
