{
  "name": "Security Training Completion Tracking Workflow",
  "description": "Automate security training enrollment and tracking",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "training_enrollments_to_track": 68,
    "current_enrollment": 0,
    "completed_enrollments": 0,
    "pending_enrollments": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "training_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize training counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open training management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "training_tracking_loop",
      "count": "{{training_enrollments_to_track}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start training tracking loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select training enrollment"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for completion check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/training_track_{{training_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture training screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "training_counter",
      "value": "{{training_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment training counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{training_counter < training_enrollments_to_track}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more enrollments"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next enrollment"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_training_completion_tracking_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}