{
  "name": "Insider Threat Detection Workflow",
  "description": "Automate insider threat indicator monitoring",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "indicators_to_monitor": 55,
    "current_indicator": 0,
    "normal_indicators": 0,
    "suspicious_indicators": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "insider_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize insider counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open insider threat platform"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for platform"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "insider_detection_loop",
      "count": "{{indicators_to_monitor}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start insider detection loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select threat indicator"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for analysis"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/insider_threat_{{insider_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture insider screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "insider_counter",
      "value": "{{insider_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment insider counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{insider_counter < indicators_to_monitor}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more indicators"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next indicator"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/insider_threat_detection_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}