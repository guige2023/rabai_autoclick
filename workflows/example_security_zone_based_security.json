{
  "name": "Security Zone Based Security Workflow",
  "description": "Automate zone-based security management",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "security_zones_to_manage": 54,
    "current_zone": 0,
    "managed_zones": 0,
    "compromised_zones": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "zone_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize zone counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open zone management console"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for console"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "zone_management_loop",
      "count": "{{security_zones_to_manage}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start zone management loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select security zone"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for zone check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/security_zone_{{zone_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture zone screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "zone_counter",
      "value": "{{zone_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment zone counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{zone_counter < security_zones_to_manage}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more zones"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next zone"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_zone_based_security_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
