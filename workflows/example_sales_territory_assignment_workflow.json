{
  "name": "Sales Territory Assignment Workflow",
  "description": "Automate sales territory assignment including account mapping and rep allocation",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "territories_to_assign": 35,
    "current_territory": 0,
    "assigned_territories": 0,
    "conflict_flags": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "territory_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize territory counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open territory management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for system to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "territory_loop",
      "count": "{{territories_to_assign}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start territory assignment loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open territory definition"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for definition"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/territory_{{territory_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture territory screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Review account assignments"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for review"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Check for conflicts"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for conflict check"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Assign sales rep"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for assignment"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/territory_assigned_{{territory_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture assignment confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "territory_counter",
      "value": "{{territory_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment territory counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{territory_counter < territories_to_assign}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more territories"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next territory"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/territory_assignment_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
