{
  "name": "Mobile Device Management Workflow",
  "description": "Automate mobile device security compliance",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "devices_to_manage": 35,
    "current_device": 0,
    "compliant_count": 0,
    "non_compliant_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "device_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize device counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open mobile device management"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for management"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "mobile_mdm_loop",
      "count": "{{devices_to_manage}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start MDM compliance loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select mobile device"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for compliance check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/mobile_mdm_{{device_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture MDM screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "device_counter",
      "value": "{{device_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment device counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{device_counter < devices_to_manage}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more devices"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next device"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/mobile_device_management_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}