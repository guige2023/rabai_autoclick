{
  "name": "Publishing Layout Design Workflow",
  "description": "Automate publishing layout design",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "layouts_to_design": 51,
    "current_layout": 0,
    "designed_layouts": 0,
    "revisions_needed": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "layout_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize layout counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open layout design system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "layout_design_loop",
      "count": "{{layouts_to_design}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start layout design loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select layout for design"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for design work"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/layout_design_{{layout_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture design screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "layout_counter",
      "value": "{{layout_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment layout counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{layout_counter < layouts_to_design}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more layouts"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next layout"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/publishing_layout_design_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
