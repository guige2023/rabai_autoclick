{
  "name": "Release Version Tagging Workflow",
  "description": "Automate version tagging process",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "versions_to_tag": 52,
    "current_version": 0,
    "tagged_versions": 0,
    "failed_tags": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "version_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize version counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open version control system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "version_tagging_loop",
      "count": "{{versions_to_tag}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start version tagging loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select version for tagging"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for tagging"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/version_tagging_{{version_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture tagging screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "version_counter",
      "value": "{{version_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment version counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{version_counter < versions_to_tag}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more versions"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next version"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/release_version_tagging_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
