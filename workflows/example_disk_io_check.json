{
  "name": "Disk I/O Monitoring Workflow",
  "description": "Automate disk I/O performance monitoring",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "disks_to_check": 6,
    "current_disk": 0,
    "healthy_count": 0,
    "high_io_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "disk_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize disk counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open disk monitor"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for monitor"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "disk_io_loop",
      "count": "{{disks_to_check}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start disk I/O monitoring loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Click disk"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.3,
      "comment": "Wait for metrics"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/disk_io_{{disk_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture disk screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "disk_counter",
      "value": "{{disk_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment disk counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{disk_counter < disks_to_check}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more disks"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next disk"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/disk_io_monitoring_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
