{
  "name": "Security Supply Chain Security Workflow",
  "description": "Automate supply chain security assessment",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "vendors_to_assess": 56,
    "current_vendor": 0,
    "assessed_vendors": 0,
    "high_risk_vendors": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "vendor_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize vendor counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open supply chain security platform"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for platform"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "supply_chain_loop",
      "count": "{{vendors_to_assess}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start supply chain assessment loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select vendor for assessment"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for assessment"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/supply_chain_{{vendor_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture supply chain screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "vendor_counter",
      "value": "{{vendor_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment vendor counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{vendor_counter < vendors_to_assess}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more vendors"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next vendor"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_supply_chain_security_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
