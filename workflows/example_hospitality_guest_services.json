{
  "name": "Hospitality Guest Services Workflow",
  "description": "Automate guest services management",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "services_to_coordinate": 48,
    "current_service": 0,
    "coordinated_services": 0,
    "pending_services": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "guest_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize guest counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open guest services system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "guest_services_loop",
      "count": "{{services_to_coordinate}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start guest services loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select service for coordination"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for coordination"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/guest_services_{{guest_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture service screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "guest_counter",
      "value": "{{guest_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment guest counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{guest_counter < services_to_coordinate}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more services"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next service"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/hospitality_guest_services_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
