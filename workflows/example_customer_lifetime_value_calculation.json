{
  "name": "Customer Lifetime Value Calculation Workflow",
  "description": "Automate CLV calculation",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "customers_to_calculate": 52,
    "current_customer": 0,
    "calculated_customers": 0,
    "failed_calculations": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "clv_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize CLV counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open CLV calculation tool"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for tool"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "clv_calculation_loop",
      "count": "{{customers_to_calculate}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start CLV calculation loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select customer for CLV calculation"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for calculation"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/clv_calculation_{{clv_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture calculation screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "clv_counter",
      "value": "{{clv_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment CLV counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{clv_counter < customers_to_calculate}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more customers"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next customer"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/customer_lifetime_value_calculation_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
