{
  "name": "Certificate Authority Audit Workflow",
  "description": "Automate CA certificate auditing",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "certificates_to_audit": 25,
    "current_cert": 0,
    "valid_count": 0,
    "revoked_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "cert_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize cert counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open CA management"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for management"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "ca_audit_loop",
      "count": "{{certificates_to_audit}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start CA audit loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select certificate"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for audit"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/ca_audit_{{cert_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture audit screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "cert_counter",
      "value": "{{cert_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment cert counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{cert_counter < certificates_to_audit}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more certificates"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next certificate"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/certificate_authority_audit_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}