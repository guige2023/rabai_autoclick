{
  "name": "Security Blue Team Operations Workflow",
  "description": "Automate blue team defense operations",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "defense_tasks_to_complete": 50,
    "current_task": 0,
    "completed_defenses": 0,
    "blocked_attacks": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "task_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize task counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open blue team operations center"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for operations center"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "blue_team_loop",
      "count": "{{defense_tasks_to_complete}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start blue team operations loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select defense task"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for task execution"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/blue_team_{{task_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture blue team screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "task_counter",
      "value": "{{task_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment task counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{task_counter < defense_tasks_to_complete}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more tasks"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next task"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_blue_team_operations_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
