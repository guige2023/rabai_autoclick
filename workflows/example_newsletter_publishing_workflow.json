{
  "name": "Newsletter Publishing Workflow",
  "description": "Automate newsletter publishing including content curation, approval, and distribution scheduling",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "newsletters_to_publish": 30,
    "current_newsletter": 0,
    "published_newsletters": 0,
    "pending_approvals": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "newsletter_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize newsletter counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open CMS publishing system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for CMS to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "publishing_loop",
      "count": "{{newsletters_to_publish}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start newsletter publishing loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open newsletter draft"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for draft"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/newsletter_{{newsletter_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture newsletter screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Review content"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for review"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Obtain approval"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for approval"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Schedule distribution"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for scheduling"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/newsletter_published_{{newsletter_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture publishing confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "newsletter_counter",
      "value": "{{newsletter_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment newsletter counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{newsletter_counter < newsletters_to_publish}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more newsletters"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next newsletter"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/newsletter_publishing_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
