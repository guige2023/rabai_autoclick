{
  "name": "Legal Client Tracking Workflow",
  "description": "Automate legal client relationship tracking",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "clients_to_track": 79,
    "current_client": 0,
    "tracked_clients": 0,
    "active_matters": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "client_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize client counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open client tracking system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "client_tracking_loop",
      "count": "{{clients_to_track}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start client tracking loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select client for tracking"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for client update"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/client_tracking_{{client_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture client screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "client_counter",
      "value": "{{client_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment client counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{client_counter < clients_to_track}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more clients"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next client"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/legal_client_tracking_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
