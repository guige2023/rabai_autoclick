{
  "name": "Security Digital Forensics Workflow",
  "description": "Automate digital forensics investigation",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "evidence_to_analyze": 48,
    "current_evidence": 0,
    "analyzed_evidence": 0,
    "critical_findings": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "evidence_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize evidence counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open forensics platform"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for platform"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "forensics_loop",
      "count": "{{evidence_to_analyze}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start forensics investigation loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select evidence item"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for evidence analysis"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/forensics_{{evidence_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture forensics screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "evidence_counter",
      "value": "{{evidence_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment evidence counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{evidence_counter < evidence_to_analyze}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more evidence"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next evidence"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_digital_forensics_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
