{
  "name": "Retail Supplier Management Workflow",
  "description": "Automate retail supplier relationship tracking",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "suppliers_to_track": 69,
    "current_supplier": 0,
    "tracked_suppliers": 0,
    "order_fulfillment_rate": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "supplier_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize supplier counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open supplier management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "supplier_management_loop",
      "count": "{{suppliers_to_track}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start supplier management loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select supplier for tracking"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for supplier update"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/supplier_management_{{supplier_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture supplier screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "supplier_counter",
      "value": "{{supplier_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment supplier counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{supplier_counter < suppliers_to_track}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more suppliers"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next supplier"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/retail_supplier_management_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
