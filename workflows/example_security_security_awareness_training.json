{
  "name": "Security Security Awareness Training Workflow",
  "description": "Automate security awareness training tracking",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "employees_to_train": 60,
    "current_employee": 0,
    "trained_employees": 0,
    "pending_training": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "employee_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize employee counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open training management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "training_loop",
      "count": "{{employees_to_train}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start training tracking loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select employee training record"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for training update"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/training_record_{{employee_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture training screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "employee_counter",
      "value": "{{employee_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment employee counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{employee_counter < employees_to_train}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more employees"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next employee"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_security_awareness_training_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
