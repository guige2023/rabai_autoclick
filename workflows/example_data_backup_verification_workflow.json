{
  "name": "Data Backup Verification Workflow",
  "description": "Automate data backup verification including backup status checks and restore testing",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "backups_to_verify": 40,
    "current_backup": 0,
    "verified_backups": 0,
    "failed_backups": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "backup_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize backup counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open backup management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for system to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "verification_loop",
      "count": "{{backups_to_verify}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start backup verification loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select backup for verification"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for selection"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/backup_{{backup_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture backup screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Verify backup integrity"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for verification"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Run restore test"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.2,
      "comment": "Wait for restore test"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Log verification results"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for logging"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/backup_verified_{{backup_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture verification confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "backup_counter",
      "value": "{{backup_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment backup counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{backup_counter < backups_to_verify}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more backups"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next backup"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/backup_verification_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
