{
  "name": "Application API Versioning Workflow",
  "description": "Automate API version management",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "api_versions_to_manage": 46,
    "current_version": 0,
    "managed_versions": 0,
    "deprecation_warnings": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "version_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize version counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open API management portal"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for portal"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "api_versioning_loop",
      "count": "{{api_versions_to_manage}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start API versioning loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select API version"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for version check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/api_version_{{version_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture version screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "version_counter",
      "value": "{{version_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment version counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{version_counter < api_versions_to_manage}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more versions"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next version"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/application_api_versioning_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
