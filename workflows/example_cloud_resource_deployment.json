{
  "name": "Cloud Resource Deployment Workflow",
  "description": "Automate cloud infrastructure deployment process",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "environments": ["dev", "staging", "production"],
    "current_env": 0,
    "deployment_steps": 5
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "env_index",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize environment index"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open cloud console"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for console"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "env_loop",
      "count": 3,
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start environment loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select environment"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.3,
      "comment": "Wait for selection"
    },
    {
      "id": 7,
      "type": "click",
      "x": 300,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Click deploy button"
    },
    {
      "id": 8,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for deployment"
    },
    {
      "id": 9,
      "type": "screenshot",
      "save_path": "./screenshots/deploy_{{env_index}}.png",
      "pre_delay": 0.5,
      "comment": "Capture deployment screenshot"
    },
    {
      "id": 10,
      "type": "set_variable",
      "name": "env_index",
      "value": "{{env_index + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment environment index"
    },
    {
      "id": 11,
      "type": "condition",
      "condition": "{{env_index < 3}}",
      "true_next": 12,
      "false_next": 13,
      "pre_delay": 0.1,
      "comment": "Check if more environments"
    },
    {
      "id": 12,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next environment"
    },
    {
      "id": 13,
      "type": "screenshot",
      "save_path": "./screenshots/deployment_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 14,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
