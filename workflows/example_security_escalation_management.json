{
  "name": "Security Escalation Management Workflow",
  "description": "Automate security incident escalation tracking",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "escalations_to_manage": 55,
    "current_escalation": 0,
    "resolved_escalations": 0,
    "pending_escalations": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "escalation_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize escalation counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open escalation management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "escalation_management_loop",
      "count": "{{escalations_to_manage}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start escalation management loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select escalation item"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for escalation check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/escalation_track_{{escalation_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture escalation screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "escalation_counter",
      "value": "{{escalation_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment escalation counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{escalation_counter < escalations_to_manage}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more escalations"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next escalation"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_escalation_management_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}