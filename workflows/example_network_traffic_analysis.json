{
  "name": "Network Traffic Analysis Workflow",
  "description": "Automate network traffic pattern analysis",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "traffic_samples_to_analyze": 45,
    "current_sample": 0,
    "normal_traffic": 0,
    "anomalous_traffic": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "traffic_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize traffic counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open network analysis tool"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for tool"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "traffic_analysis_loop",
      "count": "{{traffic_samples_to_analyze}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start traffic analysis loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select traffic sample"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for analysis"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/traffic_analysis_{{traffic_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture analysis screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "traffic_counter",
      "value": "{{traffic_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment traffic counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{traffic_counter < traffic_samples_to_analyze}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more samples"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next sample"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/network_traffic_analysis_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}