{
  "name": "Customer Feedback Analysis Workflow",
  "description": "Automate customer feedback collection and analysis",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "feedback_sources": ["survey", "support", "social"],
    "current_source": 0,
    "feedback_collected": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "source_index",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize source index"
    },
    {
      "id": 2,
      "type": "loop",
      "loop_id": "sources_loop",
      "count": 3,
      "loop_start": 3,
      "pre_delay": 0.3,
      "comment": "Start sources loop"
    },
    {
      "id": 3,
      "type": "click",
      "x": 50,
      "y": 50,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Click address bar"
    },
    {
      "id": 4,
      "type": "type_text",
      "text": "https://{{feedback_sources[source_index]}}.example.com/feedback",
      "enter_after": true,
      "pre_delay": 0.3,
      "comment": "Navigate to feedback source"
    },
    {
      "id": 5,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for page"
    },
    {
      "id": 6,
      "type": "screenshot",
      "save_path": "./screenshots/feedback_{{source_index}}.png",
      "pre_delay": 0.5,
      "comment": "Capture feedback screenshot"
    },
    {
      "id": 7,
      "type": "set_variable",
      "name": "source_index",
      "value": "{{source_index + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment source index"
    },
    {
      "id": 8,
      "type": "condition",
      "condition": "{{source_index < 3}}",
      "true_next": 9,
      "false_next": 10,
      "pre_delay": 0.1,
      "comment": "Check if more sources"
    },
    {
      "id": 9,
      "type": "goto",
      "step_id": 2,
      "pre_delay": 0.1,
      "comment": "Continue to next source"
    },
    {
      "id": 10,
      "type": "screenshot",
      "save_path": "./screenshots/feedback_analysis_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
