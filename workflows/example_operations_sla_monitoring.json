{
  "name": "Operations SLA Monitoring Workflow",
  "description": "Automate SLA compliance monitoring",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "sla_targets_to_monitor": 46,
    "current_target": 0,
    "met_sla_targets": 0,
    "breached_sla_targets": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "sla_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize SLA counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open SLA monitoring dashboard"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for dashboard"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "sla_monitoring_loop",
      "count": "{{sla_targets_to_monitor}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start SLA monitoring loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select SLA target"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for SLA check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/sla_check_{{sla_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture SLA screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "sla_counter",
      "value": "{{sla_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment SLA counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{sla_counter < sla_targets_to_monitor}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more SLA targets"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next SLA"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/operations_sla_monitoring_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
