{
  "name": "Travel Airline Crew Scheduling Workflow",
  "description": "Automate airline crew scheduling including pairing optimization and conflict resolution",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "crew_assignments": 60,
    "current_assignment": 0,
    "scheduled_crews": 0,
    "conflict_flags": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "assignment_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize assignment counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open crew scheduling system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for system to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "crew_scheduling_loop",
      "count": "{{crew_assignments}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start crew scheduling loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open flight assignment"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for assignment details"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/crew_assignment_{{assignment_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture assignment screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Verify crew availability"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for availability check"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Check FAR compliance"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for compliance check"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Assign crew pairing"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.2,
      "comment": "Wait for pairing"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/pairing_complete_{{assignment_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture pairing confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "assignment_counter",
      "value": "{{assignment_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment assignment counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{assignment_counter < crew_assignments}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more assignments"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next assignment"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/crew_scheduling_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
