{
  "name": "Binary Analysis Security Workflow",
  "description": "Automate binary security analysis",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "binaries_to_analyze": 42,
    "current_binary": 0,
    "secure_binaries": 0,
    "malicious_binaries": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "binary_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize binary counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open binary analysis platform"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for platform"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "binary_analysis_loop",
      "count": "{{binaries_to_analyze}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start binary analysis loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select binary file"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for analysis"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/binary_analysis_{{binary_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture binary screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "binary_counter",
      "value": "{{binary_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment binary counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{binary_counter < binaries_to_analyze}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more binaries"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next binary"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/binary_analysis_security_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}