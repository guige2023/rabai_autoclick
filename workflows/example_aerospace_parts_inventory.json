{
  "name": "Aerospace Parts Inventory Workflow",
  "description": "Automate aerospace parts inventory",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "parts_to_track": 54,
    "current_part": 0,
    "tracked_parts": 0,
    "low_stock_alerts": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "part_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize part counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open parts inventory system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "parts_inventory_loop",
      "count": "{{parts_to_track}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start parts inventory loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select part for tracking"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for tracking update"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/parts_inventory_{{part_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture inventory screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "part_counter",
      "value": "{{part_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment part counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{part_counter < parts_to_track}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more parts"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next part"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/aerospace_parts_inventory_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
