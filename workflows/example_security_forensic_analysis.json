{
  "name": "Security Forensic Analysis Workflow",
  "description": "Automate digital forensic evidence collection",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "evidence_sources_to_collect": 50,
    "current_source": 0,
    "collected_evidence": 0,
    "failed_collections": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "forensic_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize forensic counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open forensic analysis platform"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for platform"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "forensic_collection_loop",
      "count": "{{evidence_sources_to_collect}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start forensic collection loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select evidence source"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for evidence collection"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/forensic_collect_{{forensic_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture forensic screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "forensic_counter",
      "value": "{{forensic_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment forensic counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{forensic_counter < evidence_sources_to_collect}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more sources"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next source"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_forensic_analysis_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}