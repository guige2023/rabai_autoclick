{
  "name": "Conference Room Scheduling Workflow",
  "description": "Automate conference room scheduling",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "rooms_to_schedule": 51,
    "current_room": 0,
    "scheduled_rooms": 0,
    "conflicts": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "room_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize room counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open room scheduling system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "room_scheduling_loop",
      "count": "{{rooms_to_schedule}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start room scheduling loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select room for scheduling"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for scheduling"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/room_scheduling_{{room_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture scheduling screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "room_counter",
      "value": "{{room_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment room counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{room_counter < rooms_to_schedule}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more rooms"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next room"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/conference_room_scheduling_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
