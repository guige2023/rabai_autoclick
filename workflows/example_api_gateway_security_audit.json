{
  "name": "API Gateway Security Audit Workflow",
  "description": "Automate API gateway configuration security review",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "gateway_rules_to_audit": 48,
    "current_rule": 0,
    "secure_rules": 0,
    "insecure_rules": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "gateway_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize gateway counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open API gateway management"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for management"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "gateway_audit_loop",
      "count": "{{gateway_rules_to_audit}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start gateway audit loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select gateway rule"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for rule check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/gateway_audit_{{gateway_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture gateway screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "gateway_counter",
      "value": "{{gateway_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment gateway counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{gateway_counter < gateway_rules_to_audit}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more rules"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next rule"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/api_gateway_security_audit_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}