{
  "name": "Website Uptime Monitoring Workflow",
  "description": "Monitor website uptime and response times",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "websites": [
      "https://site1.example.com",
      "https://site2.example.com",
      "https://site3.example.com"
    ],
    "check_interval": 600,
    "max_checks": 50,
    "current_check": 0,
    "down_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "check_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize check counter"
    },
    {
      "id": 2,
      "type": "loop",
      "loop_id": "monitor_loop",
      "count": "{{max_checks}}",
      "loop_start": 3,
      "pre_delay": 0.3,
      "comment": "Start monitoring loop"
    },
    {
      "id": 3,
      "type": "set_variable",
      "name": "site_index",
      "value": 0,
      "value_type": "int",
      "pre_delay": 0.2,
      "comment": "Initialize site index"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "sites_loop",
      "count": 3,
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Loop through websites"
    },
    {
      "id": 5,
      "type": "click",
      "x": 50,
      "y": 50,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Click address bar"
    },
    {
      "id": 6,
      "type": "type_text",
      "text": "{{websites[site_index]}}",
      "enter_after": true,
      "pre_delay": 0.3,
      "comment": "Navigate to website"
    },
    {
      "id": 7,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for page load"
    },
    {
      "id": 8,
      "type": "screenshot",
      "save_path": "./screenshots/site_check_{{check_counter}}_{{site_index}}.png",
      "pre_delay": 0.5,
      "comment": "Capture site screenshot"
    },
    {
      "id": 9,
      "type": "ocr",
      "region": [0, 0, 200, 50],
      "output_var": "page_title",
      "pre_delay": 0.3,
      "comment": "Read page title"
    },
    {
      "id": 10,
      "type": "condition",
      "condition": "{{page_title.includes('Error') OR page_title.includes('404')}}",
      "true_next": 11,
      "false_next": 13,
      "pre_delay": 0.1,
      "comment": "Check for errors"
    },
    {
      "id": 11,
      "type": "set_variable",
      "name": "down_count",
      "value": "{{down_count + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment down count"
    },
    {
      "id": 12,
      "type": "goto",
      "step_id": 16,
      "pre_delay": 0.1,
      "comment": "Skip to next site"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 0.5,
      "pre_delay": 0.2,
      "comment": "Site is up"
    },
    {
      "id": 14,
      "type": "set_variable",
      "name": "site_index",
      "value": "{{site_index + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment site index"
    },
    {
      "id": 15,
      "type": "condition",
      "condition": "{{site_index < 3}}",
      "true_next": 16,
      "false_next": 17,
      "pre_delay": 0.1,
      "comment": "Check if more sites"
    },
    {
      "id": 16,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next site"
    },
    {
      "id": 17,
      "type": "set_variable",
      "name": "check_counter",
      "value": "{{check_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment check counter"
    },
    {
      "id": 18,
      "type": "condition",
      "condition": "{{check_counter < max_checks}}",
      "true_next": 19,
      "false_next": 20,
      "pre_delay": 0.1,
      "comment": "Check if more checks"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": "{{check_interval}}",
      "pre_delay": 0.5,
      "comment": "Wait before next check cycle"
    },
    {
      "id": 20,
      "type": "screenshot",
      "save_path": "./screenshots/monitoring_summary.png",
      "pre_delay": 0.5,
      "comment": "Capture final summary"
    },
    {
      "id": 21,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": false
  }
}
