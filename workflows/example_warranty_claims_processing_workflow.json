{
  "name": "Warranty Claims Processing Workflow",
  "description": "Automate warranty claims processing from claim submission to reimbursement",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "claims_to_process": 45,
    "current_claim": 0,
    "processed_claims": 0,
    "approved_claims": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "claim_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize claim counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open warranty claims system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for system to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "claims_loop",
      "count": "{{claims_to_process}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start claims processing loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open warranty claim"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for claim details"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/warranty_claim_{{claim_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture claim screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Verify warranty coverage"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for verification"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Review claim documentation"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for review"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Process reimbursement"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for processing"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/claim_processed_{{claim_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture processing confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "claim_counter",
      "value": "{{claim_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment claim counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{claim_counter < claims_to_process}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more claims"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next claim"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/warranty_claims_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
