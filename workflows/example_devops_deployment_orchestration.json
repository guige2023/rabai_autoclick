{
  "name": "DevOps Deployment Orchestration Workflow",
  "description": "Automate deployment orchestration across environments",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "deployments_to_orchestrate": 46,
    "current_deployment": 0,
    "successful_deployments": 0,
    "rolled_back_deployments": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "deployment_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize deployment counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open deployment orchestration platform"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for platform"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "deployment_orchestration_loop",
      "count": "{{deployments_to_orchestrate}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start deployment orchestration loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select deployment target"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for deployment"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/deployment_{{deployment_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture deployment screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "deployment_counter",
      "value": "{{deployment_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment deployment counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{deployment_counter < deployments_to_orchestrate}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more deployments"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next deployment"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/devops_deployment_orchestration_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
