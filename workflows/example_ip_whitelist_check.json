{
  "name": "IP Whitelist Verification Workflow",
  "description": "Automate IP whitelist compliance verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "ips_to_verify": 20,
    "current_ip": 0,
    "whitelisted_count": 0,
    "violation_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "ip_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize IP counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open firewall dashboard"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for dashboard"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "whitelist_loop",
      "count": "{{ips_to_verify}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start whitelist verification loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Click IP entry"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.3,
      "comment": "Wait for verification"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/whitelist_{{ip_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture whitelist screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "ip_counter",
      "value": "{{ip_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment IP counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{ip_counter < ips_to_verify}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more IPs"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next IP"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/whitelist_verification_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
