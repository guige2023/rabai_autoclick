{
  "name": "IoT Sensor Calibration Workflow",
  "description": "Automate sensor calibration",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "sensors_to_calibrate": 46,
    "current_sensor": 0,
    "calibrated_sensors": 0,
    "failed_calibrations": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "calibration_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize calibration counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open sensor calibration tool"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for tool"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "sensor_calibration_loop",
      "count": "{{sensors_to_calibrate}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start sensor calibration loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select sensor for calibration"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for calibration"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/sensor_calibration_{{calibration_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture calibration screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "calibration_counter",
      "value": "{{calibration_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment calibration counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{calibration_counter < sensors_to_calibrate}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more sensors"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next sensor"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/iot_sensor_calibration_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
