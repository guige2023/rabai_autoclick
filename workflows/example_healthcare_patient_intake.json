{
  "name": "Healthcare Patient Intake Workflow",
  "description": "Automate patient intake process",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "patients_to_intake": 47,
    "current_patient": 0,
    "intaked_patients": 0,
    "pending_intake": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "intake_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize intake counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open patient intake system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "patient_intake_loop",
      "count": "{{patients_to_intake}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start patient intake loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select patient for intake"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for intake processing"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/patient_intake_{{intake_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture intake screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "intake_counter",
      "value": "{{intake_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment intake counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{intake_counter < patients_to_intake}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more patients"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next patient"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/healthcare_patient_intake_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
