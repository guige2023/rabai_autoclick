{
  "name": "Security Phishing URL Analysis Workflow",
  "description": "Automate phishing URL detection and analysis",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "urls_to_analyze": 56,
    "current_url": 0,
    "analyzed_urls": 0,
    "malicious_urls": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "url_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize URL counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open phishing analysis platform"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for platform"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "phishing_analysis_loop",
      "count": "{{urls_to_analyze}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start URL analysis loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select URL for analysis"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for URL analysis"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/phishing_url_{{url_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture URL screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "url_counter",
      "value": "{{url_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment URL counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{url_counter < urls_to_analyze}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more URLs"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next URL"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_phishing_url_analysis_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
