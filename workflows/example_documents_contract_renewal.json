{
  "name": "Documents Contract Renewal Workflow",
  "description": "Automate contract renewal tracking",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "contracts_to_renew": 50,
    "current_contract": 0,
    "renewed_contracts": 0,
    "pending_renewals": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "renewal_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize renewal counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open contract management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "contract_renewal_loop",
      "count": "{{contracts_to_renew}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start contract renewal loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select contract for renewal"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for renewal processing"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/contract_renewal_{{renewal_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture renewal screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "renewal_counter",
      "value": "{{renewal_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment renewal counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{renewal_counter < contracts_to_renew}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more contracts"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next contract"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/documents_contract_renewal_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
