{
  "name": "Legal Regulatory Filing Workflow",
  "description": "Automate regulatory filing process",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "filings_to_prepare": 50,
    "current_filing": 0,
    "prepared_filings": 0,
    "failed_filings": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "filing_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize filing counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open regulatory filing system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "regulatory_filing_loop",
      "count": "{{filings_to_prepare}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start regulatory filing loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select filing for preparation"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for preparation"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/regulatory_filing_{{filing_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture filing screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "filing_counter",
      "value": "{{filing_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment filing counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{filing_counter < filings_to_prepare}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more filings"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next filing"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/legal_regulatory_filing_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
