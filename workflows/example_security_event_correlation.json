{
  "name": "Security Event Correlation Workflow",
  "description": "Automate security event correlation analysis",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "security_events_to_correlate": 68,
    "current_event": 0,
    "correlated_events": 0,
    "isolated_events": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "correlation_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize correlation counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open SIEM correlation engine"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for engine"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "correlation_analysis_loop",
      "count": "{{security_events_to_correlate}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start correlation analysis loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select security event"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for correlation"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/correlation_analysis_{{correlation_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture correlation screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "correlation_counter",
      "value": "{{correlation_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment correlation counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{correlation_counter < security_events_to_correlate}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more events"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next event"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_event_correlation_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}