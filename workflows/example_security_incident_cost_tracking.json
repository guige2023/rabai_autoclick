{
  "name": "Security Incident Cost Tracking Workflow",
  "description": "Automate security incident expense tracking",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "incident_costs_to_track": 48,
    "current_cost": 0,
    "tracked_costs": 0,
    "untracked_costs": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "cost_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize cost counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open cost tracking system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "cost_tracking_loop",
      "count": "{{incident_costs_to_track}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start cost tracking loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select incident cost item"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for cost tracking"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/cost_track_{{cost_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture cost screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "cost_counter",
      "value": "{{cost_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment cost counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{cost_counter < incident_costs_to_track}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more costs"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next cost"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_incident_cost_tracking_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}