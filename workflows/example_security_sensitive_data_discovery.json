{
  "name": "Security Sensitive Data Discovery Workflow",
  "description": "Automate sensitive data discovery and classification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "data_stores_to_scan": 48,
    "current_store": 0,
    "sensitive_data_found": 0,
    "clean_stores": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "store_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize store counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open data discovery tool"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for tool"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "data_discovery_loop",
      "count": "{{data_stores_to_scan}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start data discovery loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select data store"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for scan"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/data_discovery_{{store_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture discovery screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "store_counter",
      "value": "{{store_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment store counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{store_counter < data_stores_to_scan}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more stores"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next store"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_sensitive_data_discovery_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
