{
  "name": "Threat Modeling Automation Workflow",
  "description": "Automate threat model generation",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "threat_models_to_generate": 45,
    "current_model": 0,
    "complete_models": 0,
    "incomplete_models": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "threat_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize threat counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open threat modeling tool"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for tool"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "threat_modeling_loop",
      "count": "{{threat_models_to_generate}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start threat modeling loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select system component"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for threat analysis"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/threat_model_{{threat_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture threat screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "threat_counter",
      "value": "{{threat_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment threat counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{threat_counter < threat_models_to_generate}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more models"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next model"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/threat_modeling_automation_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}