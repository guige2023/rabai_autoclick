{
  "name": "Quality Assurance Code Coverage Workflow",
  "description": "Automate code coverage analysis",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "modules_to_analyze": 46,
    "current_module": 0,
    "analyzed_modules": 0,
    "low_coverage_modules": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "coverage_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize coverage counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open code coverage tool"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for tool"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "code_coverage_loop",
      "count": "{{modules_to_analyze}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start code coverage loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select module for coverage"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for coverage analysis"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/code_coverage_analysis_{{coverage_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture coverage screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "coverage_counter",
      "value": "{{coverage_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment coverage counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{coverage_counter < modules_to_analyze}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more modules"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next module"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/quality_assurance_code_coverage_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
