{
  "name": "Support Knowledge Base Maintenance Workflow",
  "description": "Automate knowledge base article updates",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "articles_to_update": 50,
    "current_article": 0,
    "updated_articles": 0,
    "outdated_articles": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "article_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize article counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open knowledge base management"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for management"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "knowledge_base_loop",
      "count": "{{articles_to_update}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start knowledge base loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select article for update"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for update"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/kb_article_{{article_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture article screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "article_counter",
      "value": "{{article_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment article counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{article_counter < articles_to_update}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more articles"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next article"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/support_knowledge_base_maintenance_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
