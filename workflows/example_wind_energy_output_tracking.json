{
  "name": "Wind Energy Output Tracking Workflow",
  "description": "Automate wind energy output tracking",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "output_records": 50,
    "current_record": 0,
    "tracked_records": 0,
    "efficiency_metrics": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "output_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize output counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open energy output tracking system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "output_tracking_loop",
      "count": "{{output_records}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start output tracking loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select record for tracking"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for tracking update"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/output_tracking_{{output_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture tracking screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "output_counter",
      "value": "{{output_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment output counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{output_counter < output_records}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more records"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next record"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/wind_energy_output_tracking_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
