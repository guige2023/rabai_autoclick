{
  "name": "Blockchain Transaction Monitoring Workflow",
  "description": "Automate blockchain transaction monitoring",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "transactions_to_monitor": 52,
    "current_transaction": 0,
    "monitored_transactions": 0,
    "flagged_transactions": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "transaction_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize transaction counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open blockchain monitoring tool"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for tool"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "transaction_monitoring_loop",
      "count": "{{transactions_to_monitor}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start transaction monitoring loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select transaction for monitoring"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for monitoring"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/transaction_monitoring_{{transaction_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture monitoring screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "transaction_counter",
      "value": "{{transaction_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment transaction counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{transaction_counter < transactions_to_monitor}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more transactions"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next transaction"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/blockchain_transaction_monitoring_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
