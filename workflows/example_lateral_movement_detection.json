{
  "name": "Lateral Movement Detection Workflow",
  "description": "Automate lateral movement pattern detection",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "movement_patterns_to_check": 55,
    "current_pattern": 0,
    "normal_movement": 0,
    "suspicious_movement": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "lateral_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize lateral counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open threat detection platform"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for platform"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "lateral_detection_loop",
      "count": "{{movement_patterns_to_check}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start lateral movement loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select movement pattern"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for pattern analysis"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/lateral_movement_{{lateral_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture lateral screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "lateral_counter",
      "value": "{{lateral_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment lateral counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{lateral_counter < movement_patterns_to_check}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more patterns"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next pattern"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/lateral_movement_detection_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}