{
  "name": "Streaming Content Delivery Workflow",
  "description": "Automate streaming content delivery",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "contents_to_deliver": 53,
    "current_content": 0,
    "delivered_contents": 0,
    "cdn_metrics": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "content_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize content counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open content delivery system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "content_delivery_loop",
      "count": "{{contents_to_deliver}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start content delivery loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select content for delivery"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for delivery"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/content_delivery_{{content_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture delivery screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "content_counter",
      "value": "{{content_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment content counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{content_counter < contents_to_deliver}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more contents"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next content"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/streaming_content_delivery_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
