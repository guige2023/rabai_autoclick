{
  "name": "Facilities Space Utilization Workflow",
  "description": "Automate workspace utilization tracking",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "spaces_to_analyze": 52,
    "current_space": 0,
    "analyzed_spaces": 0,
    "underutilized_spaces": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "space_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize space counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open space utilization system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "space_utilization_loop",
      "count": "{{spaces_to_analyze}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start space utilization loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select space for analysis"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for analysis"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/space_utilization_{{space_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture utilization screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "space_counter",
      "value": "{{space_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment space counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{space_counter < spaces_to_analyze}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more spaces"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next space"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/facilities_space_utilization_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
