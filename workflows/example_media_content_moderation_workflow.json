{
  "name": "Media Content Moderation Workflow",
  "description": "Automate media content moderation including image review, flagging, and approval routing",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "content_to_moderate": 60,
    "current_content": 0,
    "moderated_content": 0,
    "flagged_content": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "content_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize content counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open content moderation dashboard"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for dashboard to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "moderation_loop",
      "count": "{{content_to_moderate}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start content moderation loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open content item"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for content to load"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/content_{{content_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture content screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Run content analysis"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for analysis"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Apply moderation policy"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for policy application"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Route for approval or publish"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for routing"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/moderation_complete_{{content_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture moderation confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "content_counter",
      "value": "{{content_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment content counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{content_counter < content_to_moderate}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more content"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next content"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/moderation_batch_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture batch completion"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
