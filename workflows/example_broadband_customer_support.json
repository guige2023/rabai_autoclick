{
  "name": "Broadband Customer Support Workflow",
  "description": "Automate broadband customer support",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "tickets_to_handle": 52,
    "current_ticket": 0,
    "handled_tickets": 0,
    "escalated_tickets": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "ticket_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize ticket counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open customer support system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "customer_support_loop",
      "count": "{{tickets_to_handle}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start customer support loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select ticket for handling"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for handling"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/customer_support_{{ticket_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture support screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "ticket_counter",
      "value": "{{ticket_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment ticket counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{ticket_counter < tickets_to_handle}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more tickets"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next ticket"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/broadband_customer_support_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
