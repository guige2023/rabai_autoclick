{
  "name": "Data Exfiltration Detection Workflow",
  "description": "Automate data exfiltration attempt detection",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "data_transfers_to_monitor": 65,
    "current_transfer": 0,
    "legitimate_transfers": 0,
    "suspicious_transfers": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "exfil_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize exfil counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open DLP console"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for console"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "exfil_detection_loop",
      "count": "{{data_transfers_to_monitor}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start exfiltration detection loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select data transfer"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for exfil check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/exfil_detect_{{exfil_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture exfil screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "exfil_counter",
      "value": "{{exfil_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment exfil counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{exfil_counter < data_transfers_to_monitor}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more transfers"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next transfer"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/data_exfiltration_detection_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}