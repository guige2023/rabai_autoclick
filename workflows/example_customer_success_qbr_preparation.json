{
  "name": "Customer Success QBR Preparation Workflow",
  "description": "Automate Quarterly Business Review preparation",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "qbr_accounts_to_prepare": 46,
    "current_account": 0,
    "prepared_accounts": 0,
    "at_risk_accounts": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "qbr_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize QBR counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open QBR preparation system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "qbr_preparation_loop",
      "count": "{{qbr_accounts_to_prepare}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start QBR preparation loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select account for QBR prep"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for preparation"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/qbr_preparation_{{qbr_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture QBR screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "qbr_counter",
      "value": "{{qbr_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment QBR counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{qbr_counter < qbr_accounts_to_prepare}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more accounts"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next account"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/customer_success_qbr_preparation_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
