{
  "name": "Hospitality Spa Appointment Booking Workflow",
  "description": "Automate spa appointment booking including therapist assignment and resource scheduling",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "appointments_to_book": 35,
    "current_appointment": 0,
    "booked_appointments": 0,
    "cancelled_appointments": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "appointment_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize appointment counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open spa booking system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for system to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "booking_loop",
      "count": "{{appointments_to_book}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start booking loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open booking request"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for request details"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/spa_booking_{{appointment_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture booking screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Check therapist availability"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for availability check"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Assign therapist"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for assignment"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Confirm booking"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for confirmation"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/booking_confirmed_{{appointment_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "appointment_counter",
      "value": "{{appointment_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment appointment counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{appointment_counter < appointments_to_book}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more bookings"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next booking"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/spa_booking_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
