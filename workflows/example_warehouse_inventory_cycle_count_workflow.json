{
  "name": "Warehouse Inventory Cycle Count Workflow",
  "description": "Automate warehouse inventory cycle counting including count verification and variance analysis",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "locations_to_count": 50,
    "current_location": 0,
    "counted_locations": 0,
    "variance_flags": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "location_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize location counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open WMS inventory system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for WMS to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "cycle_count_loop",
      "count": "{{locations_to_count}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start cycle count loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Navigate to location"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for location"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/location_{{location_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture location screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Record physical count"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for recording"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Compare with system quantity"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for comparison"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Adjust inventory if needed"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for adjustment"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/count_complete_{{location_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture count confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "location_counter",
      "value": "{{location_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment location counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{location_counter < locations_to_count}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more locations"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next location"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/cycle_count_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
