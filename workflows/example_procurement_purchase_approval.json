{
  "name": "Procurement Purchase Approval Workflow",
  "description": "Automate purchase request approval process",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "purchase_requests_to_process": 46,
    "current_request": 0,
    "processed_requests": 0,
    "approved_requests": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "purchase_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize purchase counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open purchase approval system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "purchase_approval_loop",
      "count": "{{purchase_requests_to_process}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start purchase approval loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select purchase request"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for approval review"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/purchase_approval_{{purchase_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture purchase screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "purchase_counter",
      "value": "{{purchase_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment purchase counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{purchase_counter < purchase_requests_to_process}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more requests"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next request"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/procurement_purchase_approval_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
