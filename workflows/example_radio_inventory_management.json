{
  "name": "Radio Inventory Management Workflow",
  "description": "Automate radio inventory management",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "equipment_to_track": 49,
    "current_equipment": 0,
    "tracked_equipment": 0,
    "maintenance_required": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "equipment_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize equipment counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open inventory management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "inventory_management_loop",
      "count": "{{equipment_to_track}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start inventory management loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select equipment for tracking"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for tracking update"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/inventory_tracking_{{equipment_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture tracking screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "equipment_counter",
      "value": "{{equipment_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment equipment counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{equipment_counter < equipment_to_track}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more equipment"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next equipment"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/radio_inventory_management_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
