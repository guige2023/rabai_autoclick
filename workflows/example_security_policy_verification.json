{
  "name": "Security Policy Verification Workflow",
  "description": "Automate security policy compliance verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "policy_controls_to_verify": 72,
    "current_control": 0,
    "compliant_controls": 0,
    "violation_controls": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "policy_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize policy counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open policy management portal"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for portal"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "policy_verification_loop",
      "count": "{{policy_controls_to_verify}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start policy verification loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select policy control"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for compliance check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/policy_verify_{{policy_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture policy screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "policy_counter",
      "value": "{{policy_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment policy counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{policy_counter < policy_controls_to_verify}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more controls"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next control"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_policy_verification_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}