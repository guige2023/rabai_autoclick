{
  "name": "Data Breach Notification Check Workflow",
  "description": "Automate data breach notification compliance",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "breaches_to_review": 12,
    "current_breach": 0,
    "notified_count": 0,
    "pending_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "breach_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize breach counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open breach management"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for management"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "breach_notification_loop",
      "count": "{{breaches_to_review}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start breach notification loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select breach case"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for notification check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/breach_notification_{{breach_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture notification screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "breach_counter",
      "value": "{{breach_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment breach counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{breach_counter < breaches_to_review}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more breaches"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next breach"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/data_breach_notification_check_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}