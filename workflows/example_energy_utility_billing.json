{
  "name": "Energy Utility Billing Workflow",
  "description": "Automate utility billing process",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "bills_to_generate": 52,
    "current_bill": 0,
    "generated_bills": 0,
    "failed_bills": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "utility_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize utility counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open utility billing system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "utility_billing_loop",
      "count": "{{bills_to_generate}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start utility billing loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select bill for generation"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for generation"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/utility_billing_{{utility_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture billing screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "utility_counter",
      "value": "{{utility_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment utility counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{utility_counter < bills_to_generate}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more bills"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next bill"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/energy_utility_billing_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
