{
  "name": "Education Attendance Tracking Workflow",
  "description": "Automate attendance tracking",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "attendance_to_track": 49,
    "current_attendance": 0,
    "tracked_attendance": 0,
    "absent_students": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "attendance_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize attendance counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open attendance tracking system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "attendance_tracking_loop",
      "count": "{{attendance_to_track}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start attendance tracking loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select attendance for tracking"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for tracking"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/attendance_tracking_{{attendance_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture tracking screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "attendance_counter",
      "value": "{{attendance_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment attendance counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{attendance_counter < attendance_to_track}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more attendance"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next attendance"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/education_attendance_tracking_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
