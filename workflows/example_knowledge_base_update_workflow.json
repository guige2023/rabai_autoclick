{
  "name": "Knowledge Base Update Workflow",
  "description": "Automate knowledge base updates including article review, approval, and publishing",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "articles_to_update": 35,
    "current_article": 0,
    "updated_articles": 0,
    "pending_review": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "article_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize article counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open knowledge base system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for system to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "kb_update_loop",
      "count": "{{articles_to_update}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start knowledge base update loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open article for update"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for article"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/kb_article_{{article_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture article screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Review content accuracy"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for review"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Update outdated information"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for update"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Publish updated article"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for publishing"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/kb_article_updated_{{article_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture update confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "article_counter",
      "value": "{{article_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment article counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{article_counter < articles_to_update}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more articles"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next article"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/knowledge_base_update_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
