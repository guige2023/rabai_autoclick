{
  "name": "Support Ticket Management Workflow",
  "description": "Automate support ticket processing and escalation",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "ticket_queue": "inbox",
    "tickets_to_process": 15,
    "current_ticket": 0,
    "resolved_count": 0,
    "escalated_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "ticket_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize ticket counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open support system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "ticket_loop",
      "count": "{{tickets_to_process}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start ticket loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Click on ticket"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.3,
      "comment": "Wait for ticket details"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/ticket_{{ticket_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture ticket screenshot"
    },
    {
      "id": 8,
      "type": "condition",
      "condition": "{{ticket_counter % 3 == 0}}",
      "true_next": 9,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if should escalate"
    },
    {
      "id": 9,
      "type": "click_image",
      "template": "./templates/escalate_button.png",
      "confidence": 0.80,
      "pre_delay": 0.5,
      "comment": "Click escalate button"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 15,
      "pre_delay": 0.1,
      "comment": "Skip to next"
    },
    {
      "id": 11,
      "type": "click_image",
      "template": "./templates/resolve_button.png",
      "confidence": 0.80,
      "pre_delay": 0.5,
      "comment": "Click resolve button"
    },
    {
      "id": 12,
      "type": "set_variable",
      "name": "resolved_count",
      "value": "{{resolved_count + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment resolved count"
    },
    {
      "id": 13,
      "type": "goto",
      "step_id": 15,
      "pre_delay": 0.1,
      "comment": "Skip to next"
    },
    {
      "id": 14,
      "type": "delay",
      "seconds": 0.5,
      "pre_delay": 0.2,
      "comment": "Mark as pending"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "ticket_counter",
      "value": "{{ticket_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment ticket counter"
    },
    {
      "id": 16,
      "type": "key_press",
      "key": "down",
      "pre_delay": 0.2,
      "comment": "Move to next ticket"
    },
    {
      "id": 17,
      "type": "condition",
      "condition": "{{ticket_counter < tickets_to_process}}",
      "true_next": 18,
      "false_next": 19,
      "pre_delay": 0.1,
      "comment": "Check if more tickets"
    },
    {
      "id": 18,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next ticket"
    },
    {
      "id": 19,
      "type": "screenshot",
      "save_path": "./screenshots/ticket_management_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 20,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2,
    "continue_on_error": true
  }
}
