{
  "name": "Threat Detection Verification Workflow",
  "description": "Automate threat detection system verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "detectors_to_verify": 18,
    "current_detector": 0,
    "functional_count": 0,
    "failed_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "detector_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize detector counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open threat detection management"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for management"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "detection_verify_loop",
      "count": "{{detectors_to_verify}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start detection verification loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select detector"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for verification"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/threat_detector_{{detector_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture detection screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "detector_counter",
      "value": "{{detector_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment detector counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{detector_counter < detectors_to_verify}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more detectors"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next detector"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/threat_detection_verification_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}