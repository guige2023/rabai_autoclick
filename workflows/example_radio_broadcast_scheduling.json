{
  "name": "Radio Broadcast Scheduling Workflow",
  "description": "Automate radio broadcast scheduling",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "shows_to_schedule": 52,
    "current_show": 0,
    "scheduled_shows": 0,
    "conflicts": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "show_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize show counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open broadcast scheduling system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "broadcast_scheduling_loop",
      "count": "{{shows_to_schedule}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start broadcast scheduling loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select show for scheduling"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for scheduling"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/broadcast_scheduling_{{show_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture scheduling screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "show_counter",
      "value": "{{show_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment show counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{show_counter < shows_to_schedule}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more shows"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next show"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/radio_broadcast_scheduling_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
