{
  "name": "HR Employee Onboarding Workflow",
  "description": "Automate employee onboarding including paperwork, equipment setup, and training assignment",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "employees_to_onboard": 30,
    "current_employee": 0,
    "onboarded_employees": 0,
    "pending_tasks": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "employee_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize employee counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open HR onboarding system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for system to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "onboarding_loop",
      "count": "{{employees_to_onboard}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start onboarding loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open new employee record"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for record to load"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/employee_record_{{employee_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture employee screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Process new hire paperwork"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for paperwork"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Setup equipment requisition"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for setup"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Assign training modules"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for assignment"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/onboarding_complete_{{employee_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture onboarding confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "employee_counter",
      "value": "{{employee_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment employee counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{employee_counter < employees_to_onboard}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more employees"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next employee"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/onboarding_batch_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture batch completion"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
