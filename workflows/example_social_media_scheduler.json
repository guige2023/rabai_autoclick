{
  "name": "Social Media Scheduler Workflow",
  "description": "Schedule and post content to social media platforms",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "platform": "twitter",
    "post_content": "Hello from RabAI AutoClick! #automation",
    "has_media": false,
    "media_path": "",
    "schedule_times": ["09:00", "12:00", "18:00"],
    "current_schedule_index": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "schedule_index",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize schedule index"
    },
    {
      "id": 2,
      "type": "loop",
      "loop_id": "schedule_loop",
      "count": 3,
      "loop_start": 3,
      "pre_delay": 0.3,
      "comment": "Loop through scheduled times"
    },
    {
      "id": 3,
      "type": "click",
      "x": 50,
      "y": 50,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Click address bar"
    },
    {
      "id": 4,
      "type": "key_press",
      "keys": ["ctrl", "a"],
      "pre_delay": 0.1,
      "comment": "Select all"
    },
    {
      "id": 5,
      "type": "key_press",
      "key": "delete",
      "pre_delay": 0.1,
      "comment": "Clear address bar"
    },
    {
      "id": 6,
      "type": "type_text",
      "text": "https://{{platform}}.com/compose/tweet",
      "enter_after": true,
      "pre_delay": 0.3,
      "comment": "Navigate to compose page"
    },
    {
      "id": 7,
      "type": "delay",
      "seconds": 2.5,
      "pre_delay": 0.5,
      "comment": "Wait for compose page to load"
    },
    {
      "id": 8,
      "type": "click",
      "x": 400,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Click tweet compose area"
    },
    {
      "id": 9,
      "type": "type_text",
      "text": "{{post_content}}",
      "enter_after": false,
      "pre_delay": 0.2,
      "comment": "Enter post content"
    },
    {
      "id": 10,
      "type": "condition",
      "condition": "{{has_media == true}}",
      "true_next": 11,
      "false_next": 13,
      "pre_delay": 0.1,
      "comment": "Check if media attachment needed"
    },
    {
      "id": 11,
      "type": "click_image",
      "template": "./templates/media_button.png",
      "confidence": 0.80,
      "pre_delay": 0.5,
      "comment": "Click media attachment button"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.3,
      "comment": "Wait for media dialog"
    },
    {
      "id": 13,
      "type": "click_image",
      "template": "./templates/schedule_button.png",
      "confidence": 0.80,
      "pre_delay": 0.5,
      "comment": "Click schedule button"
    },
    {
      "id": 14,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.3,
      "comment": "Wait for scheduler"
    },
    {
      "id": 15,
      "type": "click",
      "x": 300,
      "y": 250,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Click time input field"
    },
    {
      "id": 16,
      "type": "key_press",
      "keys": ["ctrl", "a"],
      "pre_delay": 0.1,
      "comment": "Select all"
    },
    {
      "id": 17,
      "type": "key_press",
      "key": "delete",
      "pre_delay": 0.1,
      "comment": "Clear time field"
    },
    {
      "id": 18,
      "type": "set_variable",
      "name": "schedule_index",
      "value": "{{schedule_index + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Move to next schedule time"
    },
    {
      "id": 19,
      "type": "screenshot",
      "save_path": "./screenshots/scheduled_post_{{schedule_index}}.png",
      "pre_delay": 0.5,
      "comment": "Capture scheduled post screenshot"
    },
    {
      "id": 20,
      "type": "click_image",
      "template": "./templates/confirm_schedule.png",
      "confidence": 0.80,
      "pre_delay": 0.5,
      "comment": "Confirm schedule"
    },
    {
      "id": 21,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for confirmation"
    },
    {
      "id": 22,
      "type": "condition",
      "condition": "{{schedule_index < 3}}",
      "true_next": 23,
      "false_next": 24,
      "pre_delay": 0.1,
      "comment": "Check if more schedules"
    },
    {
      "id": 23,
      "type": "goto",
      "step_id": 3,
      "pre_delay": 0.2,
      "comment": "Continue to next schedule"
    },
    {
      "id": 24,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay after all schedules"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
