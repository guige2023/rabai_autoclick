{
  "name": "Phishing Simulation Results Workflow",
  "description": "Automate phishing simulation results analysis",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "simulation_rounds": 12,
    "current_round": 0,
    "compromised_count": 0,
    "avoided_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "round_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize round counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open phishing simulation portal"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for portal"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "phishing_results_loop",
      "count": "{{simulation_rounds}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start results analysis loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select simulation round"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for results analysis"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/phishing_results_{{round_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture results screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "round_counter",
      "value": "{{round_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment round counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{round_counter < simulation_rounds}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more rounds"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next round"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/phishing_simulation_results_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}