{
  "name": "Solar Panel Inspection Workflow",
  "description": "Automate solar panel inspection including efficiency testing and maintenance scheduling",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "panels_to_inspect": 50,
    "current_panel": 0,
    "inspected_panels": 0,
    "maintenance_required": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "panel_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize panel counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open solar monitoring system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for system to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "inspection_loop",
      "count": "{{panels_to_inspect}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start panel inspection loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select panel for inspection"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for panel data"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/panel_{{panel_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture panel screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Review efficiency metrics"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for metrics review"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Check for anomalies"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for anomaly check"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Log inspection results"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for logging"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/panel_inspection_{{panel_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture inspection log"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "panel_counter",
      "value": "{{panel_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment panel counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{panel_counter < panels_to_inspect}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more panels"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next panel"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/solar_inspection_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
