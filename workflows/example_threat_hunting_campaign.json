{
  "name": "Threat Hunting Campaign Workflow",
  "description": "Automate threat hunting campaign execution",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "hunt_areas_to_cover": 25,
    "current_area": 0,
    "clean_count": 0,
    "threat_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "hunt_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize hunt counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open threat hunting platform"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for platform"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "threat_hunting_loop",
      "count": "{{hunt_areas_to_cover}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start threat hunting loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select hunt area"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for hunting"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/threat_hunting_{{hunt_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture hunting screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "hunt_counter",
      "value": "{{hunt_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment hunt counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{hunt_counter < hunt_areas_to_cover}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more areas"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next area"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/threat_hunting_campaign_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}