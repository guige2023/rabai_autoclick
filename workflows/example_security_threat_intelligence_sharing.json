{
  "name": "Security Threat Intelligence Sharing Workflow",
  "description": "Automate threat intelligence sharing operations",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "intel_shares_to_process": 48,
    "current_share": 0,
    "shared_intel": 0,
    "pending_shares": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "share_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize share counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open threat intelligence platform"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for platform"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "intel_sharing_loop",
      "count": "{{intel_shares_to_process}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start intel sharing loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select intelligence to share"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for share processing"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/intel_share_{{share_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture intelligence share screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "share_counter",
      "value": "{{share_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment share counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{share_counter < intel_shares_to_process}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more shares"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next share"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_threat_intelligence_sharing_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
