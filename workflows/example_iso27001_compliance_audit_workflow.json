{
  "name": "ISO 27001 Compliance Audit Workflow",
  "description": "Automate ISO 27001 compliance auditing including control assessment and gap analysis",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "controls_to_assess": 50,
    "current_control": 0,
    "assessed_controls": 0,
    "non_compliant_controls": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "control_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize control counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open GRC system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for system to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "audit_loop",
      "count": "{{controls_to_assess}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start audit loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open control assessment"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for assessment"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/control_{{control_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture control screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Review evidence"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for review"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Assess compliance status"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for assessment"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Document findings"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for documentation"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/audit_findings_{{control_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture findings"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "control_counter",
      "value": "{{control_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment control counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{control_counter < controls_to_assess}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more controls"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next control"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/iso27001_audit_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
