{
  "name": "Software Release Deployment Workflow",
  "description": "Automate software release deployment including build verification, staging, and production rollout",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "releases_to_deploy": 30,
    "current_release": 0,
    "deployed_releases": 0,
    "failed_deployments": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "release_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize release counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open CI/CD deployment system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for system to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "deployment_loop",
      "count": "{{releases_to_deploy}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start deployment loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select release for deployment"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for selection"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/release_{{release_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture release screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Verify build integrity"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for verification"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Deploy to staging environment"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.2,
      "comment": "Wait for staging deployment"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Promote to production"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for production deployment"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/release_deployed_{{release_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture deployment confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "release_counter",
      "value": "{{release_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment release counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{release_counter < releases_to_deploy}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more releases"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next release"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/deployment_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
