{
  "name": "Oil and Gas Equipment Inspection Workflow",
  "description": "Automate oil and gas equipment inspection including safety checks and compliance documentation",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "equipment_to_inspect": 35,
    "current_equipment": 0,
    "inspected_equipment": 0,
    "failed_inspections": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "equipment_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize equipment counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open equipment inspection system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for system to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "inspection_loop",
      "count": "{{equipment_to_inspect}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start equipment inspection loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open equipment record"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for record"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/equipment_{{equipment_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture equipment screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Record inspection measurements"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for recording"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Check safety compliance"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for compliance check"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Generate inspection report"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for report generation"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/inspection_report_{{equipment_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture inspection report"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "equipment_counter",
      "value": "{{equipment_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment equipment counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{equipment_counter < equipment_to_inspect}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more equipment"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next equipment"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/equipment_inspection_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
