{
  "name": "Hospitality Restaurant Table Management Workflow",
  "description": "Automate restaurant table management including reservations, seating, and turnover tracking",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "reservations_to_process": 40,
    "current_reservation": 0,
    "seated_guests": 0,
    "pending_reservations": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "reservation_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize reservation counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open restaurant POS system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for POS to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "table_management_loop",
      "count": "{{reservations_to_process}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start table management loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open reservation"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for reservation details"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/reservation_{{reservation_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture reservation screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Check table availability"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for availability"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Seat guests at table"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for seating"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open table check"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for check opening"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/table_seated_{{reservation_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture seating confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "reservation_counter",
      "value": "{{reservation_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment reservation counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{reservation_counter < reservations_to_process}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more reservations"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next reservation"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/restaurant_service_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture service completion"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
