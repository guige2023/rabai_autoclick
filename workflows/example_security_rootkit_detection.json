{
  "name": "Security Rootkit Detection Workflow",
  "description": "Automate rootkit detection and analysis",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "systems_to_scan": 56,
    "current_system": 0,
    "scanned_systems": 0,
    "infected_systems": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "system_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize system counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open rootkit detection tool"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for tool"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "rootkit_detection_loop",
      "count": "{{systems_to_scan}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start rootkit detection loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Scan system for rootkits"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for scan"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/rootkit_scan_{{system_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture rootkit screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "system_counter",
      "value": "{{system_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment system counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{system_counter < systems_to_scan}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more systems"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next system"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_rootkit_detection_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
