{
  "name": "Cloud Infrastructure Audit Workflow",
  "description": "Automate cloud infrastructure auditing",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "infrastructure_components": 40,
    "current_component": 0,
    "compliant_count": 0,
    "violation_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "component_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize component counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open cloud audit portal"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for portal"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "infrastructure_audit_loop",
      "count": "{{infrastructure_components}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start infrastructure audit loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select component"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for audit"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/cloud_audit_{{component_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture audit screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "component_counter",
      "value": "{{component_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment component counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{component_counter < infrastructure_components}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more components"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next component"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/cloud_infrastructure_audit_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}