{
  "name": "Cache Hit Rate Workflow",
  "description": "Automate cache performance monitoring",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "cache_servers": 4,
    "current_server": 0,
    "healthy_servers": 0,
    "poor_hit_rate_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "server_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize server counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open cache dashboard"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for dashboard"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "cache_hit_loop",
      "count": "{{cache_servers}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start cache monitoring loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Click server"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.3,
      "comment": "Wait for metrics"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/cache_hit_{{server_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture cache screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "server_counter",
      "value": "{{server_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment server counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{server_counter < cache_servers}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more servers"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next server"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/cache_hit_rate_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
