{
  "name": "Patch Management Audit Workflow",
  "description": "Automate software patch management verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "systems_to_patch": 42,
    "current_system": 0,
    "patched_count": 0,
    "pending_patch_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "patch_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize patch counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open patch management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "patch_audit_loop",
      "count": "{{systems_to_patch}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start patch audit loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select system"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for patch check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/patch_audit_{{patch_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture patch screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "patch_counter",
      "value": "{{patch_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment patch counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{patch_counter < systems_to_patch}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more systems"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next system"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/patch_management_audit_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}