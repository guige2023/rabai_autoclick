{
  "name": "Phishing Simulation Audit Workflow",
  "description": "Automate phishing simulation campaign results review",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "simulation_results_to_review": 60,
    "current_result": 0,
    "safe_responses": 0,
    "phished_responses": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "phishing_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize phishing counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open phishing simulation platform"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for platform"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "phishing_audit_loop",
      "count": "{{simulation_results_to_review}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start phishing audit loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select simulation result"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for result review"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/phishing_audit_{{phishing_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture phishing screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "phishing_counter",
      "value": "{{phishing_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment phishing counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{phishing_counter < simulation_results_to_review}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more results"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next result"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/phishing_simulation_audit_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}