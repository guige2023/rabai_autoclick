{
  "name": "Support Ticket Escalation Workflow",
  "description": "Automate support ticket escalation review",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "tickets_to_escalate": 48,
    "current_ticket": 0,
    "escalated_tickets": 0,
    "resolved_tickets": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "escalation_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize escalation counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open support ticket system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "escalation_loop",
      "count": "{{tickets_to_escalate}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start escalation loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select ticket for escalation"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for escalation review"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/escalation_{{escalation_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture escalation screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "escalation_counter",
      "value": "{{escalation_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment escalation counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{escalation_counter < tickets_to_escalate}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more tickets"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next ticket"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/support_ticket_escalation_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
