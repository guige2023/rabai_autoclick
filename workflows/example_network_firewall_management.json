{
  "name": "Network Firewall Management Workflow",
  "description": "Automate firewall rule management",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "firewall_rules_to_manage": 48,
    "current_rule": 0,
    "managed_rules": 0,
    "policy_violations": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "firewall_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize firewall counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open firewall management console"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for console"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "firewall_management_loop",
      "count": "{{firewall_rules_to_manage}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start firewall management loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select firewall rule"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for rule update"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/firewall_rule_{{firewall_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture firewall screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "firewall_counter",
      "value": "{{firewall_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment firewall counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{firewall_counter < firewall_rules_to_manage}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more rules"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next rule"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/network_firewall_management_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
