{
  "name": "Agriculture Harvest Planning Workflow",
  "description": "Automate harvest planning process",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "harvests_to_plan": 49,
    "current_harvest": 0,
    "planned_harvests": 0,
    "ready_for_harvest": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "harvest_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize harvest counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open harvest planning system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "harvest_planning_loop",
      "count": "{{harvests_to_plan}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start harvest planning loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select harvest for planning"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for planning"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/harvest_planning_{{harvest_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture planning screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "harvest_counter",
      "value": "{{harvest_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment harvest counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{harvest_counter < harvests_to_plan}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more harvests"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next harvest"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/agriculture_harvest_planning_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
