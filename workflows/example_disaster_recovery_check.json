{
  "name": "Disaster Recovery Test Workflow",
  "description": "Automate disaster recovery testing",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "recovery_points": 6,
    "current_point": 0,
    "successful_count": 0,
    "failed_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "point_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize point counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open DR testing console"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for console"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "dr_test_loop",
      "count": "{{recovery_points}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start DR test loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Click recovery point"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 2.5,
      "pre_delay": 0.3,
      "comment": "Wait for recovery test"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/dr_test_{{point_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture DR screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "point_counter",
      "value": "{{point_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment point counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{point_counter < recovery_points}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more points"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next point"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/disaster_recovery_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
