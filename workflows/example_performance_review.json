{
  "name": "Performance Review Workflow",
  "description": "Automate employee performance review process",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "employees_to_review": 15,
    "current_employee": 0,
    "review_period": "2024-Q1",
    "ratings": ["exceeds", "meets", "below"]
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "review_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize review counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open HR system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "review_loop",
      "count": "{{employees_to_review}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start review loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Click on employee"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.3,
      "comment": "Wait for employee details"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/review_{{review_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture review screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "review_counter",
      "value": "{{review_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment review counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{review_counter < employees_to_review}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more reviews"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next review"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/performance_review_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
