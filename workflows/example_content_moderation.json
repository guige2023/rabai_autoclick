{
  "name": "Content Moderation Workflow",
  "description": "Automate content moderation and approval process",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "content_queue": "pending",
    "items_to_review": 25,
    "current_item": 0,
    "approved_count": 0,
    "rejected_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "item_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize item counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open moderation dashboard"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for dashboard"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "moderation_loop",
      "count": "{{items_to_review}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start moderation loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Click on content item"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.3,
      "comment": "Wait for content details"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/content_{{item_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture content screenshot"
    },
    {
      "id": 8,
      "type": "condition",
      "condition": "{{item_counter % 2 == 0}}",
      "true_next": 9,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if should approve"
    },
    {
      "id": 9,
      "type": "click_image",
      "template": "./templates/approve_button.png",
      "confidence": 0.80,
      "pre_delay": 0.5,
      "comment": "Click approve button"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 16,
      "pre_delay": 0.1,
      "comment": "Skip to next"
    },
    {
      "id": 11,
      "type": "click_image",
      "template": "./templates/reject_button.png",
      "confidence": 0.80,
      "pre_delay": 0.5,
      "comment": "Click reject button"
    },
    {
      "id": 12,
      "type": "set_variable",
      "name": "rejected_count",
      "value": "{{rejected_count + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment rejected count"
    },
    {
      "id": 13,
      "type": "goto",
      "step_id": 16,
      "pre_delay": 0.1,
      "comment": "Skip to next"
    },
    {
      "id": 14,
      "type": "set_variable",
      "name": "approved_count",
      "value": "{{approved_count + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment approved count"
    },
    {
      "id": 15,
      "type": "delay",
      "seconds": 0.5,
      "pre_delay": 0.2,
      "comment": "Mark as pending"
    },
    {
      "id": 16,
      "type": "set_variable",
      "name": "item_counter",
      "value": "{{item_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment item counter"
    },
    {
      "id": 17,
      "type": "key_press",
      "key": "down",
      "pre_delay": 0.2,
      "comment": "Move to next item"
    },
    {
      "id": 18,
      "type": "condition",
      "condition": "{{item_counter < items_to_review}}",
      "true_next": 19,
      "false_next": 20,
      "pre_delay": 0.1,
      "comment": "Check if more items"
    },
    {
      "id": 19,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next item"
    },
    {
      "id": 20,
      "type": "screenshot",
      "save_path": "./screenshots/moderation_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 21,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2,
    "continue_on_error": true
  }
}
