{
  "name": "Insurance Claims Processing Workflow",
  "description": "Automate insurance claims processing",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "claims_to_process": 47,
    "current_claim": 0,
    "processed_claims": 0,
    "approved_claims": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "claim_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize claim counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open claims processing system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "claims_processing_loop",
      "count": "{{claims_to_process}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start claims processing loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select claim for processing"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for processing"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/claims_processing_{{claim_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture processing screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "claim_counter",
      "value": "{{claim_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment claim counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{claim_counter < claims_to_process}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more claims"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next claim"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/insurance_claims_processing_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
