{
  "name": "Construction Project Monitoring Workflow",
  "description": "Automate construction project monitoring including progress tracking and issue escalation",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "projects_to_monitor": 30,
    "current_project": 0,
    "monitored_projects": 0,
    "escalated_issues": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "project_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize project counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open project management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for system to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "monitoring_loop",
      "count": "{{projects_to_monitor}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start monitoring loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open project dashboard"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for dashboard"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/project_{{project_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture project screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Review milestone progress"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for review"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Check budget status"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for budget check"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Update project status"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for update"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/project_status_{{project_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture status update"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "project_counter",
      "value": "{{project_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment project counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{project_counter < projects_to_monitor}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more projects"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next project"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/construction_monitoring_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
