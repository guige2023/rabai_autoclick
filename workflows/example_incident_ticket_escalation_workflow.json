{
  "name": "Incident Ticket Escalation Workflow",
  "description": "Automate incident ticket escalation including severity assessment and routing to appropriate teams",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "incidents_to_process": 50,
    "current_incident": 0,
    "escalated_incidents": 0,
    "resolved_incidents": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "incident_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize incident counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open ITSM incident management"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for ITSM to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "escalation_loop",
      "count": "{{incidents_to_process}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start incident escalation loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open incident ticket"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for ticket"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/incident_{{incident_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture incident screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Assess incident severity"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for assessment"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Determine escalation path"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for determination"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Route to appropriate team"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for routing"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/incident_escalated_{{incident_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture escalation confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "incident_counter",
      "value": "{{incident_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment incident counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{incident_counter < incidents_to_process}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more incidents"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next incident"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/incident_escalation_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
