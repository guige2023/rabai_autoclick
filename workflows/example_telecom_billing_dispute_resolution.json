{
  "name": "Telecom Billing Dispute Resolution Workflow",
  "description": "Automate telecom billing dispute processing from customer complaint to resolution",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "disputes_to_resolve": 45,
    "current_dispute": 0,
    "resolved_disputes": 0,
    "pending_disputes": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "dispute_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize dispute counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open billing dispute system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for system to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "dispute_loop",
      "count": "{{disputes_to_resolve}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start dispute resolution loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open dispute case"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for case details"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/dispute_{{dispute_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture dispute screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Review billing records"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for review"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Calculate adjustment if applicable"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for calculation"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Process resolution"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for processing"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/dispute_resolved_{{dispute_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture resolution confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "dispute_counter",
      "value": "{{dispute_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment dispute counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{dispute_counter < disputes_to_resolve}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more disputes"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next dispute"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/dispute_resolution_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
