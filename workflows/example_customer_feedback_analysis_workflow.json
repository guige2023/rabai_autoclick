{
  "name": "Customer Feedback Analysis Workflow",
  "description": "Automate customer feedback analysis including sentiment scoring and issue categorization",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "feedback_items_to_analyze": 50,
    "current_item": 0,
    "analyzed_items": 0,
    "escalated_items": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "feedback_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize feedback counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open feedback management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for system to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "analysis_loop",
      "count": "{{feedback_items_to_analyze}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start feedback analysis loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open feedback item"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for item"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/feedback_{{feedback_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture feedback screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Perform sentiment analysis"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for analysis"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Categorize issue type"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for categorization"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Route to appropriate team"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for routing"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/feedback_analyzed_{{feedback_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture analysis confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "feedback_counter",
      "value": "{{feedback_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment feedback counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{feedback_counter < feedback_items_to_analyze}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more items"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next item"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/feedback_analysis_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
