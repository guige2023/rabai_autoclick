{
  "name": "UX Accessibility Testing Workflow",
  "description": "Automate accessibility testing",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "pages_to_test": 50,
    "current_page": 0,
    "tested_pages": 0,
    "failed_tests": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "accessibility_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize accessibility counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open accessibility testing tool"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for tool"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "accessibility_testing_loop",
      "count": "{{pages_to_test}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start accessibility testing loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select page for testing"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for test"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/accessibility_testing_{{accessibility_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture test screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "accessibility_counter",
      "value": "{{accessibility_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment accessibility counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{accessibility_counter < pages_to_test}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more pages"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next page"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/ux_accessibility_testing_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
