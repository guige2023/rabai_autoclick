{
  "name": "Supply Chain Vendor Scorecard Workflow",
  "description": "Automate supply chain vendor performance evaluation including delivery metrics and quality scores",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "vendors_to_score": 40,
    "current_vendor": 0,
    "scored_vendors": 0,
    "flagged_vendors": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "vendor_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize vendor counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open vendor management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for system to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "scoring_loop",
      "count": "{{vendors_to_score}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start vendor scoring loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open vendor profile"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for profile"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/vendor_{{vendor_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture vendor screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Review delivery performance"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for review"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Calculate quality score"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for calculation"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Update scorecard"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for update"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/scorecard_updated_{{vendor_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture update confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "vendor_counter",
      "value": "{{vendor_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment vendor counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{vendor_counter < vendors_to_score}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more vendors"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next vendor"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/vendor_scoring_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
