{
  "name": "Publishing Distribution Workflow",
  "description": "Automate publishing distribution",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "publications_to_distribute": 50,
    "current_publication": 0,
    "distributed_publications": 0,
    "pending_shipments": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "distribution_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize distribution counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open distribution system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "distribution_loop",
      "count": "{{publications_to_distribute}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start distribution loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select publication for distribution"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for distribution"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/distribution_{{distribution_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture distribution screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "distribution_counter",
      "value": "{{distribution_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment distribution counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{distribution_counter < publications_to_distribute}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more publications"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next publication"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/publishing_distribution_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
