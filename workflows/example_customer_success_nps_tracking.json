{
  "name": "Customer Success NPS Tracking Workflow",
  "description": "Automate Net Promoter Score tracking",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "nps_surveys_to_process": 50,
    "current_survey": 0,
    "processed_surveys": 0,
    "promoter_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "nps_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize NPS counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open customer success dashboard"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for dashboard"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "nps_tracking_loop",
      "count": "{{nps_surveys_to_process}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start NPS tracking loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select NPS survey response"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for NPS processing"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/nps_tracking_{{nps_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture NPS screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "nps_counter",
      "value": "{{nps_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment NPS counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{nps_counter < nps_surveys_to_process}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more surveys"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next survey"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/customer_success_nps_tracking_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
