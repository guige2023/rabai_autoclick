{
  "name": "E-commerce Inventory Restocking Workflow",
  "description": "Automate e-commerce inventory restocking based on reorder points and supplier lead times",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "products_to_restock": 55,
    "current_product": 0,
    "restocked_products": 0,
    "pending_orders": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "product_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize product counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open inventory management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for system to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "restocking_loop",
      "count": "{{products_to_restock}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start restocking loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open product inventory"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for product data"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/inventory_{{product_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture inventory screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Check stock levels"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for stock check"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Calculate reorder quantity"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for calculation"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Generate purchase order"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.2,
      "comment": "Wait for PO generation"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/purchase_order_{{product_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture PO screenshot"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "product_counter",
      "value": "{{product_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment product counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{product_counter < products_to_restock}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more products"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next product"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/restocking_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
