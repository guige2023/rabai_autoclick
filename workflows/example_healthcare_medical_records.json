{
  "name": "Healthcare Medical Records Management Workflow",
  "description": "Automate medical records management",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "records_to_manage": 48,
    "current_record": 0,
    "managed_records": 0,
    "pending_records": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "records_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize records counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open medical records system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "medical_records_loop",
      "count": "{{records_to_manage}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start medical records loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select record for management"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for management action"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/medical_records_{{records_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture records screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "records_counter",
      "value": "{{records_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment records counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{records_counter < records_to_manage}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more records"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next record"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/healthcare_medical_records_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
