{
  "name": "Security Alert Tuning Workflow",
  "description": "Automate security alert optimization",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "alerts_to_tune": 65,
    "current_alert": 0,
    "tuned_alerts": 0,
    "removed_alerts": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "tune_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize tune counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open alert management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "alert_tuning_loop",
      "count": "{{alerts_to_tune}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start alert tuning loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select alert rule"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for alert analysis"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/alert_tune_{{tune_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture tuning screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "tune_counter",
      "value": "{{tune_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment tune counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{tune_counter < alerts_to_tune}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more alerts"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next alert"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_alert_tuning_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}