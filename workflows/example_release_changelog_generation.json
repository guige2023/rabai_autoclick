{
  "name": "Release Changelog Generation Workflow",
  "description": "Automate changelog documentation",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "changes_to_document": 48,
    "current_change": 0,
    "documented_changes": 0,
    "missing_documentation": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "changelog_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize changelog counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open changelog management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "changelog_generation_loop",
      "count": "{{changes_to_document}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start changelog generation loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select change for documentation"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for documentation"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/changelog_generation_{{changelog_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture changelog screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "changelog_counter",
      "value": "{{changelog_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment changelog counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{changelog_counter < changes_to_document}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more changes"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next change"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/release_changelog_generation_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
