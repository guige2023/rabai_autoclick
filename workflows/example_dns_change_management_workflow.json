{
  "name": "DNS Change Management Workflow",
  "description": "Automate DNS change management including change requests, approval, and propagation verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "dns_changes_to_process": 35,
    "current_change": 0,
    "approved_changes": 0,
    "rejected_changes": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "dns_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize DNS counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open DNS management portal"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for portal to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "dns_change_loop",
      "count": "{{dns_changes_to_process}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start DNS change loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open DNS change request"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for request"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/dns_change_{{dns_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture DNS change screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Validate change request"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for validation"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Route for approval"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for approval"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Implement DNS change"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for implementation"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/dns_implemented_{{dns_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture implementation confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "dns_counter",
      "value": "{{dns_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment DNS counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{dns_counter < dns_changes_to_process}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more changes"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next change"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/dns_change_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
