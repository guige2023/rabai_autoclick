{
  "name": "Maintenance Scheduling Workflow",
  "description": "Automate equipment maintenance scheduling",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "equipment_list": ["HVAC", "Generator", "Elevator"],
    "current_equipment": 0,
    "maintenance_interval_days": 30
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "equipment_index",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize equipment index"
    },
    {
      "id": 2,
      "type": "loop",
      "loop_id": "equipment_loop",
      "count": 3,
      "loop_start": 3,
      "pre_delay": 0.3,
      "comment": "Start equipment loop"
    },
    {
      "id": 3,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open maintenance system"
    },
    {
      "id": 4,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 5,
      "type": "click_image",
      "template": "./templates/new_maintenance.png",
      "confidence": 0.80,
      "pre_delay": 0.5,
      "comment": "Click new maintenance"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.3,
      "comment": "Wait for form"
    },
    {
      "id": 7,
      "type": "click",
      "x": 300,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Click equipment field"
    },
    {
      "id": 8,
      "type": "type_text",
      "text": "{{equipment_list[equipment_index]}}",
      "enter_after": false,
      "pre_delay": 0.2,
      "comment": "Select equipment"
    },
    {
      "id": 9,
      "type": "screenshot",
      "save_path": "./screenshots/maintenance_{{equipment_index}}.png",
      "pre_delay": 0.5,
      "comment": "Capture maintenance screenshot"
    },
    {
      "id": 10,
      "type": "set_variable",
      "name": "equipment_index",
      "value": "{{equipment_index + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment equipment index"
    },
    {
      "id": 11,
      "type": "condition",
      "condition": "{{equipment_index < 3}}",
      "true_next": 12,
      "false_next": 13,
      "pre_delay": 0.1,
      "comment": "Check if more equipment"
    },
    {
      "id": 12,
      "type": "goto",
      "step_id": 2,
      "pre_delay": 0.1,
      "comment": "Continue to next equipment"
    },
    {
      "id": 13,
      "type": "screenshot",
      "save_path": "./screenshots/maintenance_scheduling_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 14,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
