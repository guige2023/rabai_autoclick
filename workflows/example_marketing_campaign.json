{
  "name": "Marketing Campaign Automation Workflow",
  "description": "Automate marketing campaign creation and scheduling",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "campaign_name": "Spring Sale 2024",
    "target_audiences": ["segment_a", "segment_b", "segment_c"],
    "current_audience": 0,
    "channels": ["email", "social", "push"]
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "audience_index",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize audience index"
    },
    {
      "id": 2,
      "type": "loop",
      "loop_id": "audience_loop",
      "count": 3,
      "loop_start": 3,
      "pre_delay": 0.3,
      "comment": "Start audience loop"
    },
    {
      "id": 3,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open marketing platform"
    },
    {
      "id": 4,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for platform"
    },
    {
      "id": 5,
      "type": "click_image",
      "template": "./templates/new_campaign.png",
      "confidence": 0.80,
      "pre_delay": 0.5,
      "comment": "Click new campaign"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.3,
      "comment": "Wait for campaign editor"
    },
    {
      "id": 7,
      "type": "click",
      "x": 300,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Click campaign name field"
    },
    {
      "id": 8,
      "type": "type_text",
      "text": "{{campaign_name}} - {{target_audiences[audience_index]}}",
      "enter_after": false,
      "pre_delay": 0.2,
      "comment": "Enter campaign name"
    },
    {
      "id": 9,
      "type": "click",
      "x": 300,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Click audience selector"
    },
    {
      "id": 10,
      "type": "type_text",
      "text": "{{target_audiences[audience_index]}}",
      "enter_after": false,
      "pre_delay": 0.2,
      "comment": "Select target audience"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/campaign_{{audience_index}}.png",
      "pre_delay": 0.5,
      "comment": "Capture campaign screenshot"
    },
    {
      "id": 12,
      "type": "set_variable",
      "name": "audience_index",
      "value": "{{audience_index + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment audience index"
    },
    {
      "id": 13,
      "type": "condition",
      "condition": "{{audience_index < 3}}",
      "true_next": 14,
      "false_next": 15,
      "pre_delay": 0.1,
      "comment": "Check if more audiences"
    },
    {
      "id": 14,
      "type": "goto",
      "step_id": 2,
      "pre_delay": 0.1,
      "comment": "Continue to next audience"
    },
    {
      "id": 15,
      "type": "screenshot",
      "save_path": "./screenshots/marketing_campaign_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 16,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
