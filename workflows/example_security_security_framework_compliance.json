{
  "name": "Security Security Framework Compliance Workflow",
  "description": "Automate security framework compliance checking",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "framework_controls_to_check": 54,
    "current_control": 0,
    "compliant_controls": 0,
    "non_compliant_controls": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "control_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize control counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open compliance management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "framework_compliance_loop",
      "count": "{{framework_controls_to_check}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start framework compliance loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select framework control"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for control assessment"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/framework_control_{{control_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture control screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "control_counter",
      "value": "{{control_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment control counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{control_counter < framework_controls_to_check}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more controls"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next control"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_security_framework_compliance_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
