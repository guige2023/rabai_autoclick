{
  "name": "Energy Smart Grid Monitoring Workflow",
  "description": "Automate smart grid monitoring including demand response and outage detection",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "grid_points_to_monitor": 60,
    "current_point": 0,
    "monitored_points": 0,
    "alerts_triggered": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "monitor_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize monitor counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open grid monitoring system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for system to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "grid_monitoring_loop",
      "count": "{{grid_points_to_monitor}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start grid monitoring loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select grid monitoring point"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for data"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/grid_point_{{monitor_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture grid point screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Analyze load data"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for analysis"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Check for anomalies"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for anomaly check"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Log monitoring data"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for logging"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/monitoring_data_{{monitor_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture monitoring data"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "monitor_counter",
      "value": "{{monitor_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment monitor counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{monitor_counter < grid_points_to_monitor}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more points"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next point"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/grid_monitoring_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
