{
  "name": "Support Ticket Escalation Workflow",
  "description": "Automate support ticket triage and escalation",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "tickets_to_triage": 30,
    "current_ticket": 0,
    "escalated_count": 0,
    "resolved_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "ticket_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize ticket counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open support dashboard"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for dashboard"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "triage_loop",
      "count": "{{tickets_to_triage}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start triage loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Click ticket"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.3,
      "comment": "Wait for ticket"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/ticket_{{ticket_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture ticket screenshot"
    },
    {
      "id": 8,
      "type": "condition",
      "condition": "{{ticket_counter % 5 == 0}}",
      "true_next": 9,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check severity"
    },
    {
      "id": 9,
      "type": "click",
      "x": 300,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Escalate ticket"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 13,
      "pre_delay": 0.1,
      "comment": "Skip to next"
    },
    {
      "id": 11,
      "type": "click",
      "x": 400,
      "y": 400,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Resolve ticket"
    },
    {
      "id": 12,
      "type": "set_variable",
      "name": "resolved_count",
      "value": "{{resolved_count + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment resolved count"
    },
    {
      "id": 13,
      "type": "set_variable",
      "name": "ticket_counter",
      "value": "{{ticket_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment ticket counter"
    },
    {
      "id": 14,
      "type": "condition",
      "condition": "{{ticket_counter < tickets_to_triage}}",
      "true_next": 15,
      "false_next": 16,
      "pre_delay": 0.1,
      "comment": "Check if more tickets"
    },
    {
      "id": 15,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next ticket"
    },
    {
      "id": 16,
      "type": "screenshot",
      "save_path": "./screenshots/escalation_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 17,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
