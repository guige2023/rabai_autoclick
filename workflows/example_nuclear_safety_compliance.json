{
  "name": "Nuclear Safety Compliance Workflow",
  "description": "Automate nuclear safety compliance",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "inspections_to_complete": 50,
    "current_inspection": 0,
    "completed_inspections": 0,
    "violations_found": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "inspection_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize inspection counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open safety compliance system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "safety_compliance_loop",
      "count": "{{inspections_to_complete}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start safety compliance loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select inspection for completion"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for inspection"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/safety_inspection_{{inspection_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture inspection screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "inspection_counter",
      "value": "{{inspection_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment inspection counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{inspection_counter < inspections_to_complete}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more inspections"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next inspection"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/nuclear_safety_compliance_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
