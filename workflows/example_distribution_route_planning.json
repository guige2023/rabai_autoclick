{
  "name": "Distribution Route Planning Workflow",
  "description": "Automate distribution route planning",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "routes_to_plan": 50,
    "current_route": 0,
    "planned_routes": 0,
    "optimization_savings": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "route_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize route counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open route planning system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "route_planning_loop",
      "count": "{{routes_to_plan}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start route planning loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select route for planning"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for planning"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/route_planning_{{route_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture planning screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "route_counter",
      "value": "{{route_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment route counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{route_counter < routes_to_plan}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more routes"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next route"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/distribution_route_planning_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
