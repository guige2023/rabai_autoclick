{
  "name": "Network Access Control Workflow",
  "description": "Automate network access control verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "access_points_to_verify": 25,
    "current_point": 0,
    "authorized_count": 0,
    "unauthorized_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "access_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize access counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open NAC management"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for management"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "nac_verify_loop",
      "count": "{{access_points_to_verify}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start NAC verification loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select access point"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for verification"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/nac_verify_{{access_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture NAC screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "access_counter",
      "value": "{{access_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment access counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{access_counter < access_points_to_verify}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more access points"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next access point"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/network_access_control_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}