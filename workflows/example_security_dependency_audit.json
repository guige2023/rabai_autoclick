{
  "name": "Security Dependency Audit Workflow",
  "description": "Automate dependency security audits",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "dependencies_to_audit": 48,
    "current_dependency": 0,
    "audited_dependencies": 0,
    "vulnerable_dependencies": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "audit_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize audit counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open dependency audit tool"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for tool"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "dependency_audit_loop",
      "count": "{{dependencies_to_audit}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start dependency audit loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select dependency for audit"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for audit"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/dependency_audit_{{audit_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture audit screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "audit_counter",
      "value": "{{audit_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment audit counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{audit_counter < dependencies_to_audit}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more dependencies"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next dependency"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_dependency_audit_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
