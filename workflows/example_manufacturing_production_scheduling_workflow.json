{
  "name": "Manufacturing Production Scheduling Workflow",
  "description": "Automate manufacturing production scheduling including job sequencing and resource allocation",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "jobs_to_schedule": 45,
    "current_job": 0,
    "scheduled_jobs": 0,
    "delayed_jobs": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "job_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize job counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open MES scheduling system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for MES to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "scheduling_loop",
      "count": "{{jobs_to_schedule}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start production scheduling loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open job order"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for order"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/production_job_{{job_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture job screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Check material availability"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for availability check"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Allocate machine resources"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for allocation"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Set production schedule"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for scheduling"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/schedule_set_{{job_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture schedule confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "job_counter",
      "value": "{{job_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment job counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{job_counter < jobs_to_schedule}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more jobs"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next job"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/production_scheduling_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
