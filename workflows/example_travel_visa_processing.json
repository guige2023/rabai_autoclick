{
  "name": "Travel Visa Processing Workflow",
  "description": "Automate travel visa processing",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "visa_applications": 48,
    "current_application": 0,
    "processed_applications": 0,
    "pending_approvals": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "visa_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize visa counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open visa processing system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "visa_processing_loop",
      "count": "{{visa_applications}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start visa processing loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select application for processing"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for processing"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/visa_processing_{{visa_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture processing screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "visa_counter",
      "value": "{{visa_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment visa counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{visa_counter < visa_applications}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more applications"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next application"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/travel_visa_processing_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
