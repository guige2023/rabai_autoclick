{
  "name": "Research Literature Review Workflow",
  "description": "Automate literature review process",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "papers_to_review": 48,
    "current_paper": 0,
    "reviewed_papers": 0,
    "relevant_papers": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "literature_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize literature counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open academic database"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for database"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "literature_review_loop",
      "count": "{{papers_to_review}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start literature review loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select paper for review"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for paper review"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/literature_review_{{literature_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture literature screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "literature_counter",
      "value": "{{literature_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment literature counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{literature_counter < papers_to_review}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more papers"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next paper"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/research_literature_review_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
