{
  "name": "Real Estate Property Listing Management Workflow",
  "description": "Automate real estate listing management including listing creation, updates, and status changes",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "listings_to_manage": 40,
    "current_listing": 0,
    "updated_listings": 0,
    "pending_listings": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "listing_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize listing counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open MLS listing system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for MLS to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "listing_management_loop",
      "count": "{{listings_to_manage}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start listing management loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open property listing"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for listing to load"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/listing_{{listing_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture listing screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Update property details"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for update"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Sync with MLS"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for sync"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Update listing status"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for status update"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/listing_updated_{{listing_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture update confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "listing_counter",
      "value": "{{listing_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment listing counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{listing_counter < listings_to_manage}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more listings"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next listing"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/listing_management_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
