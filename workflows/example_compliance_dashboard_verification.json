{
  "name": "Compliance Dashboard Verification Workflow",
  "description": "Automate compliance dashboard status verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "dashboards_to_verify": 18,
    "current_dashboard": 0,
    "compliant_count": 0,
    "non_compliant_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "dashboard_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize dashboard counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open compliance portal"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for portal"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "dashboard_verification_loop",
      "count": "{{dashboards_to_verify}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start dashboard verification loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select dashboard"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for compliance check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/dashboard_verify_{{dashboard_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture dashboard screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "dashboard_counter",
      "value": "{{dashboard_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment dashboard counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{dashboard_counter < dashboards_to_verify}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more dashboards"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next dashboard"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/compliance_dashboard_verification_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}