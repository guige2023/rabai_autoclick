{
  "name": "Finance Accounts Payable Workflow",
  "description": "Automate accounts payable processing",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "payments_to_process": 50,
    "current_payment": 0,
    "processed_payments": 0,
    "failed_payments": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "payment_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize payment counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open accounts payable system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "accounts_payable_loop",
      "count": "{{payments_to_process}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start accounts payable loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select payment for processing"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for processing"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/accounts_payable_{{payment_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture payment screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "payment_counter",
      "value": "{{payment_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment payment counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{payment_counter < payments_to_process}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more payments"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next payment"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/finance_accounts_payable_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
