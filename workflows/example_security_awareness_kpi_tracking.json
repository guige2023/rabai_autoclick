{
  "name": "Security Awareness KPI Tracking Workflow",
  "description": "Automate security awareness program metrics",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "awareness_kpis_to_track": 55,
    "current_kpi": 0,
    "met_kpis": 0,
    "missed_kpis": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "awareness_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize awareness counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open awareness metrics portal"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for portal"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "awareness_kpi_loop",
      "count": "{{awareness_kpis_to_track}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start awareness KPI loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select awareness KPI"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for KPI check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/awareness_kpi_{{awareness_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture awareness screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "awareness_counter",
      "value": "{{awareness_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment awareness counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{awareness_counter < awareness_kpis_to_track}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more KPIs"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next KPI"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_awareness_kpi_tracking_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}