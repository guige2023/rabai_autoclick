{
  "name": "Product Feature Prioritization Workflow",
  "description": "Automate feature prioritization",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "features_to_prioritize": 49,
    "current_feature": 0,
    "prioritized_features": 0,
    "failed_prioritization": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "priority_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize priority counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open prioritization tool"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for tool"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "feature_prioritization_loop",
      "count": "{{features_to_prioritize}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start feature prioritization loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select feature for prioritization"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for prioritization"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/feature_prioritization_{{priority_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture prioritization screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "priority_counter",
      "value": "{{priority_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment priority counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{priority_counter < features_to_prioritize}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more features"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next feature"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/product_feature_prioritization_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
