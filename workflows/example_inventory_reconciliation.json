{
  "name": "Inventory Reconciliation Workflow",
  "description": "Automate inventory count reconciliation",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "warehouse_locations": 6,
    "current_location": 0,
    "items_checked": 0,
    "discrepancies_found": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "location_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize location counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open inventory system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "inventory_loop",
      "count": "{{warehouse_locations}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start reconciliation loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Click location"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for data"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/inventory_{{location_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture inventory screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "location_counter",
      "value": "{{location_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment location counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{location_counter < warehouse_locations}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more locations"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next location"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/inventory_reconciliation_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
