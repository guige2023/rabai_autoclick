{
  "name": "Insurance Premium Calculations Workflow",
  "description": "Automate insurance premium calculations",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "calculations_to_process": 53,
    "current_calculation": 0,
    "processed_calculations": 0,
    "errors": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "calculation_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize calculation counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open premium calculation system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "premium_calculation_loop",
      "count": "{{calculations_to_process}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start premium calculation loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select calculation for processing"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for calculation"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/premium_calculation_{{calculation_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture calculation screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "calculation_counter",
      "value": "{{calculation_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment calculation counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{calculation_counter < calculations_to_process}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more calculations"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next calculation"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/insurance_premium_calculations_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
