{
  "name": "IoT Device Security Audit Workflow",
  "description": "Automate IoT device vulnerability assessment",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "iot_devices_to_audit": 55,
    "current_device": 0,
    "secure_devices": 0,
    "vulnerable_devices": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "iot_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize IoT counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open IoT security platform"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for platform"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "iot_audit_loop",
      "count": "{{iot_devices_to_audit}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start IoT audit loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select IoT device"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for vulnerability check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/iot_audit_{{iot_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture IoT screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "iot_counter",
      "value": "{{iot_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment IoT counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{iot_counter < iot_devices_to_audit}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more devices"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next device"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/iot_device_security_audit_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}