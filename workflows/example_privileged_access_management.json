{
  "name": "Privileged Access Management Workflow",
  "description": "Automate PAM policy compliance verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "privileged_accounts_to_review": 52,
    "current_account": 0,
    "compliant_accounts": 0,
    "non_compliant_accounts": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "pam_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize PAM counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open PAM management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "pam_review_loop",
      "count": "{{privileged_accounts_to_review}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start PAM review loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select privileged account"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for account check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/pam_review_{{pam_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture PAM screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "pam_counter",
      "value": "{{pam_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment PAM counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{pam_counter < privileged_accounts_to_review}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more accounts"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next account"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/privileged_access_management_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}