{
  "name": "Zero Trust Policy Audit Workflow",
  "description": "Automate zero trust security model verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "trust_policies_to_audit": 48,
    "current_policy": 0,
    "compliant_policies": 0,
    "non_compliant_policies": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "zerotrust_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize zerotrust counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open zero trust management"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for management"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "zerotrust_audit_loop",
      "count": "{{trust_policies_to_audit}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start zerotrust audit loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select trust policy"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for policy check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/zerotrust_audit_{{zerotrust_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture zerotrust screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "zerotrust_counter",
      "value": "{{zerotrust_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment zerotrust counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{zerotrust_counter < trust_policies_to_audit}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more policies"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next policy"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/zerotrust_policy_audit_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}