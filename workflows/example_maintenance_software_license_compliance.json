{
  "name": "Maintenance Software License Compliance Workflow",
  "description": "Automate software license compliance auditing",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "licenses_to_audit": 52,
    "current_license": 0,
    "compliant_licenses": 0,
    "violations_found": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "license_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize license counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open license management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "license_compliance_loop",
      "count": "{{licenses_to_audit}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start license compliance loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select license for audit"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for audit"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/license_audit_{{license_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture license screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "license_counter",
      "value": "{{license_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment license counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{license_counter < licenses_to_audit}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more licenses"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next license"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/maintenance_software_license_compliance_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
