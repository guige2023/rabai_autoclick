{
  "name": "Operations Maintenance Scheduling Workflow",
  "description": "Automate maintenance scheduling",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "maintenance_to_schedule": 52,
    "current_maintenance": 0,
    "scheduled_maintenance": 0,
    "overdue_maintenance": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "maintenance_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize maintenance counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open maintenance scheduling system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "maintenance_scheduling_loop",
      "count": "{{maintenance_to_schedule}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start maintenance scheduling loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select maintenance for scheduling"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for scheduling"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/maintenance_scheduling_{{maintenance_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture scheduling screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "maintenance_counter",
      "value": "{{maintenance_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment maintenance counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{maintenance_counter < maintenance_to_schedule}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more maintenance"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next maintenance"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/operations_maintenance_scheduling_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
