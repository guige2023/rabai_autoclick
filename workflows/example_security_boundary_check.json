{
  "name": "Security Boundary Check Workflow",
  "description": "Automate security boundary verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "boundaries_to_verify": 18,
    "current_boundary": 0,
    "secure_count": 0,
    "breached_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "boundary_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize boundary counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open security dashboard"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for dashboard"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "boundary_check_loop",
      "count": "{{boundaries_to_verify}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start boundary verification loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select security boundary"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for verification"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/security_boundary_{{boundary_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture boundary screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "boundary_counter",
      "value": "{{boundary_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment boundary counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{boundary_counter < boundaries_to_verify}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more boundaries"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next boundary"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_boundary_check_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}