{
  "name": "Sales Sales Forecasting Workflow",
  "description": "Automate sales forecasting process",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "forecast_periods_to_update": 46,
    "current_period": 0,
    "updated_forecasts": 0,
    "forecast_accuracy": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "forecast_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize forecast counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open sales forecasting system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "forecasting_loop",
      "count": "{{forecast_periods_to_update}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start forecasting loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select forecast period"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for forecast update"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/forecast_update_{{forecast_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture forecast screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "forecast_counter",
      "value": "{{forecast_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment forecast counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{forecast_counter < forecast_periods_to_update}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more periods"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next period"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/sales_sales_forecasting_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
