{
  "name": "Security Application Whitelisting Workflow",
  "description": "Automate application whitelisting management",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "applications_to_whitelist": 52,
    "current_app": 0,
    "whitelisted_apps": 0,
    "blocked_apps": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "app_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize app counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open application whitelisting console"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for console"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "whitelisting_loop",
      "count": "{{applications_to_whitelist}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start whitelisting loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select application"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for whitelist update"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/app_whitelist_{{app_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture whitelisting screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "app_counter",
      "value": "{{app_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment app counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{app_counter < applications_to_whitelist}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more apps"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next app"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_application_whitelisting_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
