{
  "name": "Cloud Access Security Audit Workflow",
  "description": "Automate CASB policy compliance verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "cloud_apps_to_audit": 45,
    "current_app": 0,
    "compliant_apps": 0,
    "non_compliant_apps": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "casb_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize CASB counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open CASB dashboard"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for dashboard"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "casb_audit_loop",
      "count": "{{cloud_apps_to_audit}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start CASB audit loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select cloud app"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for compliance check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/casb_audit_{{casb_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture CASB screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "casb_counter",
      "value": "{{casb_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment CASB counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{casb_counter < cloud_apps_to_audit}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more apps"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next app"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/cloud_access_security_audit_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}