{
  "name": "Basic Example Workflow",
  "description": "Demonstrates basic click, type, and delay actions",
  "variables": {},
  "steps": [
    {
      "id": 1,
      "type": "delay",
      "seconds": 0.5,
      "pre_delay": 0,
      "comment": "Brief pause before starting"
    },
    {
      "id": 2,
      "type": "click",
      "x": 500,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.2,
      "comment": "Click at center of screen"
    },
    {
      "id": 3,
      "type": "type_text",
      "text": "Hello RabAI AutoClick!",
      "interval": 0.05,
      "pre_delay": 0.3,
      "comment": "Type greeting with 50ms interval"
    },
    {
      "id": 4,
      "type": "delay",
      "seconds": 0.3,
      "pre_delay": 0,
      "comment": "Wait for text to register"
    },
    {
      "id": 5,
      "type": "key_press",
      "key": "enter",
      "pre_delay": 0.2,
      "comment": "Press Enter key"
    },
    {
      "id": 6,
      "type": "screenshot",
      "save_path": "example_screenshot.png",
      "pre_delay": 0.5,
      "comment": "Capture result screenshot"
    }
  ]
}
