{
  "name": "Data Data Lineage Tracking Workflow",
  "description": "Automate data lineage documentation",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "data_flows_to_track": 46,
    "current_flow": 0,
    "tracked_flows": 0,
    "lineage_gaps": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "flow_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize flow counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open lineage tracking system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "lineage_tracking_loop",
      "count": "{{data_flows_to_track}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start lineage tracking loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select data flow"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for tracking"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/lineage_{{flow_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture lineage screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "flow_counter",
      "value": "{{flow_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment flow counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{flow_counter < data_flows_to_track}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more flows"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next flow"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/data_data_lineage_tracking_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
