{
  "name": "Security LDAP Security Audit Workflow",
  "description": "Automate LDAP directory security auditing",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "ldap_entries_to_audit": 54,
    "current_entry": 0,
    "secure_entries": 0,
    "weak_entries": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "entry_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize entry counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open LDAP management tool"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for tool"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "ldap_audit_loop",
      "count": "{{ldap_entries_to_audit}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start LDAP audit loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select LDAP entry"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for entry audit"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/ldap_entry_{{entry_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture LDAP entry screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "entry_counter",
      "value": "{{entry_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment entry counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{entry_counter < ldap_entries_to_audit}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more entries"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next entry"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_ldap_security_audit_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
