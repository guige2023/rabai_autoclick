{
  "name": "License Renewal Tracking Workflow",
  "description": "Automate license renewal tracking including expiration monitoring and renewal processing",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "licenses_to_track": 40,
    "current_license": 0,
    "renewed_licenses": 0,
    "expiring_soon": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "license_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize license counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open license management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for system to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "license_tracking_loop",
      "count": "{{licenses_to_track}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start license tracking loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open license record"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for record"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/license_{{license_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture license screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Check expiration status"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for status check"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Process renewal if needed"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for processing"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Update license record"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for update"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/license_renewed_{{license_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture renewal confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "license_counter",
      "value": "{{license_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment license counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{license_counter < licenses_to_track}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more licenses"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next license"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/license_tracking_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
