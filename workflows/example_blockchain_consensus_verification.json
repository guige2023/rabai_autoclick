{
  "name": "Blockchain Consensus Verification Workflow",
  "description": "Automate consensus verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "verifications_to_perform": 44,
    "current_verification": 0,
    "completed_verifications": 0,
    "failed_verifications": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "verify_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize verify counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open consensus verification tool"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for tool"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "consensus_verification_loop",
      "count": "{{verifications_to_perform}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start consensus verification loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select verification task"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for verification"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/consensus_verification_{{verify_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture verification screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "verify_counter",
      "value": "{{verify_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment verify counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{verify_counter < verifications_to_perform}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more verifications"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next verification"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/blockchain_consensus_verification_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
