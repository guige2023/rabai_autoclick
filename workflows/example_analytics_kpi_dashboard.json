{
  "name": "Analytics KPI Dashboard Workflow",
  "description": "Automate KPI dashboard updates",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "dashboards_to_update": 46,
    "current_dashboard": 0,
    "updated_dashboards": 0,
    "failed_updates": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "kpi_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize KPI counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open KPI dashboard system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "kpi_dashboard_loop",
      "count": "{{dashboards_to_update}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start KPI dashboard loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select dashboard for update"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for update"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/kpi_dashboard_{{kpi_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture dashboard screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "kpi_counter",
      "value": "{{kpi_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment KPI counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{kpi_counter < dashboards_to_update}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more dashboards"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next dashboard"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/analytics_kpi_dashboard_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
