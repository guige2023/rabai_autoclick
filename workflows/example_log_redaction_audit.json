{
  "name": "Log Redaction Audit Workflow",
  "description": "Automate sensitive data redaction in logs verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "log_sources_to_audit": 42,
    "current_source": 0,
    "properly_redacted": 0,
    "incomplete_redaction": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "redaction_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize redaction counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open log management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "redaction_audit_loop",
      "count": "{{log_sources_to_audit}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start redaction audit loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select log source"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for redaction check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/redaction_audit_{{redaction_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture redaction screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "redaction_counter",
      "value": "{{redaction_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment redaction counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{redaction_counter < log_sources_to_audit}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more sources"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next source"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/log_redaction_audit_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}