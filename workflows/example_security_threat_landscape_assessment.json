{
  "name": "Security Threat Landscape Assessment Workflow",
  "description": "Automate threat landscape assessment",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "threat_areas_to_assess": 52,
    "current_area": 0,
    "assessed_areas": 0,
    "high_risk_areas": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "area_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize area counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open threat intelligence platform"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for platform"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "threat_landscape_loop",
      "count": "{{threat_areas_to_assess}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start threat landscape loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select threat area"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for assessment"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/threat_landscape_{{area_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture threat landscape screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "area_counter",
      "value": "{{area_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment area counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{area_counter < threat_areas_to_assess}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more areas"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next area"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_threat_landscape_assessment_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
