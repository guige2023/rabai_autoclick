{
  "name": "Database Query Optimization Workflow",
  "description": "Automate database query performance optimization",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "queries_to_optimize": 50,
    "current_query": 0,
    "optimized_queries": 0,
    "slow_queries": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "query_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize query counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open database performance dashboard"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for dashboard"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "query_optimization_loop",
      "count": "{{queries_to_optimize}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start query optimization loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select query for optimization"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for analysis"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/query_optimization_{{query_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture optimization screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "query_counter",
      "value": "{{query_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment query counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{query_counter < queries_to_optimize}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more queries"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next query"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/database_query_optimization_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
