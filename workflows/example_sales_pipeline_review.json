{
  "name": "Sales Pipeline Review Workflow",
  "description": "Automate sales pipeline review process",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "pipeline_stages_to_review": 48,
    "current_stage": 0,
    "reviewed_stages": 0,
    "pipeline_value": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "pipeline_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize pipeline counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open sales pipeline view"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for pipeline view"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "pipeline_review_loop",
      "count": "{{pipeline_stages_to_review}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start pipeline review loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select pipeline stage for review"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for stage review"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/pipeline_review_{{pipeline_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture pipeline screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "pipeline_counter",
      "value": "{{pipeline_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment pipeline counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{pipeline_counter < pipeline_stages_to_review}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more stages"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next stage"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/sales_pipeline_review_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
