{
  "name": "Customer Success Health Score Tracking Workflow",
  "description": "Automate customer health score monitoring",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "customers_to_score": 52,
    "current_customer": 0,
    "scored_customers": 0,
    "unhealthy_customers": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "health_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize health score counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open customer health dashboard"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for dashboard"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "health_score_loop",
      "count": "{{customers_to_score}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start health score tracking loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select customer for health score"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for health score calculation"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/health_score_{{health_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture health score screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "health_counter",
      "value": "{{health_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment health counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{health_counter < customers_to_score}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more customers"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next customer"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/customer_success_health_score_tracking_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
