{
  "name": "Travel Expense Tracking Workflow",
  "description": "Automate travel expense tracking",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "expenses_to_track": 50,
    "current_expense": 0,
    "tracked_expenses": 0,
    "pending_reimbursements": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "expense_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize expense counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open expense tracking system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "expense_tracking_loop",
      "count": "{{expenses_to_track}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start expense tracking loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select expense for tracking"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for tracking"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/expense_tracking_{{expense_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture tracking screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "expense_counter",
      "value": "{{expense_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment expense counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{expense_counter < expenses_to_track}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more expenses"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next expense"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/travel_expense_tracking_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
