{
  "name": "Security Threat Landscape Mapping Workflow",
  "description": "Automate threat landscape mapping",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "threat_actors_to_map": 52,
    "current_actor": 0,
    "mapped_actors": 0,
    "high_risk_actors": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "actor_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize actor counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open threat landscape platform"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for platform"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "threat_mapping_loop",
      "count": "{{threat_actors_to_map}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start threat mapping loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select threat actor"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for mapping"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/threat_actor_{{actor_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture threat actor screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "actor_counter",
      "value": "{{actor_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment actor counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{actor_counter < threat_actors_to_map}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more actors"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next actor"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_threat_landscape_mapping_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
