{
  "name": "Product Sprint Planning Workflow",
  "description": "Automate sprint planning process",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "sprints_to_plan": 43,
    "current_sprint": 0,
    "planned_sprints": 0,
    "failed_planning": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "sprint_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize sprint counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open sprint planning tool"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for tool"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "sprint_planning_loop",
      "count": "{{sprints_to_plan}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start sprint planning loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select sprint for planning"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for planning"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/sprint_planning_{{sprint_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture planning screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "sprint_counter",
      "value": "{{sprint_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment sprint counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{sprint_counter < sprints_to_plan}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more sprints"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next sprint"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/product_sprint_planning_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
