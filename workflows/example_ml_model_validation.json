{
  "name": "ML Model Validation Workflow",
  "description": "Automate ML model validation",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "models_to_validate": 46,
    "current_model": 0,
    "validated_models": 0,
    "failed_validations": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "validation_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize validation counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open model validation system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "model_validation_loop",
      "count": "{{models_to_validate}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start model validation loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select model for validation"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for validation"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/model_validation_{{validation_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture validation screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "validation_counter",
      "value": "{{validation_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment validation counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{validation_counter < models_to_validate}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more models"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next model"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/ml_model_validation_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
