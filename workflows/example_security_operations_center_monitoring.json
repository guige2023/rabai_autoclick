{
  "name": "Security Operations Center Monitoring Workflow",
  "description": "Automate SOC monitoring dashboard verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "monitoring_points_to_check": 32,
    "current_point": 0,
    "active_count": 0,
    "inactive_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "monitor_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize monitor counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open SOC monitoring"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for monitoring"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "soc_monitoring_loop",
      "count": "{{monitoring_points_to_check}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start SOC monitoring loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select monitoring point"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for status check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/soc_monitoring_{{monitor_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture monitoring screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "monitor_counter",
      "value": "{{monitor_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment monitor counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{monitor_counter < monitoring_points_to_check}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more points"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next point"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_operations_center_monitoring_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}