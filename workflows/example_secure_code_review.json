{
  "name": "Secure Code Review Workflow",
  "description": "Automate secure coding practice verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "code_repositories_to_review": 48,
    "current_repo": 0,
    "secure_repos": 0,
    "insecure_repos": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "code_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize code counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open code review platform"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for platform"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "code_review_loop",
      "count": "{{code_repositories_to_review}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start code review loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select repository"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for security review"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/code_review_{{code_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture code screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "code_counter",
      "value": "{{code_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment code counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{code_counter < code_repositories_to_review}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more repos"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next repo"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/secure_code_review_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}