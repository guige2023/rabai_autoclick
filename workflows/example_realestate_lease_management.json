{
  "name": "Real Estate Lease Management Workflow",
  "description": "Automate real estate lease tracking and management",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "leases_to_manage": 81,
    "current_lease": 0,
    "managed_leases": 0,
    "expiring_leases": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "lease_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize lease counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open lease management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "lease_management_loop",
      "count": "{{leases_to_manage}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start lease management loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select lease for management"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for lease update"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/lease_management_{{lease_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture lease screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "lease_counter",
      "value": "{{lease_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment lease counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{lease_counter < leases_to_manage}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more leases"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next lease"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/realestate_lease_management_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
