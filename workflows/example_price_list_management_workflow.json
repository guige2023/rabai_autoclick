{
  "name": "Price List Management Workflow",
  "description": "Automate price list management including pricing updates, approval routing, and distribution",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "price_updates_to_process": 40,
    "current_update": 0,
    "updated_prices": 0,
    "pending_approvals": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "price_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize price counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open pricing management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for system to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "pricing_loop",
      "count": "{{price_updates_to_process}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start price update loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open price update record"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for record"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/price_update_{{price_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture price update screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Verify margin impact"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for verification"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Route for approval"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for routing"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Publish approved prices"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for publishing"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/price_published_{{price_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture publishing confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "price_counter",
      "value": "{{price_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment price counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{price_counter < price_updates_to_process}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more updates"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next update"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/price_management_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
