{
  "name": "Support Satisfaction Survey Workflow",
  "description": "Automate customer satisfaction survey distribution",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "surveys_to_send": 46,
    "current_survey": 0,
    "sent_surveys": 0,
    "response_rate": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "survey_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize survey counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open survey management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "survey_distribution_loop",
      "count": "{{surveys_to_send}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start survey distribution loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select customer for survey"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for distribution"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/survey_distribution_{{survey_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture survey screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "survey_counter",
      "value": "{{survey_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment survey counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{survey_counter < surveys_to_send}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more surveys"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next survey"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/support_satisfaction_survey_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
