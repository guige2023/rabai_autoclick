{
  "name": "Product Feature Backlog Management Workflow",
  "description": "Automate feature backlog management",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "features_to_manage": 47,
    "current_feature": 0,
    "managed_features": 0,
    "failed_management": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "feature_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize feature counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open backlog management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "feature_backlog_loop",
      "count": "{{features_to_manage}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start feature backlog loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select feature for management"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for management action"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/feature_backlog_{{feature_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture backlog screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "feature_counter",
      "value": "{{feature_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment feature counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{feature_counter < features_to_manage}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more features"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next feature"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/product_feature_backlog_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
