{
  "name": "Cloud Resource Optimization Workflow",
  "description": "Automate cloud resource optimization including rightsizing recommendations and cost analysis",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "resources_to_analyze": 50,
    "current_resource": 0,
    "optimized_resources": 0,
    "cost_savings": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "resource_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize resource counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open cloud cost management"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for portal to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "optimization_loop",
      "count": "{{resources_to_analyze}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start optimization loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select resource for analysis"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for selection"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/cloud_resource_{{resource_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture resource screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Analyze utilization patterns"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for analysis"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Generate rightsizing recommendation"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for recommendation"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Apply optimization"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for application"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/resource_optimized_{{resource_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture optimization confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "resource_counter",
      "value": "{{resource_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment resource counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{resource_counter < resources_to_analyze}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more resources"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next resource"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/cloud_optimization_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
