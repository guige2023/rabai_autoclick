{
  "name": "Security Email DLP Policy Management Workflow",
  "description": "Automate email DLP policy management",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "dlp_policies_to_manage": 54,
    "current_policy": 0,
    "active_policies": 0,
    "violations_detected": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "policy_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize policy counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open email DLP console"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for console"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "email_dlp_loop",
      "count": "{{dlp_policies_to_manage}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start email DLP loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select DLP policy"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for policy update"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/email_dlp_{{policy_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture DLP screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "policy_counter",
      "value": "{{policy_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment policy counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{policy_counter < dlp_policies_to_manage}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more policies"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next policy"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_email_dlp_policy_management_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
