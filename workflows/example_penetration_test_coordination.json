{
  "name": "Penetration Test Coordination Workflow",
  "description": "Automate penetration test scheduling and tracking",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "pentest_targets_to_schedule": 42,
    "current_target": 0,
    "scheduled_targets": 0,
    "completed_targets": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "pentest_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize pentest counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open pentest management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "pentest_coordination_loop",
      "count": "{{pentest_targets_to_schedule}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start pentest coordination loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select pentest target"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for scheduling"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/pentest_coord_{{pentest_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture pentest screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "pentest_counter",
      "value": "{{pentest_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment pentest counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{pentest_counter < pentest_targets_to_schedule}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more targets"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next target"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/penetration_test_coordination_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}