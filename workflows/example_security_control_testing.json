{
  "name": "Security Control Testing Workflow",
  "description": "Automate security control effectiveness testing",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "controls_to_test": 40,
    "current_control": 0,
    "effective_count": 0,
    "ineffective_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "control_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize control counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open security testing platform"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for platform"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "control_testing_loop",
      "count": "{{controls_to_test}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start control testing loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select security control"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for control test"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/control_testing_{{control_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture test screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "control_counter",
      "value": "{{control_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment control counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{control_counter < controls_to_test}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more controls"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next control"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_control_testing_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}