{
  "name": "Research Analysis Pipeline Workflow",
  "description": "Automate research data analysis pipeline",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "analyses_to_run": 46,
    "current_analysis": 0,
    "completed_analyses": 0,
    "failed_analyses": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "analysis_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize analysis counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open analysis pipeline system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "analysis_pipeline_loop",
      "count": "{{analyses_to_run}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start analysis pipeline loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select analysis for pipeline"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for analysis completion"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/analysis_pipeline_{{analysis_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture analysis screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "analysis_counter",
      "value": "{{analysis_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment analysis counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{analysis_counter < analyses_to_run}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more analyses"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next analysis"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/research_analysis_pipeline_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
