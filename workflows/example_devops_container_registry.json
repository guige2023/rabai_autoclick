{
  "name": "DevOps Container Registry Management Workflow",
  "description": "Automate container registry management",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "containers_to_manage": 53,
    "current_container": 0,
    "managed_containers": 0,
    "failed_operations": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "registry_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize registry counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open container registry management"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for management console"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "container_registry_loop",
      "count": "{{containers_to_manage}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start container registry loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select container for management"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for operation"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/container_registry_{{registry_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture registry screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "registry_counter",
      "value": "{{registry_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment registry counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{registry_counter < containers_to_manage}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more containers"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next container"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/devops_container_registry_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
