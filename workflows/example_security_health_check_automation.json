{
  "name": "Security Health Check Automation Workflow",
  "description": "Automate security health monitoring verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "health_checks_to_perform": 70,
    "current_check": 0,
    "healthy_systems": 0,
    "unhealthy_systems": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "health_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize health counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open security health dashboard"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for dashboard"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "health_check_loop",
      "count": "{{health_checks_to_perform}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start health check loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select health check"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for health verification"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/health_check_{{health_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture health screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "health_counter",
      "value": "{{health_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment health counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{health_counter < health_checks_to_perform}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more checks"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next check"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_health_check_automation_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}