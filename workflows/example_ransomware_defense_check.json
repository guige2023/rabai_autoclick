{
  "name": "Ransomware Defense Check Workflow",
  "description": "Automate ransomware defense verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "systems_to_check": 30,
    "current_system": 0,
    "defended_count": 0,
    "vulnerable_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "system_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize system counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open ransomware defense"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for defense"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "ransomware_check_loop",
      "count": "{{systems_to_check}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start ransomware check loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select system"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for defense check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/ransomware_defense_{{system_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture defense screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "system_counter",
      "value": "{{system_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment system counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{system_counter < systems_to_check}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more systems"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next system"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/ransomware_defense_check_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}