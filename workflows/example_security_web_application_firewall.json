{
  "name": "Security Web Application Firewall Workflow",
  "description": "Automate WAF rule management and monitoring",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "waf_rules_to_manage": 54,
    "current_rule": 0,
    "active_rules": 0,
    "blocked_requests": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "rule_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize rule counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open WAF management console"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for console"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "waf_management_loop",
      "count": "{{waf_rules_to_manage}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start WAF rule management loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select WAF rule"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for rule analysis"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/waf_rule_{{rule_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture WAF screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "rule_counter",
      "value": "{{rule_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment rule counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{rule_counter < waf_rules_to_manage}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more rules"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next rule"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_web_application_firewall_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
