{
  "name": "Configuration Baseline Verification Workflow",
  "description": "Automate security configuration baseline checks",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "config_items_to_verify": 75,
    "current_item": 0,
    "compliant_items": 0,
    "non_compliant_items": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "baseline_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize baseline counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open configuration management"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for management"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "baseline_verification_loop",
      "count": "{{config_items_to_verify}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start baseline verification loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select configuration item"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for baseline check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/baseline_verify_{{baseline_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture baseline screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "baseline_counter",
      "value": "{{baseline_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment baseline counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{baseline_counter < config_items_to_verify}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more items"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next item"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/configuration_baseline_verification_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}