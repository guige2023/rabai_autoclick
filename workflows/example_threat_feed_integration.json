{
  "name": "Threat Feed Integration Workflow",
  "description": "Automate threat intelligence feed integration",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "threat_feeds_to_integrate": 45,
    "current_feed": 0,
    "integrated_feeds": 0,
    "failed_integrations": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "feed_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize feed counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open threat feed platform"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for platform"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "feed_integration_loop",
      "count": "{{threat_feeds_to_integrate}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start feed integration loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select threat feed"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for feed integration"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/feed_integration_{{feed_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture feed screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "feed_counter",
      "value": "{{feed_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment feed counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{feed_counter < threat_feeds_to_integrate}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more feeds"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next feed"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/threat_feed_integration_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}