{
  "name": "Identity Verification Audit Workflow",
  "description": "Automate identity verification process audit",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "identities_to_verify": 32,
    "current_identity": 0,
    "verified_count": 0,
    "failed_verification": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "identity_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize identity counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open identity management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "identity_verification_loop",
      "count": "{{identities_to_verify}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start identity verification loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select identity"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for verification"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/identity_verify_{{identity_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture verification screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "identity_counter",
      "value": "{{identity_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment identity counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{identity_counter < identities_to_verify}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more identities"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next identity"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/identity_verification_audit_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}