{
  "name": "Broadband Service Activation Workflow",
  "description": "Automate broadband service activation",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "activations_to_process": 49,
    "current_activation": 0,
    "processed_activations": 0,
    "failed_activations": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "activation_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize activation counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open service activation system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "service_activation_loop",
      "count": "{{activations_to_process}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start service activation loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select activation for processing"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for activation"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/service_activation_{{activation_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture activation screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "activation_counter",
      "value": "{{activation_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment activation counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{activation_counter < activations_to_process}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more activations"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next activation"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/broadband_service_activation_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
