{
  "name": "Bug Bug Regression Tracking Workflow",
  "description": "Automate regression bug monitoring",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "regressions_to_track": 52,
    "current_regression": 0,
    "tracked_regressions": 0,
    "reopened_bugs": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "regression_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize regression counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open regression tracking system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "regression_tracking_loop",
      "count": "{{regressions_to_track}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start regression tracking loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select regression bug"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for tracking update"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/regression_tracking_{{regression_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture regression screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "regression_counter",
      "value": "{{regression_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment regression counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{regression_counter < regressions_to_track}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more regressions"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next regression"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/bug_regression_tracking_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
