{
  "name": "Fitness Class Scheduling Workflow",
  "description": "Automate fitness class scheduling including instructor assignment and room allocation",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "classes_to_schedule": 50,
    "current_class": 0,
    "scheduled_classes": 0,
    "conflicts_detected": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "class_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize class counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open fitness club management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for system to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "scheduling_loop",
      "count": "{{classes_to_schedule}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start class scheduling loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open class scheduling module"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for module"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/class_{{class_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture class screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Check instructor availability"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for availability check"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Allocate room"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for allocation"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Confirm class schedule"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for confirmation"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/class_scheduled_{{class_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture scheduling confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "class_counter",
      "value": "{{class_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment class counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{class_counter < classes_to_schedule}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more classes"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next class"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/fitness_scheduling_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
