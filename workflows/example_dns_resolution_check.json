{
  "name": "DNS Resolution Check Workflow",
  "description": "Automate DNS resolution monitoring",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "domains_to_check": 30,
    "current_domain": 0,
    "resolved_count": 0,
    "failed_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "domain_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize domain counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open DNS monitoring"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for monitoring"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "dns_check_loop",
      "count": "{{domains_to_check}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start DNS check loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select domain"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for DNS resolution"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/dns_check_{{domain_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture DNS screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "domain_counter",
      "value": "{{domain_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment domain counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{domain_counter < domains_to_check}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more domains"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next domain"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/dns_resolution_check_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}