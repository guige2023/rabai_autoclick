{
  "name": "Energy Renewable Integration Workflow",
  "description": "Automate renewable energy integration",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "sources_to_integrate": 47,
    "current_source": 0,
    "integrated_sources": 0,
    "pending_integration": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "renewable_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize renewable counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open renewable integration system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "renewable_integration_loop",
      "count": "{{sources_to_integrate}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start renewable integration loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select source for integration"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for integration"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/renewable_integration_{{renewable_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture integration screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "renewable_counter",
      "value": "{{renewable_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment renewable counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{renewable_counter < sources_to_integrate}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more sources"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next source"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/energy_renewable_integration_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
