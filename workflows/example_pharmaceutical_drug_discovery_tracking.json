{
  "name": "Pharmaceutical Drug Discovery Tracking Workflow",
  "description": "Automate pharmaceutical drug discovery tracking from compound screening to trial phases",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "compounds_to_track": 35,
    "current_compound": 0,
    "tracked_compounds": 0,
    "flagged_compounds": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "compound_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize compound counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open drug discovery system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for system to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "discovery_loop",
      "count": "{{compounds_to_track}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start discovery tracking loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open compound record"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for record"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/compound_{{compound_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture compound screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Review screening results"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for review"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Update trial phase status"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for update"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Log research data"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for logging"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/discovery_update_{{compound_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture update confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "compound_counter",
      "value": "{{compound_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment compound counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{compound_counter < compounds_to_track}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more compounds"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next compound"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/drug_discovery_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
