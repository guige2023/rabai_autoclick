{
  "name": "Event Planning Venue Coordination Workflow",
  "description": "Automate event planning venue coordination including booking, setup, and vendor coordination",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "events_to_coordinate": 35,
    "current_event": 0,
    "coordinated_events": 0,
    "pending_bookings": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "event_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize event counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open event management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for system to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "venue_loop",
      "count": "{{events_to_coordinate}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start venue coordination loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open event details"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for details"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/event_{{event_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture event screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Verify venue availability"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for verification"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Coordinate vendor requirements"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for coordination"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Confirm booking"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for confirmation"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/event_coordinated_{{event_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture coordination confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "event_counter",
      "value": "{{event_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment event counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{event_counter < events_to_coordinate}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more events"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next event"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/venue_coordination_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
