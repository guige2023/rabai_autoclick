{
  "name": "Utilities Meter Reading Workflow",
  "description": "Automate utilities meter reading including consumption tracking and billing integration",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "meters_to_read": 60,
    "current_meter": 0,
    "read_meters": 0,
    "estimated_reads": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "meter_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize meter counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open meter management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for system to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "meter_reading_loop",
      "count": "{{meters_to_read}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start meter reading loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select meter for reading"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for meter data"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/meter_{{meter_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture meter screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Record current reading"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for recording"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Calculate consumption"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for calculation"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Submit reading to billing"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for submission"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/meter_read_{{meter_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture reading confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "meter_counter",
      "value": "{{meter_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment meter counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{meter_counter < meters_to_read}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more meters"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next meter"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/meter_reading_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
