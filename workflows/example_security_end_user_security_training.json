{
  "name": "Security End User Security Training Workflow",
  "description": "Automate end user security training assignments",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "users_to_train": 58,
    "current_user": 0,
    "trained_users": 0,
    "pending_users": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "user_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize user counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open training portal"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for portal"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "user_training_loop",
      "count": "{{users_to_train}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start user training loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Assign training to user"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for assignment"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/user_training_{{user_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture training screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "user_counter",
      "value": "{{user_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment user counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{user_counter < users_to_train}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more users"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next user"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_end_user_security_training_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
