{
  "name": "Cloud Access Security Check Workflow",
  "description": "Automate cloud access security broker verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "cloud_apps_to_check": 30,
    "current_app": 0,
    "secured_count": 0,
    "unsecured_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "app_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize app counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open CASB dashboard"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for dashboard"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "casb_check_loop",
      "count": "{{cloud_apps_to_check}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start CASB check loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select cloud app"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for security check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/casb_check_{{app_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture security screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "app_counter",
      "value": "{{app_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment app counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{app_counter < cloud_apps_to_check}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more apps"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next app"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/cloud_access_security_check_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}