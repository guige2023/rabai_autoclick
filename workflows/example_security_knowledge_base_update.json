{
  "name": "Security Knowledge Base Update Workflow",
  "description": "Automate security knowledge base maintenance",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "kb_articles_to_update": 52,
    "current_article": 0,
    "updated_articles": 0,
    "pending_updates": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "kb_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize KB counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open knowledge base system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "kb_update_loop",
      "count": "{{kb_articles_to_update}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start KB update loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select KB article"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for article update"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/kb_update_{{kb_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture KB screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "kb_counter",
      "value": "{{kb_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment KB counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{kb_counter < kb_articles_to_update}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more articles"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next article"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_knowledge_base_update_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}