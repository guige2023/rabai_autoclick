{
  "name": "Maintenance Warranty Tracking Workflow",
  "description": "Automate warranty expiration tracking",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "warranties_to_track": 46,
    "current_warranty": 0,
    "tracked_warranties": 0,
    "expiring_warranties": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "warranty_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize warranty counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open warranty tracking system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "warranty_tracking_loop",
      "count": "{{warranties_to_track}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start warranty tracking loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select warranty for tracking"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for tracking check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/warranty_tracking_{{warranty_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture warranty screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "warranty_counter",
      "value": "{{warranty_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment warranty counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{warranty_counter < warranties_to_track}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more warranties"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next warranty"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/maintenance_warranty_tracking_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
