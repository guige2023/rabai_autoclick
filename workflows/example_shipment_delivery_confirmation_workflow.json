{
  "name": "Shipment Delivery Confirmation Workflow",
  "description": "Automate shipment delivery confirmation including proof of delivery capture and customer notification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "deliveries_to_confirm": 50,
    "current_delivery": 0,
    "confirmed_deliveries": 0,
    "failed_deliveries": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "delivery_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize delivery counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open delivery tracking system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for system to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "confirmation_loop",
      "count": "{{deliveries_to_confirm}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start delivery confirmation loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open delivery record"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for record"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/delivery_{{delivery_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture delivery screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Verify delivery status"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for verification"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Capture proof of delivery"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for capture"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Notify customer"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for notification"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/delivery_confirmed_{{delivery_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "delivery_counter",
      "value": "{{delivery_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment delivery counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{delivery_counter < deliveries_to_confirm}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more deliveries"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next delivery"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/delivery_confirmation_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
