{
  "name": "Application Dependency Check Workflow",
  "description": "Automate application dependency vulnerability checking",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "applications_to_check": 30,
    "current_app": 0,
    "up_to_date_count": 0,
    "vulnerable_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "app_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize app counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open dependency management"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for management"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "dependency_check_loop",
      "count": "{{applications_to_check}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start dependency check loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select application"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for dependency check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/dependency_check_{{app_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture dependency screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "app_counter",
      "value": "{{app_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment app counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{app_counter < applications_to_check}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more applications"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next application"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/application_dependency_check_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}