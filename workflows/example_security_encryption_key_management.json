{
  "name": "Security Encryption Key Management Workflow",
  "description": "Automate encryption key management operations",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "encryption_keys_to_manage": 52,
    "current_key": 0,
    "managed_keys": 0,
    "expiring_keys": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "key_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize key counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open key management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "key_management_loop",
      "count": "{{encryption_keys_to_manage}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start key management loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select encryption key"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for key check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/encryption_key_{{key_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture key screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "key_counter",
      "value": "{{key_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment key counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{key_counter < encryption_keys_to_manage}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more keys"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next key"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_encryption_key_management_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
