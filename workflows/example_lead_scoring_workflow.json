{
  "name": "Lead Scoring Workflow",
  "description": "Automate lead scoring including demographic analysis, engagement tracking, and priority assignment",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "leads_to_score": 55,
    "current_lead": 0,
    "scored_leads": 0,
    "hot_leads": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "lead_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize lead counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open CRM lead management"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for CRM to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "scoring_loop",
      "count": "{{leads_to_score}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start lead scoring loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open lead profile"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for profile"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/lead_{{lead_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture lead screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Analyze demographic data"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for analysis"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Calculate engagement score"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for calculation"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Assign priority tier"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for assignment"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/lead_scored_{{lead_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture scoring confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "lead_counter",
      "value": "{{lead_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment lead counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{lead_counter < leads_to_score}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more leads"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next lead"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/lead_scoring_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
