{
  "name": "SOX Compliance Audit Workflow",
  "description": "Automate SOX control verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "sox_controls_to_verify": 52,
    "current_control": 0,
    "effective_controls": 0,
    "ineffective_controls": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "sox_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize SOX counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open SOX compliance portal"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for portal"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "sox_audit_loop",
      "count": "{{sox_controls_to_verify}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start SOX audit loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select SOX control"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for control check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/sox_audit_{{sox_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture SOX screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "sox_counter",
      "value": "{{sox_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment SOX counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{sox_counter < sox_controls_to_verify}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more controls"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next control"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/sox_compliance_audit_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}