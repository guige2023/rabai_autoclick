{
  "name": "Construction Project Tracking Workflow",
  "description": "Automate construction project tracking",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "projects_to_track": 51,
    "current_project": 0,
    "tracked_projects": 0,
    "delayed_projects": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "project_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize project counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open project tracking system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "project_tracking_loop",
      "count": "{{projects_to_track}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start project tracking loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select project for tracking"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for tracking update"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/project_tracking_{{project_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture tracking screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "project_counter",
      "value": "{{project_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment project counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{project_counter < projects_to_track}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more projects"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next project"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/construction_project_tracking_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
