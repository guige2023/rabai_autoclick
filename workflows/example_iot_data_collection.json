{
  "name": "IoT Data Collection Workflow",
  "description": "Automate IoT data collection",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "data_points_to_collect": 54,
    "current_data_point": 0,
    "collected_data_points": 0,
    "failed_collections": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "data_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize data counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open IoT data collection system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "data_collection_loop",
      "count": "{{data_points_to_collect}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start data collection loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select data point for collection"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for collection"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/data_collection_{{data_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture data screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "data_counter",
      "value": "{{data_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment data counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{data_counter < data_points_to_collect}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more data points"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next data point"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/iot_data_collection_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
