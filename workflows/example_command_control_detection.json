{
  "name": "Command Control Detection Workflow",
  "description": "Automate C2 communication detection",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "network_connections_to_check": 58,
    "current_connection": 0,
    "clean_connections": 0,
    "c2_connections": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "c2_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize C2 counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open network security platform"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for platform"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "c2_detection_loop",
      "count": "{{network_connections_to_check}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start C2 detection loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select network connection"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for C2 analysis"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/c2_detect_{{c2_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture C2 screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "c2_counter",
      "value": "{{c2_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment C2 counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{c2_counter < network_connections_to_check}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more connections"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next connection"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/command_control_detection_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}