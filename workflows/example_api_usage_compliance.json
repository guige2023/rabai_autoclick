{
  "name": "API Usage Compliance Workflow",
  "description": "Automate API usage policy compliance",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "api_consumers_to_check": 25,
    "current_consumer": 0,
    "compliant_count": 0,
    "violation_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "consumer_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize consumer counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open API management"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for management"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "api_compliance_loop",
      "count": "{{api_consumers_to_check}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start API compliance loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select API consumer"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for compliance check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/api_usage_compliance_{{consumer_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture compliance screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "consumer_counter",
      "value": "{{consumer_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment consumer counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{consumer_counter < api_consumers_to_check}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more consumers"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next consumer"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/api_usage_compliance_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}