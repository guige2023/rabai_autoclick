{
  "name": "Configuration Compliance Workflow",
  "description": "Automate system configuration compliance checking",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "configs_to_check": 20,
    "current_config": 0,
    "compliant_count": 0,
    "violation_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "config_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize config counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open compliance dashboard"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for dashboard"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "config_check_loop",
      "count": "{{configs_to_check}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start configuration check loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select configuration"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for compliance check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/config_compliance_{{config_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture compliance screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "config_counter",
      "value": "{{config_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment config counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{config_counter < configs_to_check}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more configs"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next config"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/configuration_compliance_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}