{
  "name": "Security Remote Access Audit Workflow",
  "description": "Automate remote access security auditing",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "remote_sessions_to_audit": 54,
    "current_session": 0,
    "secure_sessions": 0,
    "risky_sessions": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "session_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize session counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open remote access management"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for management console"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "remote_access_loop",
      "count": "{{remote_sessions_to_audit}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start remote access audit loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select remote session"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for session analysis"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/remote_session_{{session_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture session screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "session_counter",
      "value": "{{session_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment session counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{session_counter < remote_sessions_to_audit}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more sessions"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next session"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_remote_access_audit_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
