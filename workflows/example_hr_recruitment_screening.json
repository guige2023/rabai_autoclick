{
  "name": "HR Recruitment Screening Workflow",
  "description": "Automate candidate recruitment screening",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "candidates_to_screen": 52,
    "current_candidate": 0,
    "screened_candidates": 0,
    "qualified_candidates": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "candidate_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize candidate counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open recruitment system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "recruitment_screening_loop",
      "count": "{{candidates_to_screen}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start recruitment screening loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select candidate for screening"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for screening"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/candidate_screening_{{candidate_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture candidate screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "candidate_counter",
      "value": "{{candidate_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment candidate counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{candidate_counter < candidates_to_screen}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more candidates"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next candidate"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/hr_recruitment_screening_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
