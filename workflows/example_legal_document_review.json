{
  "name": "Legal Document Review Workflow",
  "description": "Automate document review process",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "documents_to_review": 51,
    "current_document": 0,
    "reviewed_documents": 0,
    "flagged_documents": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "review_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize review counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open document review system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "document_review_loop",
      "count": "{{documents_to_review}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start document review loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select document for review"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for review"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/document_review_{{review_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture review screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "review_counter",
      "value": "{{review_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment review counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{review_counter < documents_to_review}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more documents"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next document"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/legal_document_review_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
