{
  "name": "Security API Security Testing Workflow",
  "description": "Automate API security penetration testing",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "apis_to_test": 48,
    "current_api": 0,
    "passed_tests": 0,
    "failed_tests": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "api_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize API counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open API security testing tool"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for tool"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "api_testing_loop",
      "count": "{{apis_to_test}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start API testing loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select API endpoint"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for security test"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/api_test_{{api_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture API test screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "api_counter",
      "value": "{{api_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment API counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{api_counter < apis_to_test}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more APIs"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next API"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_api_security_testing_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
