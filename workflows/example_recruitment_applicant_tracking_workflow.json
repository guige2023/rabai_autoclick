{
  "name": "Recruitment Applicant Tracking Workflow",
  "description": "Automate recruitment applicant tracking from resume screening to interview scheduling",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "applicants_to_process": 50,
    "current_applicant": 0,
    "processed_applicants": 0,
    "interview_scheduled": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "applicant_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize applicant counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open ATS recruitment system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for ATS to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "recruitment_loop",
      "count": "{{applicants_to_process}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start applicant tracking loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open applicant profile"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for profile"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/applicant_{{applicant_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture applicant screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Screen resume"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for screening"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Rate qualifications"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for rating"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Advance to next stage"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for advancement"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/applicant_advanced_{{applicant_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture advancement confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "applicant_counter",
      "value": "{{applicant_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment applicant counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{applicant_counter < applicants_to_process}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more applicants"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next applicant"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/recruitment_batch_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture batch completion"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
