{
  "name": "Project Task Tracking Workflow",
  "description": "Automate project task tracking and updates",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "tasks_to_track": 50,
    "current_task": 0,
    "tracked_tasks": 0,
    "overdue_tasks": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "task_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize task counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open project management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "task_tracking_loop",
      "count": "{{tasks_to_track}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start task tracking loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select task for tracking"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for tracking update"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/task_tracking_{{task_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture task screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "task_counter",
      "value": "{{task_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment task counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{task_counter < tasks_to_track}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more tasks"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next task"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/project_task_tracking_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
