{
  "name": "Password Manager Workflow",
  "description": "Automate password management and credential filling",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "accounts": [
      {"site": "gmail.com", "username": "user@gmail.com"},
      {"site": "github.com", "username": "user@github.com"},
      {"site": "twitter.com", "username": "user@twitter.com"}
    ],
    "current_account": 0,
    "password": "secure_password_123"
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "account_index",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize account index"
    },
    {
      "id": 2,
      "type": "loop",
      "loop_id": "accounts_loop",
      "count": 3,
      "loop_start": 3,
      "pre_delay": 0.3,
      "comment": "Start accounts loop"
    },
    {
      "id": 3,
      "type": "click",
      "x": 50,
      "y": 50,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Click address bar"
    },
    {
      "id": 4,
      "type": "type_text",
      "text": "https://{{accounts[account_index].site}}/login",
      "enter_after": true,
      "pre_delay": 0.3,
      "comment": "Navigate to login page"
    },
    {
      "id": 5,
      "type": "delay",
      "seconds": 2.5,
      "pre_delay": 0.5,
      "comment": "Wait for page load"
    },
    {
      "id": 6,
      "type": "click",
      "x": 300,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Click username field"
    },
    {
      "id": 7,
      "type": "type_text",
      "text": "{{accounts[account_index].username}}",
      "enter_after": false,
      "pre_delay": 0.2,
      "comment": "Enter username"
    },
    {
      "id": 8,
      "type": "key_press",
      "key": "tab",
      "pre_delay": 0.2,
      "comment": "Move to password field"
    },
    {
      "id": 9,
      "type": "type_text",
      "text": "{{password}}",
      "enter_after": false,
      "pre_delay": 0.2,
      "comment": "Enter password"
    },
    {
      "id": 10,
      "type": "screenshot",
      "save_path": "./screenshots/login_{{account_index}}.png",
      "pre_delay": 0.5,
      "comment": "Capture login screenshot"
    },
    {
      "id": 11,
      "type": "set_variable",
      "name": "account_index",
      "value": "{{account_index + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment account index"
    },
    {
      "id": 12,
      "type": "condition",
      "condition": "{{account_index < 3}}",
      "true_next": 13,
      "false_next": 14,
      "pre_delay": 0.1,
      "comment": "Check if more accounts"
    },
    {
      "id": 13,
      "type": "goto",
      "step_id": 2,
      "pre_delay": 0.1,
      "comment": "Continue to next account"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/password_management_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 15,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
