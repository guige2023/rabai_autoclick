{
  "name": "Satellite Communication Management Workflow",
  "description": "Automate satellite communication management",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "links_to_manage": 49,
    "current_link": 0,
    "managed_links": 0,
    "interference_detected": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "link_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize link counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open communication management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "communication_management_loop",
      "count": "{{links_to_manage}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start communication management loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select link for management"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for management action"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/communication_link_{{link_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture management screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "link_counter",
      "value": "{{link_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment link counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{link_counter < links_to_manage}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more links"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next link"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/satellite_communication_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
