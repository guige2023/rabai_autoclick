{
  "name": "Legal Contract Review Workflow",
  "description": "Automate legal contract review process including clause extraction and risk assessment",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "contracts_to_review": 35,
    "current_contract": 0,
    "reviewed_contracts": 0,
    "flagged_contracts": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "contract_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize contract counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open contract management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for system to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "contract_review_loop",
      "count": "{{contracts_to_review}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start contract review loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open contract for review"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for contract to load"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/contract_{{contract_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture contract screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Extract key clauses"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for extraction"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Identify risk provisions"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for risk analysis"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Mark for approval"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for marking"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/contract_reviewed_{{contract_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture review confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "contract_counter",
      "value": "{{contract_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment contract counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{contract_counter < contracts_to_review}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more contracts"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next contract"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/contract_review_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
