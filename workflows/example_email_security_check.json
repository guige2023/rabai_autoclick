{
  "name": "Email Security Check Workflow",
  "description": "Automate email security verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "email_domains": 10,
    "current_domain": 0,
    "secure_count": 0,
    "insecure_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "domain_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize domain counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open email security dashboard"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for dashboard"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "email_security_loop",
      "count": "{{email_domains}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start email security loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Click domain"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.3,
      "comment": "Wait for security check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/email_security_{{domain_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture email security screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "domain_counter",
      "value": "{{domain_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment domain counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{domain_counter < email_domains}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more domains"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next domain"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/email_security_check_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
