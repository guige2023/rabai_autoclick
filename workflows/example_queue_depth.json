{
  "name": "Message Queue Depth Monitoring Workflow",
  "description": "Automate message queue depth monitoring",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "queues_to_check": 8,
    "current_queue": 0,
    "healthy_count": 0,
    "backlogged_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "queue_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize queue counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open queue monitor"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for monitor"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "queue_depth_loop",
      "count": "{{queues_to_check}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start queue depth loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Click queue"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.3,
      "comment": "Wait for depth check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/queue_depth_{{queue_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture queue screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "queue_counter",
      "value": "{{queue_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment queue counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{queue_counter < queues_to_check}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more queues"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next queue"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/queue_depth_monitoring_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
