{
  "name": "Security API Gateway Security Workflow",
  "description": "Automate API gateway security monitoring",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "api_requests_to_monitor": 58,
    "current_request": 0,
    "monitored_requests": 0,
    "blocked_requests": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "request_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize request counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open API gateway dashboard"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for dashboard"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "api_gateway_loop",
      "count": "{{api_requests_to_monitor}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start API monitoring loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select API request"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for request analysis"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/api_gateway_{{request_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture API screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "request_counter",
      "value": "{{request_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment request counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{request_counter < api_requests_to_monitor}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more requests"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next request"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_api_gateway_security_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
