{
  "name": "Legal Case Tracking Workflow",
  "description": "Automate legal case tracking",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "cases_to_track": 74,
    "current_case": 0,
    "tracked_cases": 0,
    "case_updates": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "case_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize case counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open case tracking system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "case_tracking_loop",
      "count": "{{cases_to_track}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start case tracking loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select case for tracking"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for case update"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/case_tracking_{{case_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture case screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "case_counter",
      "value": "{{case_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment case counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{case_counter < cases_to_track}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more cases"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next case"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/legal_case_tracking_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
