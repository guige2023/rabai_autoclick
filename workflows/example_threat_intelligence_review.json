{
  "name": "Threat Intelligence Review Workflow",
  "description": "Automate threat intelligence feed review",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "threat_indicators_to_review": 28,
    "current_indicator": 0,
    "reviewed_count": 0,
    "actionable_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "indicator_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize indicator counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open threat intelligence portal"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for portal"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "threat_intel_review_loop",
      "count": "{{threat_indicators_to_review}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start threat review loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select threat indicator"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for review"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/threat_intel_review_{{indicator_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture review screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "indicator_counter",
      "value": "{{indicator_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment indicator counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{indicator_counter < threat_indicators_to_review}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more indicators"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next indicator"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/threat_intelligence_review_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}