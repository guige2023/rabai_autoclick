{
  "name": "Operations Change Management Workflow",
  "description": "Automate IT change management process",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "change_requests_to_process": 50,
    "current_change": 0,
    "processed_changes": 0,
    "rejected_changes": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "change_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize change counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open change management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "change_management_loop",
      "count": "{{change_requests_to_process}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start change management loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select change request"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for review"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/change_request_{{change_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture change screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "change_counter",
      "value": "{{change_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment change counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{change_counter < change_requests_to_process}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more changes"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next change"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/operations_change_management_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
