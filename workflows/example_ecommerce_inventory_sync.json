{
  "name": "Ecommerce Inventory Sync Workflow",
  "description": "Automate inventory synchronization across channels",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "listings_to_sync": 48,
    "current_listing": 0,
    "synced_listings": 0,
    "sync_errors": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "sync_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize sync counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open inventory sync dashboard"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for dashboard"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "inventory_sync_loop",
      "count": "{{listings_to_sync}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start inventory sync loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select listing for sync"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for sync"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/inventory_sync_{{sync_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture sync screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "sync_counter",
      "value": "{{sync_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment sync counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{sync_counter < listings_to_sync}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more listings"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next listing"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/ecommerce_inventory_sync_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
