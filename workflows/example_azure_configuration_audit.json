{
  "name": "Azure Configuration Audit Workflow",
  "description": "Automate Azure cloud security configuration review",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "azure_resources_to_audit": 58,
    "current_resource": 0,
    "secure_resources": 0,
    "misconfigured_resources": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "azure_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize azure counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open Azure security center"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for center"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "azure_audit_loop",
      "count": "{{azure_resources_to_audit}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start Azure audit loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select Azure resource"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for configuration check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/azure_audit_{{azure_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture azure screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "azure_counter",
      "value": "{{azure_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment azure counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{azure_counter < azure_resources_to_audit}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more resources"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next resource"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/azure_configuration_audit_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}