{
  "name": "Satellite Data Download Workflow",
  "description": "Automate satellite data download",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "downloads_to_process": 51,
    "current_download": 0,
    "processed_downloads": 0,
    "failed_downloads": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "download_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize download counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open data download system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "data_download_loop",
      "count": "{{downloads_to_process}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start data download loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select download for processing"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for download"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/data_download_{{download_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture download screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "download_counter",
      "value": "{{download_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment download counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{download_counter < downloads_to_process}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more downloads"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next download"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/satellite_data_download_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
