{
  "name": "Security Container Registry Security Workflow",
  "description": "Automate container registry security scanning",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "container_images_to_scan": 58,
    "current_image": 0,
    "scanned_images": 0,
    "vulnerable_images": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "image_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize image counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open container registry"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for registry"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "registry_security_loop",
      "count": "{{container_images_to_scan}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start registry security loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select container image"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for image scan"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/container_registry_{{image_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture registry screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "image_counter",
      "value": "{{image_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment image counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{image_counter < container_images_to_scan}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more images"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next image"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_container_registry_security_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
