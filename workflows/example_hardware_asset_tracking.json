{
  "name": "Hardware Asset Tracking Workflow",
  "description": "Automate hardware asset inventory tracking",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "hardware_assets_to_track": 65,
    "current_asset": 0,
    "located_assets": 0,
    "missing_assets": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "asset_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize asset counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open asset management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "asset_tracking_loop",
      "count": "{{hardware_assets_to_track}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start asset tracking loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select hardware asset"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for asset check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/asset_track_{{asset_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture asset screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "asset_counter",
      "value": "{{asset_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment asset counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{asset_counter < hardware_assets_to_track}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more assets"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next asset"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/hardware_asset_tracking_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}