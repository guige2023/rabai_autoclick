{
  "name": "Rogue Device Detection Workflow",
  "description": "Automate rogue device detection on network",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "network_segments_to_scan": 22,
    "current_segment": 0,
    "authorized_count": 0,
    "rogue_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "segment_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize segment counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open network security"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for security"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "rogue_detection_loop",
      "count": "{{network_segments_to_scan}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start rogue detection loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Scan network segment"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for detection"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/rogue_device_detection_{{segment_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture detection screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "segment_counter",
      "value": "{{segment_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment segment counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{segment_counter < network_segments_to_scan}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more segments"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next segment"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/rogue_device_detection_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}