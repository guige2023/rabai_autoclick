{
  "name": "Logistics Shipment Tracking Workflow",
  "description": "Automate logistics shipment tracking from pickup to delivery confirmation",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "shipments_to_track": 50,
    "current_shipment": 0,
    "tracked_shipments": 0,
    "delayed_shipments": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "shipment_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize shipment counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open logistics tracking system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for system to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "tracking_loop",
      "count": "{{shipments_to_track}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start tracking loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open shipment tracking"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for tracking data"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/shipment_{{shipment_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture shipment screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Verify delivery status"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for verification"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Update tracking events"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for update"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Notify customer if needed"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for notification"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/tracking_updated_{{shipment_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture update confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "shipment_counter",
      "value": "{{shipment_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment shipment counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{shipment_counter < shipments_to_track}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more shipments"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next shipment"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/tracking_batch_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
