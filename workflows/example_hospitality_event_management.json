{
  "name": "Hospitality Event Management Workflow",
  "description": "Automate event management",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "events_to_coordinate": 46,
    "current_event": 0,
    "coordinated_events": 0,
    "pending_events": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "event_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize event counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open event management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "event_management_loop",
      "count": "{{events_to_coordinate}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start event management loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select event for coordination"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for coordination"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/event_management_{{event_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture event screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "event_counter",
      "value": "{{event_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment event counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{event_counter < events_to_coordinate}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more events"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next event"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/hospitality_event_management_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
