{
  "name": "Firmware Update Workflow",
  "description": "Automate firmware updates across multiple devices",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "devices_to_update": 12,
    "current_device": 0,
    "firmware_version": "2.5.0",
    "update_timeout": 300
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "device_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize device counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open device management console"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for console"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "update_loop",
      "count": "{{devices_to_update}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start update loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Click on device"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 0.5,
      "pre_delay": 0.2,
      "comment": "Wait for device details"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/device_{{device_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture device screenshot"
    },
    {
      "id": 8,
      "type": "click_image",
      "template": "./templates/update_firmware.png",
      "confidence": 0.80,
      "pre_delay": 0.5,
      "comment": "Click update firmware button"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for update to start"
    },
    {
      "id": 10,
      "type": "set_variable",
      "name": "device_counter",
      "value": "{{device_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment device counter"
    },
    {
      "id": 11,
      "type": "condition",
      "condition": "{{device_counter < devices_to_update}}",
      "true_next": 12,
      "false_next": 13,
      "pre_delay": 0.1,
      "comment": "Check if more devices"
    },
    {
      "id": 12,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next device"
    },
    {
      "id": 13,
      "type": "screenshot",
      "save_path": "./screenshots/firmware_update_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 14,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
