{
  "name": "NIST Framework Alignment Workflow",
  "description": "Automate NIST cybersecurity framework assessment",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "nist_functions_to_assess": 72,
    "current_function": 0,
    "aligned_functions": 0,
    "misaligned_functions": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "nist_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize NIST counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open NIST assessment tool"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for tool"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "nist_assessment_loop",
      "count": "{{nist_functions_to_assess}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start NIST assessment loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select NIST function"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for alignment check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/nist_assess_{{nist_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture NIST screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "nist_counter",
      "value": "{{nist_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment NIST counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{nist_counter < nist_functions_to_assess}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more functions"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next function"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/nist_framework_alignment_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}