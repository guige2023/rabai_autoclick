{
  "name": "Security Threat Intelligence Platform Workflow",
  "description": "Automate threat intelligence platform management",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "threat_indicators_to_process": 56,
    "current_indicator": 0,
    "processed_indicators": 0,
    "high_confidence_indicators": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "indicator_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize indicator counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open threat intelligence platform"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for platform"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "tip_management_loop",
      "count": "{{threat_indicators_to_process}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start TIP management loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select threat indicator"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for indicator processing"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/tip_indicator_{{indicator_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture TIP screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "indicator_counter",
      "value": "{{indicator_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment indicator counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{indicator_counter < threat_indicators_to_process}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more indicators"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next indicator"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_threat_intelligence_platform_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
