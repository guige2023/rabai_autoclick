{
  "name": "Security Security Strategy Development Workflow",
  "description": "Automate security strategy development",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "strategy_initiatives_to_develop": 52,
    "current_initiative": 0,
    "developed_initiatives": 0,
    "pending_initiatives": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "initiative_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize initiative counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open strategy development platform"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for platform"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "strategy_development_loop",
      "count": "{{strategy_initiatives_to_develop}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start strategy development loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select initiative"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for strategy development"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/strategy_development_{{initiative_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture strategy screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "initiative_counter",
      "value": "{{initiative_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment initiative counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{initiative_counter < strategy_initiatives_to_develop}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more initiatives"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next initiative"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_security_strategy_development_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
