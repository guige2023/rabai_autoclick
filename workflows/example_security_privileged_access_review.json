{
  "name": "Security Privileged Access Review Workflow",
  "description": "Automate privileged access monitoring and review",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "privileged_accounts_to_review": 42,
    "current_account": 0,
    "approved_access": 0,
    "suspicious_access": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "account_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize account counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open privileged access management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "privileged_access_loop",
      "count": "{{privileged_accounts_to_review}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start privileged access review loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select privileged account"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for access review"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/privileged_access_{{account_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture privileged access screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "account_counter",
      "value": "{{account_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment account counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{account_counter < privileged_accounts_to_review}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more accounts"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next account"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_privileged_access_review_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
