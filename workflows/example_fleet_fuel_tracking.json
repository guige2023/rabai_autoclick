{
  "name": "Fleet Fuel Tracking Workflow",
  "description": "Automate fleet fuel consumption tracking",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "fuel_records": 46,
    "current_record": 0,
    "tracked_records": 0,
    "fuel_alerts": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "fuel_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize fuel counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open fuel tracking system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "fuel_tracking_loop",
      "count": "{{fuel_records}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start fuel tracking loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select fuel record for tracking"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for tracking"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/fuel_tracking_{{fuel_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture fuel screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "fuel_counter",
      "value": "{{fuel_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment fuel counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{fuel_counter < fuel_records}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more records"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next record"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/fleet_fuel_tracking_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
