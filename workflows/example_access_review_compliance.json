{
  "name": "Access Review Compliance Workflow",
  "description": "Automate periodic access rights review",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "access_rights_to_review": 55,
    "current_right": 0,
    "approved_rights": 0,
    "revoked_rights": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "right_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize right counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open access review system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "access_review_loop",
      "count": "{{access_rights_to_review}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start access review loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select access right"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for right check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/access_review_{{right_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture review screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "right_counter",
      "value": "{{right_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment right counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{right_counter < access_rights_to_review}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more rights"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next right"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/access_review_compliance_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}