{
  "name": "Dynamic Analysis Security Workflow",
  "description": "Automate dynamic application security testing",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "endpoints_to_test": 58,
    "current_endpoint": 0,
    "secure_endpoints": 0,
    "vulnerable_endpoints": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "dast_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize DAST counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open DAST scanner"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for scanner"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "dast_test_loop",
      "count": "{{endpoints_to_test}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start DAST test loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select endpoint"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for security test"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/dast_test_{{dast_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture DAST screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "dast_counter",
      "value": "{{dast_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment DAST counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{dast_counter < endpoints_to_test}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more endpoints"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next endpoint"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/dynamic_analysis_security_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}