{
  "name": "IoT Firmware Update Workflow",
  "description": "Automate IoT firmware updates",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "devices_to_update": 48,
    "current_device": 0,
    "updated_devices": 0,
    "failed_updates": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "update_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize update counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open firmware update system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "firmware_update_loop",
      "count": "{{devices_to_update}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start firmware update loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select device for update"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for update"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/firmware_update_{{update_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture update screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "update_counter",
      "value": "{{update_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment update counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{update_counter < devices_to_update}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more devices"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next device"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/iot_firmware_update_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
