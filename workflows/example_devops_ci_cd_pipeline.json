{
  "name": "DevOps CI/CD Pipeline Workflow",
  "description": "Automate CI/CD pipeline execution",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "pipelines_to_execute": 47,
    "current_pipeline": 0,
    "executed_pipelines": 0,
    "failed_pipelines": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "pipeline_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize pipeline counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open CI/CD dashboard"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for dashboard"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "ci_cd_pipeline_loop",
      "count": "{{pipelines_to_execute}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start CI/CD pipeline loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select pipeline for execution"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for execution"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/ci_cd_pipeline_{{pipeline_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture pipeline screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "pipeline_counter",
      "value": "{{pipeline_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment pipeline counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{pipeline_counter < pipelines_to_execute}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more pipelines"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next pipeline"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/devops_ci_cd_pipeline_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
