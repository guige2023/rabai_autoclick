{
  "name": "API API Documentation Update Workflow",
  "description": "Automate API documentation validation",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "docs_to_validate": 46,
    "current_doc": 0,
    "validated_docs": 0,
    "outdated_docs": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "doc_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize documentation counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open API documentation portal"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for portal"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "doc_validation_loop",
      "count": "{{docs_to_validate}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start documentation validation loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select API doc for validation"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for doc validation"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/doc_validation_{{doc_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture doc screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "doc_counter",
      "value": "{{doc_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment doc counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{doc_counter < docs_to_validate}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more docs"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next doc"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/api_api_documentation_update_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
