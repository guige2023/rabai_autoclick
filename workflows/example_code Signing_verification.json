{
  "name": "Code Signing Verification Workflow",
  "description": "Automate code signing certificate validation",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "signed_artifacts_to_verify": 48,
    "current_artifact": 0,
    "valid_signatures": 0,
    "invalid_signatures": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "signature_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize signature counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open code signing verification tool"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for tool"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "signature_verification_loop",
      "count": "{{signed_artifacts_to_verify}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start signature verification loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select signed artifact"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for signature check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/signature_verify_{{signature_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture signature screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "signature_counter",
      "value": "{{signature_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment signature counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{signature_counter < signed_artifacts_to_verify}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more artifacts"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next artifact"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/code_signing_verification_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}