{
  "name": "S3 Bucket Security Audit Workflow",
  "description": "Automate AWS S3 bucket permission verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "s3_buckets_to_audit": 52,
    "current_bucket": 0,
    "secure_buckets": 0,
    "public_buckets": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "s3_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize S3 counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open AWS S3 console"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for console"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "s3_audit_loop",
      "count": "{{s3_buckets_to_audit}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start S3 audit loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select S3 bucket"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for permission check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/s3_audit_{{s3_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture S3 screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "s3_counter",
      "value": "{{s3_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment S3 counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{s3_counter < s3_buckets_to_audit}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more buckets"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next bucket"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/s3_bucket_security_audit_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}