{
  "name": "Infrastructure Hardware Inventory Workflow",
  "description": "Automate hardware inventory management",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "hardware_items_to_inventory": 52,
    "current_item": 0,
    "inventoried_items": 0,
    "missing_items": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "inventory_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize inventory counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open inventory management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "inventory_loop",
      "count": "{{hardware_items_to_inventory}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start inventory loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select hardware item"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for inventory check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/hardware_inventory_{{inventory_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture inventory screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "inventory_counter",
      "value": "{{inventory_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment inventory counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{inventory_counter < hardware_items_to_inventory}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more items"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next item"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/infrastructure_hardware_inventory_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
