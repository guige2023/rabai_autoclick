{
  "name": "Release Rollback Planning Workflow",
  "description": "Automate rollback procedure documentation",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "services_to_plan": 46,
    "current_service": 0,
    "planned_services": 0,
    "complex_rollbacks": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "rollback_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize rollback counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open rollback planning system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "rollback_planning_loop",
      "count": "{{services_to_plan}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start rollback planning loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select service for rollback planning"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for planning"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/rollback_planning_{{rollback_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture rollback screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "rollback_counter",
      "value": "{{rollback_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment rollback counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{rollback_counter < services_to_plan}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more services"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next service"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/release_rollback_planning_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
