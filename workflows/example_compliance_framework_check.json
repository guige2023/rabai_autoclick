{
  "name": "Compliance Framework Check Workflow",
  "description": "Automate compliance framework requirement verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "requirements_to_check": 50,
    "current_requirement": 0,
    "met_count": 0,
    " unmet_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "req_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize requirement counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open compliance framework"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for framework"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "framework_check_loop",
      "count": "{{requirements_to_check}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start requirement check loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select requirement"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for verification"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/compliance_req_{{req_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture requirement screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "req_counter",
      "value": "{{req_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment requirement counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{req_counter < requirements_to_check}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more requirements"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next requirement"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/compliance_framework_check_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}