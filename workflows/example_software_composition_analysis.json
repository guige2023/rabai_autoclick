{
  "name": "Software Composition Analysis Workflow",
  "description": "Automate dependency vulnerability scanning",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "dependencies_to_scan": 75,
    "current_dep": 0,
    "secure_deps": 0,
    "vulnerable_deps": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "sca_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize SCA counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open dependency scanner"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for scanner"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "sca_scan_loop",
      "count": "{{dependencies_to_scan}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start SCA scan loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select dependency"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for vulnerability check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/sca_scan_{{sca_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture SCA screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "sca_counter",
      "value": "{{sca_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment SCA counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{sca_counter < dependencies_to_scan}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more deps"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next dep"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/software_composition_analysis_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}