{
  "name": "Security Backup Security Audit Workflow",
  "description": "Automate backup security auditing",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "backups_to_audit": 50,
    "current_backup": 0,
    "secure_backups": 0,
    "vulnerable_backups": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "backup_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize backup counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open backup management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "backup_audit_loop",
      "count": "{{backups_to_audit}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start backup audit loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select backup for audit"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for backup check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/backup_audit_{{backup_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture backup audit screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "backup_counter",
      "value": "{{backup_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment backup counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{backup_counter < backups_to_audit}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more backups"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next backup"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_backup_security_audit_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
