{
  "name": "Banking Fraud Detection Workflow",
  "description": "Automate banking fraud detection",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "transactions_to_analyze": 51,
    "current_transaction": 0,
    "analyzed_transactions": 0,
    "fraud_alerts": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "fraud_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize fraud counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open fraud detection system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "fraud_detection_loop",
      "count": "{{transactions_to_analyze}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start fraud detection loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select transaction for analysis"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for analysis"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/fraud_analysis_{{fraud_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture analysis screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "fraud_counter",
      "value": "{{fraud_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment fraud counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{fraud_counter < transactions_to_analyze}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more transactions"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next transaction"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/banking_fraud_detection_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
