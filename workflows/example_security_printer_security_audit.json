{
  "name": "Security Printer Security Audit Workflow",
  "description": "Automate printer security auditing",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "printers_to_audit": 52,
    "current_printer": 0,
    "secure_printers": 0,
    "vulnerable_printers": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "printer_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize printer counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open printer management console"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for console"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "printer_audit_loop",
      "count": "{{printers_to_audit}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start printer audit loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select printer for audit"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for printer check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/printer_audit_{{printer_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture printer screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "printer_counter",
      "value": "{{printer_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment printer counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{printer_counter < printers_to_audit}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more printers"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next printer"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_printer_security_audit_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
