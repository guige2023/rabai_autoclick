{
  "name": "Multi-Factor Authentication Audit Workflow",
  "description": "Automate MFA enrollment and compliance verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "users_to_audit": 68,
    "current_user": 0,
    "mfa_enabled": 0,
    "mfa_not_enabled": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "mfa_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize MFA counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open MFA management portal"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for portal"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "mfa_audit_loop",
      "count": "{{users_to_audit}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start MFA audit loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select user account"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for MFA check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/mfa_audit_{{mfa_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture MFA screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "mfa_counter",
      "value": "{{mfa_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment MFA counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{mfa_counter < users_to_audit}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more users"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next user"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/multi_factor_auth_audit_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}