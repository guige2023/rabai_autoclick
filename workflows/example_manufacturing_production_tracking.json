{
  "name": "Manufacturing Production Tracking Workflow",
  "description": "Automate manufacturing production tracking",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "production_runs": 60,
    "current_run": 0,
    "tracked_runs": 0,
    "quality_issues": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "production_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize production counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open production tracking system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "production_tracking_loop",
      "count": "{{production_runs}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start production tracking loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select production run for tracking"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for tracking update"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/production_tracking_{{production_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture production screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "production_counter",
      "value": "{{production_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment production counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{production_counter < production_runs}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more runs"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next run"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/manufacturing_production_tracking_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
