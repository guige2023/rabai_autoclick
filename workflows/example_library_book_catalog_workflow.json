{
  "name": "Library Book Catalog Workflow",
  "description": "Automate library book catalog management including cataloging, classification, and inventory",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "books_to_catalog": 50,
    "current_book": 0,
    "cataloged_books": 0,
    "missing_items": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "book_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize book counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open library management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for system to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "cataloging_loop",
      "count": "{{books_to_catalog}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start cataloging loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Scan book barcode"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for scan"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/book_{{book_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture book screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Verify bibliographic data"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for verification"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Assign classification"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for assignment"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Update catalog record"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for update"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/book_cataloged_{{book_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture catalog confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "book_counter",
      "value": "{{book_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment book counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{book_counter < books_to_catalog}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more books"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next book"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/cataloging_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
