{
  "name": "Hydroelectric Water Level Monitoring Workflow",
  "description": "Automate hydroelectric water level monitoring",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "monitoring_stations": 51,
    "current_station": 0,
    "monitored_stations": 0,
    "flood_warnings": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "station_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize station counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open water level monitoring system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "water_level_monitoring_loop",
      "count": "{{monitoring_stations}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start water level monitoring loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select station for monitoring"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for monitoring"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/water_level_monitoring_{{station_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture monitoring screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "station_counter",
      "value": "{{station_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment station counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{station_counter < monitoring_stations}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more stations"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next station"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/hydro_water_level_monitoring_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
