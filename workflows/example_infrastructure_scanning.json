{
  "name": "Infrastructure Scanning Workflow",
  "description": "Automate infrastructure security scanning",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "infrastructure_assets_to_scan": 68,
    "current_asset": 0,
    "secure_assets": 0,
    "vulnerable_assets": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "infra_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize infra counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open infrastructure scanner"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for scanner"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "infrastructure_scan_loop",
      "count": "{{infrastructure_assets_to_scan}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start infrastructure scan loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select infrastructure asset"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for vulnerability scan"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/infra_scan_{{infra_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture infra screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "infra_counter",
      "value": "{{infra_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment infra counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{infra_counter < infrastructure_assets_to_scan}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more assets"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next asset"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/infrastructure_scanning_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}