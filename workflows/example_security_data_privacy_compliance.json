{
  "name": "Security Data Privacy Compliance Workflow",
  "description": "Automate data privacy compliance verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "privacy_controls_to_verify": 56,
    "current_control": 0,
    "verified_controls": 0,
    "non_compliant_controls": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "control_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize control counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open privacy compliance platform"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for platform"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "privacy_compliance_loop",
      "count": "{{privacy_controls_to_verify}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start privacy compliance loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select privacy control"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for verification"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/privacy_control_{{control_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture privacy screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "control_counter",
      "value": "{{control_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment control counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{control_counter < privacy_controls_to_verify}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more controls"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next control"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_data_privacy_compliance_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
