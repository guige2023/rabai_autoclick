{
  "name": "Survey Response Collection Workflow",
  "description": "Automate survey response collection including distribution, tracking, and response aggregation",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "surveys_to_collect": 40,
    "current_survey": 0,
    "collected_responses": 0,
    "pending_responses": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "survey_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize survey counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open survey management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for system to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "collection_loop",
      "count": "{{surveys_to_collect}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start survey collection loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open survey campaign"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for campaign"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/survey_{{survey_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture survey screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Track response rate"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for tracking"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Send reminders if needed"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for reminders"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Aggregate responses"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for aggregation"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/survey_results_{{survey_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture results"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "survey_counter",
      "value": "{{survey_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment survey counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{survey_counter < surveys_to_collect}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more surveys"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next survey"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/survey_collection_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
