{
  "name": "Security Test Coverage Verification Workflow",
  "description": "Automate security test coverage analysis",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "test_cases_to_verify": 68,
    "current_test": 0,
    "covered_tests": 0,
    "uncovered_tests": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "coverage_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize coverage counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open test coverage platform"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for platform"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "coverage_verification_loop",
      "count": "{{test_cases_to_verify}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start coverage verification loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select test case"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for coverage check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/coverage_verify_{{coverage_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture coverage screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "coverage_counter",
      "value": "{{coverage_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment coverage counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{coverage_counter < test_cases_to_verify}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more tests"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next test"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_test_coverage_verification_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}