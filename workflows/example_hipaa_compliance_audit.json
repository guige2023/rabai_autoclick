{
  "name": "HIPAA Compliance Audit Workflow",
  "description": "Automate HIPAA requirement verification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "hipaa_safeguards_to_check": 45,
    "current_safeguard": 0,
    "implemented_safeguards": 0,
    "missing_safeguards": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "hipaa_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize HIPAA counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open HIPAA compliance system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "hipaa_audit_loop",
      "count": "{{hipaa_safeguards_to_check}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start HIPAA audit loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select HIPAA safeguard"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for safeguard check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/hipaa_audit_{{hipaa_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture HIPAA screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "hipaa_counter",
      "value": "{{hipaa_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment HIPAA counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{hipaa_counter < hipaa_safeguards_to_check}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more safeguards"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next safeguard"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/hipaa_compliance_audit_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}