{
  "name": "Security User Behavior Analytics Workflow",
  "description": "Automate user behavior analytics and anomaly detection",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "users_to_analyze": 58,
    "current_user": 0,
    "analyzed_users": 0,
    "anomalous_behaviors": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "user_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize user counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open UBA platform"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for platform"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "uba_analysis_loop",
      "count": "{{users_to_analyze}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start UBA analysis loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select user for analysis"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for behavior analysis"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/uba_analysis_{{user_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture UBA screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "user_counter",
      "value": "{{user_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment user counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{user_counter < users_to_analyze}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more users"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next user"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_user_behavior_analytics_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
