{
  "name": "Network VPN Management Workflow",
  "description": "Automate VPN connection management",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "vpn_connections_to_manage": 46,
    "current_connection": 0,
    "managed_connections": 0,
    "connection_issues": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "vpn_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize VPN counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open VPN management portal"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for portal"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "vpn_management_loop",
      "count": "{{vpn_connections_to_manage}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start VPN management loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select VPN connection"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for management action"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/vpn_connection_{{vpn_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture VPN screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "vpn_counter",
      "value": "{{vpn_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment VPN counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{vpn_counter < vpn_connections_to_manage}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more connections"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next connection"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/network_vpn_management_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
