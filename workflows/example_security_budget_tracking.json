{
  "name": "Security Budget Tracking Workflow",
  "description": "Automate security budget allocation monitoring",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "budget_items_to_track": 65,
    "current_item": 0,
    "within_budget": 0,
    "over_budget": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "budget_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize budget counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open budget management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "budget_tracking_loop",
      "count": "{{budget_items_to_track}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start budget tracking loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select budget item"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for budget check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/budget_track_{{budget_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture budget screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "budget_counter",
      "value": "{{budget_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment budget counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{budget_counter < budget_items_to_track}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more items"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next item"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_budget_tracking_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}