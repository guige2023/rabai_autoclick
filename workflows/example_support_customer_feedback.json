{
  "name": "Support Customer Feedback Workflow",
  "description": "Automate customer feedback analysis",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "feedback_items_to_analyze": 52,
    "current_feedback": 0,
    "analyzed_feedback": 0,
    "negative_feedback": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "feedback_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize feedback counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open feedback management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "feedback_analysis_loop",
      "count": "{{feedback_items_to_analyze}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start feedback analysis loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select feedback item"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for analysis"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/feedback_analysis_{{feedback_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture feedback screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "feedback_counter",
      "value": "{{feedback_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment feedback counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{feedback_counter < feedback_items_to_analyze}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more feedback"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next feedback"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/support_customer_feedback_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
