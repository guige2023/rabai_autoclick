{
  "name": "Analytics KPI Monitoring Workflow",
  "description": "Automate KPI monitoring and alerting",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "kpis_to_monitor": 48,
    "current_kpi": 0,
    "monitored_kpis": 0,
    "alert_triggered": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "kpi_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize KPI counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open KPI dashboard"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for dashboard"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "kpi_monitoring_loop",
      "count": "{{kpis_to_monitor}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start KPI monitoring loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select KPI for monitoring"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/kpi_{{kpi_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture KPI screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "kpi_counter",
      "value": "{{kpi_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment KPI counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{kpi_counter < kpis_to_monitor}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more KPIs"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next KPI"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/analytics_kpi_monitoring_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
