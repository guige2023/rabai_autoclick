{
  "name": "Incident Resolution Tracking Workflow",
  "description": "Automate incident resolution progress tracking",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "incidents_to_track": 25,
    "current_incident": 0,
    "resolved_count": 0,
    "in_progress_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "incident_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize incident counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open incident management"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for management"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "incident_tracking_loop",
      "count": "{{incidents_to_track}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start incident tracking loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select incident"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for status check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/incident_tracking_{{incident_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture tracking screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "incident_counter",
      "value": "{{incident_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment incident counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{incident_counter < incidents_to_track}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more incidents"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next incident"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/incident_resolution_tracking_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}