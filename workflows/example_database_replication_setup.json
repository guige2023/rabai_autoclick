{
  "name": "Database Replication Setup Workflow",
  "description": "Automate database replication setup",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "replications_to_setup": 44,
    "current_replication": 0,
    "setup_replications": 0,
    "failed_setups": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "replication_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize replication counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open replication management system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "replication_setup_loop",
      "count": "{{replications_to_setup}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start replication setup loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select replication for setup"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for setup"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/replication_setup_{{replication_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture setup screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "replication_counter",
      "value": "{{replication_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment replication counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{replication_counter < replications_to_setup}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more replications"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next replication"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/database_replication_setup_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
