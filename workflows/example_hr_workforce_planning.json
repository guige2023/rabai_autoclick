{
  "name": "HR Workforce Planning Workflow",
  "description": "Automate workforce planning",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "plans_to_create": 44,
    "current_plan": 0,
    "created_plans": 0,
    "failed_plans": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "workforce_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize workforce counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open workforce planning system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "workforce_planning_loop",
      "count": "{{plans_to_create}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start workforce planning loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select plan for creation"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for planning"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/workforce_planning_{{workforce_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture planning screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "workforce_counter",
      "value": "{{workforce_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment workforce counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{workforce_counter < plans_to_create}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more plans"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next plan"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/hr_workforce_planning_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
