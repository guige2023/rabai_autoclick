{
  "name": "Security Architecture Review Workflow",
  "description": "Automate security architecture validation",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "architecture_components_to_review": 52,
    "current_component": 0,
    "secure_components": 0,
    "weak_components": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "arch_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize arch counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open architecture review tool"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for tool"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "arch_review_loop",
      "count": "{{architecture_components_to_review}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start architecture review loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select architecture component"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for review"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/arch_review_{{arch_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture arch screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "arch_counter",
      "value": "{{arch_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment arch counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{arch_counter < architecture_components_to_review}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more components"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next component"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_architecture_review_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}