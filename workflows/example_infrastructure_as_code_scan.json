{
  "name": "Infrastructure as Code Scan Workflow",
  "description": "Automate IaC security scanning",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "iac_files_to_scan": 28,
    "current_file": 0,
    "secure_count": 0,
    "issues_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "file_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize file counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open IaC scanner"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for scanner"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "iac_scan_loop",
      "count": "{{iac_files_to_scan}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start IaC scan loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select IaC file"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for scan"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/iac_scan_{{file_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture scan screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "file_counter",
      "value": "{{file_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment file counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{file_counter < iac_files_to_scan}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more files"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next file"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/infrastructure_as_code_scan_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}