{
  "name": "Security Awareness Metrics Workflow",
  "description": "Automate security awareness program metrics collection",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "training_modules": 15,
    "current_module": 0,
    "completed_count": 0,
    "pending_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "module_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize module counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open security awareness portal"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for portal"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "awareness_metrics_loop",
      "count": "{{training_modules}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start metrics collection loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select training module"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for metrics check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/awareness_metrics_{{module_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture metrics screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "module_counter",
      "value": "{{module_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment module counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{module_counter < training_modules}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more modules"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next module"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_awareness_metrics_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}