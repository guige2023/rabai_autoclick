{
  "name": "User Access Review Workflow",
  "description": "Automate user access review including permission auditing and compliance certification",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "users_to_review": 45,
    "current_user": 0,
    "reviewed_users": 0,
    "revoked_access": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "user_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize user counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open IAM access review system"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for system to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "access_review_loop",
      "count": "{{users_to_review}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start access review loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open user access profile"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for profile"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/access_review_{{user_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture access screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Review current permissions"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for review"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Verify business justification"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for verification"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Certify or revoke access"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for certification"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/access_certified_{{user_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture certification confirmation"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "user_counter",
      "value": "{{user_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment user counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{user_counter < users_to_review}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more users"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next user"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/access_review_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
