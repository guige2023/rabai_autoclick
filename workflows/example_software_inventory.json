{
  "name": "Software Inventory Audit Workflow",
  "description": "Automate software inventory compliance checking",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "software_to_audit": 30,
    "current_software": 0,
    "licensed_count": 0,
    "unlicensed_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "software_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize software counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open software inventory"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for inventory"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "software_loop",
      "count": "{{software_to_audit}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start software audit loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Click software entry"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.3,
      "comment": "Wait for license check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/software_{{software_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture software screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "software_counter",
      "value": "{{software_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment software counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{software_counter < software_to_audit}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more software"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next software"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/software_inventory_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
