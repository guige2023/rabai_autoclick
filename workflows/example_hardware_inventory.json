{
  "name": "Hardware Asset Inventory Workflow",
  "description": "Automate hardware asset inventory tracking",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "hardware_items": 45,
    "current_item": 0,
    "registered_count": 0,
    "unregistered_count": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "hw_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize hardware counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open asset management"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for system"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "hw_inventory_loop",
      "count": "{{hardware_items}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start hardware inventory loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select hardware item"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for inventory check"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/hardware_inventory_{{hw_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture inventory screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "hw_counter",
      "value": "{{hw_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment hardware counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{hw_counter < hardware_items}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more items"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next item"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/hardware_inventory_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}