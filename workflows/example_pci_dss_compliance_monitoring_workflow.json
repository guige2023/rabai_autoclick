{
  "name": "PCI DSS Compliance Monitoring Workflow",
  "description": "Automate PCI DSS compliance monitoring including security control verification and vulnerability scanning",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "controls_to_verify": 50,
    "current_control": 0,
    "verified_controls": 0,
    "failed_controls": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "control_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize control counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open compliance dashboard"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 3.0,
      "pre_delay": 0.5,
      "comment": "Wait for dashboard to load"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "compliance_loop",
      "count": "{{controls_to_verify}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start compliance verification loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 160,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Open control requirement"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for requirement"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/pci_control_{{control_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture control screenshot"
    },
    {
      "id": 8,
      "type": "click",
      "x": 340,
      "y": 230,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Verify current implementation"
    },
    {
      "id": 9,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for verification"
    },
    {
      "id": 10,
      "type": "click",
      "x": 460,
      "y": 300,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Check evidence documentation"
    },
    {
      "id": 11,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.2,
      "comment": "Wait for check"
    },
    {
      "id": 12,
      "type": "click",
      "x": 580,
      "y": 370,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Update compliance status"
    },
    {
      "id": 13,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.2,
      "comment": "Wait for update"
    },
    {
      "id": 14,
      "type": "screenshot",
      "save_path": "./screenshots/compliance_status_{{control_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture status update"
    },
    {
      "id": 15,
      "type": "set_variable",
      "name": "control_counter",
      "value": "{{control_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment control counter"
    },
    {
      "id": 16,
      "type": "condition",
      "condition": "{{control_counter < controls_to_verify}}",
      "true_next": 17,
      "false_next": 18,
      "pre_delay": 0.1,
      "comment": "Check if more controls"
    },
    {
      "id": 17,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next control"
    },
    {
      "id": 18,
      "type": "screenshot",
      "save_path": "./screenshots/pci_dss_compliance_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 19,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 3
  }
}
