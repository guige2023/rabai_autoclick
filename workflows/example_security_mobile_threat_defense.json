{
  "name": "Security Mobile Threat Defense Workflow",
  "description": "Automate mobile threat defense operations",
  "version": "1.0",
  "author": "RabAI Team",
  "variables": {
    "mobile_devices_to_defend": 54,
    "current_device": 0,
    "protected_devices": 0,
    "threats_detected": 0
  },
  "steps": [
    {
      "id": 1,
      "type": "set_variable",
      "name": "device_counter",
      "value": 0,
      "value_type": "int",
      "pre_delay": 1.0,
      "comment": "Initialize device counter"
    },
    {
      "id": 2,
      "type": "click",
      "x": 100,
      "y": 100,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.3,
      "comment": "Open mobile threat defense platform"
    },
    {
      "id": 3,
      "type": "delay",
      "seconds": 2.0,
      "pre_delay": 0.5,
      "comment": "Wait for platform"
    },
    {
      "id": 4,
      "type": "loop",
      "loop_id": "mobile_defense_loop",
      "count": "{{mobile_devices_to_defend}}",
      "loop_start": 5,
      "pre_delay": 0.3,
      "comment": "Start mobile defense loop"
    },
    {
      "id": 5,
      "type": "click",
      "x": 200,
      "y": 200,
      "button": "left",
      "clicks": 1,
      "pre_delay": 0.4,
      "comment": "Select mobile device"
    },
    {
      "id": 6,
      "type": "delay",
      "seconds": 1.5,
      "pre_delay": 0.3,
      "comment": "Wait for threat scan"
    },
    {
      "id": 7,
      "type": "screenshot",
      "save_path": "./screenshots/mobile_defense_{{device_counter}}.png",
      "pre_delay": 0.5,
      "comment": "Capture mobile defense screenshot"
    },
    {
      "id": 8,
      "type": "set_variable",
      "name": "device_counter",
      "value": "{{device_counter + 1}}",
      "value_type": "expression",
      "pre_delay": 0.2,
      "comment": "Increment device counter"
    },
    {
      "id": 9,
      "type": "condition",
      "condition": "{{device_counter < mobile_devices_to_defend}}",
      "true_next": 10,
      "false_next": 11,
      "pre_delay": 0.1,
      "comment": "Check if more devices"
    },
    {
      "id": 10,
      "type": "goto",
      "step_id": 4,
      "pre_delay": 0.1,
      "comment": "Continue to next device"
    },
    {
      "id": 11,
      "type": "screenshot",
      "save_path": "./screenshots/security_mobile_threat_defense_complete.png",
      "pre_delay": 0.5,
      "comment": "Capture completion screenshot"
    },
    {
      "id": 12,
      "type": "delay",
      "seconds": 1.0,
      "pre_delay": 0.5,
      "comment": "Final delay"
    }
  ],
  "settings": {
    "loop_count": 1,
    "retry_on_failure": true,
    "max_retries": 2
  }
}
