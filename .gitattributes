# Git attributes for RabAI AutoClick

# Set default behavior for text files
* text=auto

# Explicitly declare text files
*.py text
*.md text
*.txt text
*.json text
*.yaml text
*.yml text
*.sh text eol=lf
*.bash text eol=lf

# Declare files that will always have CRLF line endings on checkout
*.bat text eol=crlf

# Denote all files that are truly binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.icns binary
*.dmg binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary

# Exclude large binary files from diff
*.png binary
*.jpg binary
*.jpeg binary

# Export ignore
.gitattributes export-ignore
.gitignore export-ignore
